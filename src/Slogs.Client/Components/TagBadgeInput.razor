@inject SlogsApiClient ApiClient

<div class="tag-badge-input" data-tag-input>
    <div class="tag-badge-input__control">
        <div class="tag-badge-input__surface">
            @foreach (var tag in selectedTags)
            {
                <span class="tag-badge-input__badge" data-tag-badge="@tag">
                    <span>#@tag</span>
                    <button type="button"
                            class="tag-badge-input__remove"
                            aria-label="@($"{tag} 태그 제거")"
                            @onclick="() => RemoveTagAsync(tag)">
                        ×
                    </button>
                </span>
            }
            <input id="@InputId"
                   class="tag-badge-input__field"
                   value="@pendingTag"
                   disabled="@IsFull"
                   placeholder="@InputPlaceholder"
                   autocomplete="off"
                   inputmode="text"
                   lang="ko"
                   spellcheck="false"
                   @oninput="HandleInputAsync"
                   @onkeydown="HandleKeyDownAsync"
                   @onkeyup="HandleKeyUpAsync" />
        </div>

        @if (ShouldShowSuggestions)
        {
            <div class="tag-badge-input__menu" role="listbox" aria-label="기존 태그 추천">
                @foreach (var item in visibleSuggestions)
                {
                    <button type="button"
                            class="tag-badge-input__suggestion"
                            data-tag-suggestion="@item.Tag"
                            role="option"
                            @onclick="() => AddTagAsync(item.Tag)">
                        <span>#@item.Tag</span>
                        <span>@item.Count</span>
                    </button>
                }
            </div>
        }
    </div>

    <div class="tag-badge-input__meta">
        <span>@($"{selectedTags.Count}/{MaxTags}")</span>
        @if (IsFull)
        {
            <span>태그는 최대 @(MaxTags)개까지 사용할 수 있습니다.</span>
        }
        else
        {
            <span>Enter 또는 쉼표로 추가</span>
        }
    </div>
</div>

@code {
    private readonly List<string> selectedTags = [];
    private IReadOnlyList<(string Tag, int Count)> existingTags = [];
    private IReadOnlyList<(string Tag, int Count)> visibleSuggestions = [];
    private string pendingTag = string.Empty;
    private string lastValue = "\u0000";

    [Parameter] public string? Id { get; set; }
    [Parameter] public string? Value { get; set; }
    [Parameter] public EventCallback<string> ValueChanged { get; set; }
    [Parameter] public string Placeholder { get; set; } = "태그 선택 또는 입력";
    [Parameter] public int MaxTags { get; set; } = 5;

    private string InputId => string.IsNullOrWhiteSpace(Id)
        ? $"tag-input-{GetHashCode():x}"
        : Id;

    private bool IsFull => selectedTags.Count >= MaxTags;

    private bool ShouldShowSuggestions => !IsFull && visibleSuggestions.Count > 0;

    private string InputPlaceholder => selectedTags.Count == 0
        ? Placeholder
        : IsFull ? "태그 최대 개수" : "태그 추가";

    protected override async Task OnInitializedAsync()
    {
        existingTags = await ApiClient.GetTagCloudAsync(50);
        RefreshSuggestions();
    }

    protected override void OnParametersSet()
    {
        var incomingTags = ParseTags(Value ?? string.Empty).Take(MaxTags).ToList();
        var normalizedValue = string.Join(", ", incomingTags);
        if (string.Equals(lastValue, normalizedValue, StringComparison.Ordinal))
        {
            RefreshSuggestions();
            return;
        }

        selectedTags.Clear();
        selectedTags.AddRange(incomingTags);
        lastValue = normalizedValue;
        RefreshSuggestions();
    }

    private async Task HandleInputAsync(ChangeEventArgs args)
    {
        var value = args.Value?.ToString() ?? string.Empty;
        if (!value.Contains(','))
        {
            pendingTag = value;
            RefreshSuggestions();
            return;
        }

        var parts = value.Split(',');
        var changed = false;
        for (var index = 0; index < parts.Length - 1; index++)
        {
            changed |= AddTag(parts[index]);
        }

        pendingTag = parts[^1].Trim();
        RefreshSuggestions();

        if (changed)
        {
            await NotifyTagsChangedAsync();
        }
    }

    private async Task HandleKeyDownAsync(KeyboardEventArgs args)
    {
        if (args.IsComposing)
        {
            return;
        }

        if (args.Key is "Enter" or "NumpadEnter")
        {
            await AddTagAsync(pendingTag);
        }
        else if (args.Key is "Backspace" && string.IsNullOrWhiteSpace(pendingTag) && selectedTags.Count > 0)
        {
            selectedTags.RemoveAt(selectedTags.Count - 1);
            await NotifyTagsChangedAsync();
        }
    }

    private async Task HandleKeyUpAsync(KeyboardEventArgs args)
    {
        if (args.Key is not ("Enter" or "NumpadEnter") || args.IsComposing || string.IsNullOrWhiteSpace(pendingTag))
        {
            return;
        }

        await AddTagAsync(pendingTag);
    }

    private async Task AddTagAsync(string tag)
    {
        if (AddTag(tag))
        {
            await NotifyTagsChangedAsync();
            return;
        }

        pendingTag = string.Empty;
        RefreshSuggestions();
    }

    private bool AddTag(string tag)
    {
        if (IsFull)
        {
            return false;
        }

        var normalizedTag = NormalizeTag(tag);
        if (string.IsNullOrWhiteSpace(normalizedTag)
            || selectedTags.Contains(normalizedTag, StringComparer.OrdinalIgnoreCase))
        {
            return false;
        }

        selectedTags.Add(normalizedTag);
        pendingTag = string.Empty;
        RefreshSuggestions();
        return true;
    }

    private async Task RemoveTagAsync(string tag)
    {
        selectedTags.RemoveAll(x => string.Equals(x, tag, StringComparison.OrdinalIgnoreCase));
        RefreshSuggestions();
        await NotifyTagsChangedAsync();
    }

    private async Task NotifyTagsChangedAsync()
    {
        lastValue = SerializeTags();
        await ValueChanged.InvokeAsync(lastValue);
    }

    private void RefreshSuggestions()
    {
        var filter = NormalizeTag(pendingTag);
        visibleSuggestions = existingTags
            .Where(x => !selectedTags.Contains(x.Tag, StringComparer.OrdinalIgnoreCase))
            .Where(x => string.IsNullOrWhiteSpace(filter) || x.Tag.Contains(filter, StringComparison.OrdinalIgnoreCase))
            .Take(12)
            .ToList();
    }

    private string SerializeTags()
        => string.Join(", ", selectedTags);

    private static IEnumerable<string> ParseTags(string value)
        => value
            .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Select(NormalizeTag)
            .Where(x => !string.IsNullOrWhiteSpace(x))
            .Distinct(StringComparer.OrdinalIgnoreCase);

    private static string NormalizeTag(string? value)
        => string.IsNullOrWhiteSpace(value)
            ? string.Empty
            : value.Trim().TrimStart('#').ToLowerInvariant();
}
