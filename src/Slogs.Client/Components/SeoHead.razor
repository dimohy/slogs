@inject NavigationManager Navigation

<HeadContent>
    <meta name="description" content="@EffectiveDescription" />
    <meta name="robots" content="@RobotsContent" />
    <link rel="canonical" href="@CanonicalUrl" />
    <meta property="og:locale" content="ko_KR" />
    <meta property="og:site_name" content="@SeoMetadata.SiteName" />
    <meta property="og:title" content="@EffectiveTitle" />
    <meta property="og:description" content="@EffectiveDescription" />
    <meta property="og:type" content="@Type" />
    <meta property="og:url" content="@CanonicalUrl" />
    @if (!string.IsNullOrWhiteSpace(AbsoluteImageUrl))
    {
        <meta property="og:image" content="@AbsoluteImageUrl" />
    }
    <meta name="twitter:card" content="@(string.IsNullOrWhiteSpace(AbsoluteImageUrl) ? "summary" : "summary_large_image")" />
    <meta name="twitter:title" content="@EffectiveTitle" />
    <meta name="twitter:description" content="@EffectiveDescription" />
    @if (!string.IsNullOrWhiteSpace(AbsoluteImageUrl))
    {
        <meta name="twitter:image" content="@AbsoluteImageUrl" />
    }
    @if (!string.IsNullOrWhiteSpace(Author))
    {
        <meta name="author" content="@Author" />
        <meta property="article:author" content="@Author" />
    }
    @if (PublishedAt is not null)
    {
        <meta property="article:published_time" content="@PublishedAt.Value.ToUniversalTime().ToString("O")" />
    }
    @if (UpdatedAt is not null)
    {
        <meta property="article:modified_time" content="@UpdatedAt.Value.ToUniversalTime().ToString("O")" />
    }
    @if (Tags is not null)
    {
        @foreach (var tag in Tags.Where(tag => !string.IsNullOrWhiteSpace(tag)))
        {
            <meta property="article:tag" content="@tag" />
        }
    }
    @if (!string.IsNullOrWhiteSpace(JsonLd))
    {
        <script type="application/ld+json">@((MarkupString)JsonLd)</script>
    }
</HeadContent>

@code {
    [Parameter] public string? Title { get; set; }
    [Parameter] public string? Description { get; set; }
    [Parameter] public string? CanonicalPath { get; set; }
    [Parameter] public string Type { get; set; } = "website";
    [Parameter] public string? ImageUrl { get; set; }
    [Parameter] public string? Author { get; set; }
    [Parameter] public IReadOnlyList<string>? Tags { get; set; }
    [Parameter] public DateTime? PublishedAt { get; set; }
    [Parameter] public DateTime? UpdatedAt { get; set; }
    [Parameter] public bool NoIndex { get; set; }
    [Parameter] public string? JsonLd { get; set; }

    private string EffectiveTitle => string.IsNullOrWhiteSpace(Title) ? SeoMetadata.SiteName : Title.Trim();

    private string EffectiveDescription => SeoMetadata.NormalizeDescription(Description);

    private string RobotsContent => NoIndex
        ? "noindex, nofollow"
        : "index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1";

    private string CanonicalUrl => SeoMetadata.AbsoluteUrl(Navigation.BaseUri, GetCanonicalPath());

    private string? AbsoluteImageUrl => string.IsNullOrWhiteSpace(ImageUrl)
        ? null
        : SeoMetadata.AbsoluteUrl(Navigation.BaseUri, ImageUrl);

    private string GetCanonicalPath()
    {
        if (!string.IsNullOrWhiteSpace(CanonicalPath))
        {
            return CanonicalPath;
        }

        var current = new Uri(Navigation.Uri);
        return current.AbsolutePath;
    }
}
