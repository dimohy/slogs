@inject SlogsAuthState AuthState
@inject SlogsApiClient ApiClient
@inject NavigationManager Navigation
@inject IJSRuntime JS

@if (CurrentUser is not null)
{
    <section class="rounded-2xl border border-slate-200 bg-white p-5">
        <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
            <div class="max-w-2xl">
                <p class="text-xs font-bold uppercase text-slate-500">MCP 설정</p>
                <h2 class="mt-1 text-xl font-black text-slate-900">Slogs MCP 연결</h2>
                <p class="mt-2 text-sm leading-6 text-slate-600">HTTP MCP 클라이언트에 엔드포인트와 `mcp` scope Bearer 토큰을 등록하면 이 계정의 LLM Wiki 도구와 Slogs 글쓰기 도구를 사용할 수 있습니다. Obsidian 동기화에는 별도의 `obsidian.sync` scope 토큰을 사용합니다.</p>
            </div>
            <div class="flex flex-wrap items-center gap-2 lg:justify-end">
                <button class="inline-flex min-w-max shrink-0 items-center justify-center whitespace-nowrap rounded-full border border-slate-300 px-3 py-1.5 text-sm font-semibold text-slate-700 transition hover:bg-slate-100"
                        type="button"
                        @onclick="CopyEndpointAsync">엔드포인트 복사</button>
                <button class="inline-flex min-w-max shrink-0 items-center justify-center whitespace-nowrap rounded-full bg-slate-900 px-3 py-1.5 text-sm font-semibold text-white transition hover:bg-slate-800"
                        type="button"
                        @onclick="CopySetupConfigAsync">설정 복사</button>
            </div>
        </div>

        <div class="mt-4 grid gap-3 lg:grid-cols-2">
            <div class="rounded-xl border border-slate-200 bg-slate-50 p-3">
                <p class="text-xs font-bold uppercase text-slate-500">Endpoint</p>
                <p class="mt-2 break-all rounded-lg bg-white px-3 py-2 font-mono text-xs text-slate-800">@McpEndpoint</p>
                <p class="mt-3 text-xs font-bold uppercase text-slate-500">Authorization Header</p>
                <p class="mt-2 break-all rounded-lg bg-white px-3 py-2 font-mono text-xs text-slate-800">@SetupAuthorizationHeader</p>
            </div>

            <div class="rounded-xl border border-slate-200 bg-slate-50 p-3">
                <div class="flex flex-wrap items-center justify-between gap-2">
                    <p class="text-xs font-bold uppercase text-slate-500">Client Config Example</p>
                    @if (!string.IsNullOrWhiteSpace(copySetupMessage))
                    {
                        <span class="text-xs font-semibold text-emerald-700">@copySetupMessage</span>
                    }
                </div>
                <pre class="mt-2 overflow-auto rounded-lg bg-slate-950 p-3 text-xs text-slate-100"><code>@SetupConfigJson</code></pre>
            </div>
        </div>
    </section>

    <section class="rounded-2xl border border-slate-200 bg-white p-5">
        <div class="flex flex-wrap items-center justify-between gap-2">
            <div>
                <p class="text-xs font-bold uppercase text-slate-500">Slogs MCP</p>
                <h2 class="mt-1 text-xl font-black text-slate-900">Slogs MCP 토큰</h2>
            </div>
            <span class="rounded-full bg-slate-100 px-2.5 py-1 text-xs font-semibold text-slate-500">@McpEndpoint</span>
        </div>

        <div class="mt-4 grid gap-2 md:grid-cols-[minmax(0,0.8fr)_minmax(0,1fr)_auto]">
            <select class="rounded-xl border border-slate-200 px-3 py-2 text-sm font-semibold text-slate-700 outline-none focus:border-slate-500"
                    @bind="tokenPurpose">
                <option value="@TokenPurposeMcp">MCP</option>
                <option value="@TokenPurposeObsidian">Obsidian 동기화</option>
            </select>
            <input class="min-w-0 flex-1 rounded-xl border border-slate-200 px-3 py-2 text-sm outline-none focus:border-slate-500"
                   placeholder="토큰 이름"
                   @bind="tokenName"
                   @bind:event="oninput" />
            <button class="inline-flex min-w-max shrink-0 items-center justify-center whitespace-nowrap rounded-xl bg-slate-900 px-4 py-2 text-sm font-semibold text-white transition hover:bg-slate-800 disabled:cursor-not-allowed disabled:opacity-60"
                    type="button"
                    disabled="@isCreatingToken"
                    @onclick="CreateTokenAsync">
                @(isCreatingToken ? "생성 중..." : "토큰 생성")
            </button>
        </div>

        @if (!string.IsNullOrWhiteSpace(message))
        {
            <p class="mt-4 rounded-lg border border-sky-200 bg-sky-50 px-3 py-2 text-sm text-sky-900">@message</p>
        }

        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <p class="mt-4 rounded-lg border border-rose-200 bg-rose-50 px-3 py-2 text-sm text-rose-800">@errorMessage</p>
        }

        @if (createdToken is not null)
        {
            <div class="mt-4 rounded-xl border border-emerald-200 bg-emerald-50 p-3">
                <div class="flex flex-wrap items-center justify-between gap-2">
                    <p class="text-sm font-semibold text-emerald-950">새 토큰</p>
                    <button class="inline-flex min-w-max shrink-0 items-center justify-center whitespace-nowrap rounded-full border border-emerald-300 px-3 py-1 text-xs font-semibold text-emerald-900 transition hover:bg-emerald-100"
                            type="button"
                            @onclick="CopyCreatedTokenAsync">복사</button>
                </div>
                <p class="mt-2 break-all rounded-lg bg-white px-3 py-2 font-mono text-xs text-slate-800">@createdToken.Token</p>
                @if (!string.IsNullOrWhiteSpace(copyTokenMessage))
                {
                    <p class="mt-2 text-xs font-semibold text-emerald-900">@copyTokenMessage</p>
                }
            </div>
        }

        <div class="mt-4 space-y-2">
            @if (ActiveTokens.Count == 0)
            {
                <p class="rounded-xl border border-dashed border-slate-300 bg-slate-50 px-4 py-6 text-center text-sm text-slate-500">등록된 Slogs MCP 토큰이 없습니다.</p>
            }
            else
            {
                @foreach (var token in ActiveTokens)
                {
                    <div class="flex flex-wrap items-center justify-between gap-2 rounded-xl border border-slate-200 px-3 py-2">
                        <div class="min-w-0">
                            <p class="truncate text-sm font-semibold text-slate-900">@token.Name</p>
                            <p class="text-xs text-slate-500">@token.TokenPrefix... · @FormatScopes(token.Scopes) · @FormatDateTime(token.CreatedAt)@GetTokenLastUsedStatus(token)</p>
                        </div>
                        <button class="inline-flex min-w-max shrink-0 items-center justify-center whitespace-nowrap rounded-full border border-rose-300 px-3 py-1 text-xs font-semibold text-rose-700 transition hover:bg-rose-50"
                                type="button"
                                @onclick="() => RevokeTokenAsync(token.Id)">폐기</button>
                    </div>
                }
            }
        </div>
    </section>

    <section class="rounded-2xl border border-slate-200 bg-white p-5">
        <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
            <div class="max-w-2xl">
                <p class="text-xs font-bold uppercase text-slate-500">Obsidian Sync</p>
                <h2 class="mt-1 text-xl font-black text-slate-900">Obsidian Vault와 Drive</h2>
                <p class="mt-2 text-sm leading-6 text-slate-600">obsidian.sync scope 토큰으로 Obsidian 플러그인과 Windows WinFsp Drive가 같은 원격 Vault API를 사용합니다.</p>
            </div>
            <div class="flex flex-wrap items-center gap-2 lg:justify-end">
                <button class="inline-flex min-w-max shrink-0 items-center justify-center whitespace-nowrap rounded-full border border-slate-300 px-3 py-1.5 text-sm font-semibold text-slate-700 transition hover:bg-slate-100"
                        type="button"
                        @onclick="CopyObsidianApiEndpointAsync">API 복사</button>
                <button class="inline-flex min-w-max shrink-0 items-center justify-center whitespace-nowrap rounded-full border border-slate-300 px-3 py-1.5 text-sm font-semibold text-slate-700 transition hover:bg-slate-100"
                        type="button"
                        @onclick="CopyObsidianPluginRepositoryAsync">플러그인 URL 복사</button>
                <button class="inline-flex min-w-max shrink-0 items-center justify-center whitespace-nowrap rounded-full border border-slate-300 px-3 py-1.5 text-sm font-semibold text-slate-700 transition hover:bg-slate-100"
                        type="button"
                        @onclick="CopyDriveInstallCommandAsync">Drive 설치 복사</button>
                <button class="inline-flex min-w-max shrink-0 items-center justify-center whitespace-nowrap rounded-full bg-slate-900 px-3 py-1.5 text-sm font-semibold text-white transition hover:bg-slate-800"
                        type="button"
                        @onclick="CopyDriveCommandAsync">Drive 실행 복사</button>
            </div>
        </div>

        <div class="mt-4 grid gap-3 lg:grid-cols-3">
            <div class="rounded-xl border border-slate-200 bg-slate-50 p-3">
                <p class="text-xs font-bold uppercase text-slate-500">Obsidian plugin</p>
                <p class="mt-2 text-sm font-semibold text-slate-900">Slogs Sync</p>
                <p class="mt-2 text-xs leading-5 text-slate-600">커뮤니티 플러그인 등록 승인 후 Obsidian에서 Slogs Sync를 검색해 설치합니다.</p>
                <p class="mt-3 text-xs font-bold uppercase text-slate-500">Beta URL</p>
                <p class="mt-2 break-all rounded-lg bg-white px-3 py-2 font-mono text-xs text-slate-800">@ObsidianPluginRepositoryUrl</p>
                <p class="mt-2 text-xs leading-5 text-slate-500">승인 전에는 Obsidian 커뮤니티 플러그인 BRAT에서 위 저장소 URL을 추가해 설치합니다.</p>
            </div>

            <div class="rounded-xl border border-slate-200 bg-slate-50 p-3">
                <p class="text-xs font-bold uppercase text-slate-500">Obsidian API</p>
                <p class="mt-2 break-all rounded-lg bg-white px-3 py-2 font-mono text-xs text-slate-800">@ObsidianApiEndpoint</p>
                <p class="mt-3 text-xs font-bold uppercase text-slate-500">Drive install</p>
                <pre class="mt-2 max-h-40 overflow-auto rounded-lg bg-slate-950 p-3 text-xs text-slate-100"><code>@DriveInstallCommand</code></pre>
                <p class="mt-3 text-xs font-bold uppercase text-slate-500">Drive run</p>
                <pre class="mt-2 overflow-auto rounded-lg bg-slate-950 p-3 text-xs text-slate-100"><code>@DriveCommandExample</code></pre>
                @if (!string.IsNullOrWhiteSpace(copyObsidianMessage))
                {
                    <p class="mt-2 text-xs font-semibold text-emerald-800">@copyObsidianMessage</p>
                }
            </div>

            <div class="rounded-xl border border-slate-200 bg-slate-50 p-3">
                <p class="text-xs font-bold uppercase text-slate-500">Remote vault</p>
                <div class="mt-2 flex flex-col gap-2 sm:flex-row">
                    <input class="min-w-0 flex-1 rounded-xl border border-slate-200 px-3 py-2 text-sm outline-none focus:border-slate-500"
                           placeholder="Vault 이름"
                           @bind="newObsidianVaultName"
                           @bind:event="oninput" />
                    <button class="inline-flex min-w-max shrink-0 items-center justify-center whitespace-nowrap rounded-xl bg-slate-900 px-4 py-2 text-sm font-semibold text-white transition hover:bg-slate-800 disabled:cursor-not-allowed disabled:opacity-60"
                            type="button"
                            disabled="@isCreatingObsidianVault"
                            @onclick="CreateObsidianVaultAsync">@(isCreatingObsidianVault ? "생성 중..." : "Vault 열기")</button>
                </div>
                <p class="mt-3 text-xs leading-5 text-slate-500">동일한 이름이 이미 있으면 새로 만들지 않고 기존 원격 Vault를 엽니다.</p>
                @if (!string.IsNullOrWhiteSpace(obsidianMessage))
                {
                    <p class="mt-3 rounded-lg border border-sky-200 bg-sky-50 px-3 py-2 text-sm text-sky-900">@obsidianMessage</p>
                }
                @if (!string.IsNullOrWhiteSpace(obsidianErrorMessage))
                {
                    <p class="mt-3 rounded-lg border border-rose-200 bg-rose-50 px-3 py-2 text-sm text-rose-800">@obsidianErrorMessage</p>
                }
            </div>
        </div>

        <div class="mt-4 space-y-2">
            @if (isLoadingObsidianVaults)
            {
                <p class="rounded-xl border border-dashed border-slate-300 bg-slate-50 px-4 py-6 text-center text-sm text-slate-500">Obsidian Vault를 불러오는 중입니다.</p>
            }
            else if (obsidianVaults.Count == 0)
            {
                <p class="rounded-xl border border-dashed border-slate-300 bg-slate-50 px-4 py-6 text-center text-sm text-slate-500">등록된 Obsidian 원격 Vault가 없습니다.</p>
            }
            else
            {
                @foreach (var vault in obsidianVaults)
                {
                    var status = obsidianStatuses.TryGetValue(vault.Id, out var foundStatus) ? foundStatus : null;
                    <div class="@GetObsidianVaultCardClass(vault.Id)">
                        <div class="flex flex-wrap items-center justify-between gap-2">
                            <div class="min-w-0">
                                <p class="truncate text-sm font-semibold text-slate-900">@vault.Name</p>
                                <p class="text-xs text-slate-500">v@vault.CurrentVersion · @FormatDateTime(vault.UpdatedAt)</p>
                            </div>
                            <div class="flex flex-wrap items-center gap-2">
                                @if (status is not null)
                                {
                                    <div class="flex flex-wrap gap-2 text-xs font-semibold text-slate-600">
                                        <span class="rounded-full bg-slate-100 px-2.5 py-1">활성 @status.ActiveFileCount</span>
                                        <span class="rounded-full bg-slate-100 px-2.5 py-1">삭제 @status.DeletedFileCount</span>
                                        <span class="rounded-full bg-slate-100 px-2.5 py-1">@FormatBytes(status.TotalSizeBytes)</span>
                                    </div>
                                }
                                <button class="obsidian-vault-delete-trigger inline-flex min-w-max shrink-0 items-center justify-center whitespace-nowrap rounded-full border px-3 py-1 text-xs font-semibold transition disabled:cursor-not-allowed"
                                        type="button"
                                        disabled="@isDeletingObsidianVault"
                                        @onclick="() => BeginDeleteObsidianVault(vault)">삭제</button>
                            </div>
                        </div>
                        @if (deletingObsidianVaultId == vault.Id)
                        {
                            <div class="obsidian-vault-delete-panel mt-3 rounded-lg border p-3">
                                <p class="text-xs font-semibold text-rose-900">이 작업은 원격 Vault, 파일, 삭제 기록, 클라이언트 상태, 버전 이력을 모두 삭제합니다.</p>
                                <label class="mt-2 block text-xs font-semibold text-rose-900" for="@GetVaultDeleteInputId(vault.Id)">
                                    삭제하려면 <span class="font-mono">@vault.Name</span> 을 그대로 입력하세요.
                                </label>
                                <div class="mt-2 flex flex-col gap-2 sm:flex-row">
                                    <input id="@GetVaultDeleteInputId(vault.Id)"
                                           class="obsidian-vault-delete-input min-w-0 flex-1 rounded-xl border bg-white px-3 py-2 text-sm outline-none"
                                           autocomplete="off"
                                           @bind="deleteObsidianVaultConfirmation"
                                           @bind:event="oninput" />
                                    <button class="obsidian-vault-delete-cancel inline-flex min-w-max shrink-0 items-center justify-center whitespace-nowrap rounded-xl border px-4 py-2 text-sm font-semibold transition disabled:cursor-not-allowed"
                                            type="button"
                                            disabled="@isDeletingObsidianVault"
                                            @onclick="CancelDeleteObsidianVault">취소</button>
                                    <button class="obsidian-vault-delete-confirm inline-flex min-w-max shrink-0 items-center justify-center whitespace-nowrap rounded-xl px-4 py-2 text-sm font-semibold transition disabled:cursor-not-allowed"
                                            type="button"
                                            disabled="@(!CanDeleteObsidianVault(vault))"
                                            @onclick="() => DeleteObsidianVaultAsync(vault)">@(isDeletingObsidianVault ? "삭제 중..." : "완전 삭제")</button>
                                </div>
                            </div>
                        }
                        @if (status?.Clients.Count > 0)
                        {
                            <div class="mt-3 divide-y divide-slate-100 rounded-lg border border-slate-100">
                                @foreach (var client in status.Clients)
                                {
                                    <div class="flex flex-wrap items-center justify-between gap-2 px-3 py-2 text-xs">
                                        <span class="font-semibold text-slate-700">@client.ClientName</span>
                                        <span class="text-slate-500">@client.ClientKind · v@client.LastSeenVersion · @FormatDateTime(client.LastSeenAt)</span>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                }
            }
        </div>
    </section>
}

@code {
    private const string TokenPurposeMcp = "mcp";
    private const string TokenPurposeObsidian = "obsidian";

    private AuthUser? CurrentUser => AuthState.CurrentUser;
    private string McpEndpoint => new Uri(new Uri(Navigation.BaseUri), "mcp").ToString();
    private string ObsidianApiEndpoint => new Uri(new Uri(Navigation.BaseUri), "api/obsidian").ToString();
    private const string ObsidianPluginRepositoryUrl = "https://github.com/dimohy/obsidian-slogs-sync";
    private static string DriveInstallCommand =>
        """
        $manifest = Join-Path $env:TEMP "SlogsObsidianDrive-winget"
        Remove-Item $manifest -Recurse -Force -ErrorAction SilentlyContinue
        New-Item -ItemType Directory -Force -Path $manifest | Out-Null
        $base = "https://raw.githubusercontent.com/dimohy/slogs/main/packaging/winget/manifests/d/Dimohy/SlogsObsidianDrive/0.1.0"
        @("Dimohy.SlogsObsidianDrive.yaml","Dimohy.SlogsObsidianDrive.locale.en-US.yaml","Dimohy.SlogsObsidianDrive.installer.yaml") | ForEach-Object {
            Invoke-WebRequest "$base/$_" -OutFile (Join-Path $manifest $_)
        }
        winget install --manifest $manifest --accept-package-agreements --accept-source-agreements
        """;
    private string DriveCommandExample => $"SlogsObsidianDrive --server {Navigation.BaseUri.TrimEnd('/')} --token <obsidian.sync 토큰> --vault \"{DriveVaultNameExample}\" --mount S:";
    private string DriveVaultNameExample => string.IsNullOrWhiteSpace(newObsidianVaultName)
        ? (obsidianVaults.FirstOrDefault()?.Name ?? "My Obsidian Vault")
        : newObsidianVaultName.Trim();
    private string SetupAuthorizationHeader => $"Authorization: Bearer {SetupTokenValue}";
    private string SetupTokenValue => createdToken?.Scopes.Contains(SlogsTokenScopes.Mcp) == true ? createdToken.Token : "<Slogs MCP 토큰>";
    private string SetupConfigJson => string.Join(Environment.NewLine, [
        "{",
        "  \"mcpServers\": {",
        "    \"slogs\": {",
        "      \"type\": \"http\",",
        $"      \"url\": \"{McpEndpoint}\",",
        "      \"headers\": {",
        $"        \"Authorization\": \"Bearer {SetupTokenValue}\"",
        "      }",
        "    }",
        "  }",
        "}"
    ]);

    private IReadOnlyList<LlmWikiTokenResponse> tokens = [];
    private LlmWikiTokenCreatedResponse? createdToken;
    private string tokenName = "Codex Slogs MCP";
    private string tokenPurpose = TokenPurposeMcp;
    private string message = string.Empty;
    private string errorMessage = string.Empty;
    private string copyTokenMessage = string.Empty;
    private string copySetupMessage = string.Empty;
    private string copyObsidianMessage = string.Empty;
    private bool isCreatingToken;
    private IReadOnlyList<ObsidianVaultResponse> obsidianVaults = [];
    private Dictionary<Guid, ObsidianVaultStatusResponse> obsidianStatuses = [];
    private string newObsidianVaultName = "My Obsidian Vault";
    private string obsidianMessage = string.Empty;
    private string obsidianErrorMessage = string.Empty;
    private bool isLoadingObsidianVaults;
    private bool isCreatingObsidianVault;
    private Guid? deletingObsidianVaultId;
    private string deleteObsidianVaultConfirmation = string.Empty;
    private bool isDeletingObsidianVault;
    private IReadOnlyList<LlmWikiTokenResponse> ActiveTokens
        => tokens.Where(token => !token.IsRevoked).ToList();

    protected override async Task OnInitializedAsync()
    {
        await AuthState.EnsureInitializedAsync();
        await LoadTokensAsync();
        await LoadObsidianVaultsAsync();
    }

    private async Task LoadTokensAsync()
    {
        if (CurrentUser is null)
        {
            return;
        }

        tokens = await ApiClient.GetLlmWikiTokensAsync(CurrentUser.UserName);
    }

    private async Task LoadObsidianVaultsAsync()
    {
        if (CurrentUser is null)
        {
            return;
        }

        isLoadingObsidianVaults = true;
        try
        {
            obsidianVaults = await ApiClient.GetObsidianVaultsAsync(CurrentUser.UserName);
            var statuses = new Dictionary<Guid, ObsidianVaultStatusResponse>();
            foreach (var vault in obsidianVaults)
            {
                var status = await ApiClient.GetObsidianVaultStatusAsync(CurrentUser.UserName, vault.Id);
                if (status is not null)
                {
                    statuses[vault.Id] = status;
                }
            }

            obsidianStatuses = statuses;
        }
        finally
        {
            isLoadingObsidianVaults = false;
        }
    }

    private async Task CreateTokenAsync()
    {
        if (CurrentUser is null || isCreatingToken)
        {
            return;
        }

        ClearMessages();
        isCreatingToken = true;
        try
        {
            var scopes = GetSelectedScopes();
            createdToken = await ApiClient.CreateLlmWikiTokenAsync(CurrentUser.UserName, tokenName, scopes);
            await LoadTokensAsync();
            message = $"{FormatScopes(scopes)} 토큰이 생성되었습니다.";
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isCreatingToken = false;
        }
    }

    private async Task CopyCreatedTokenAsync()
    {
        if (createdToken is null)
        {
            return;
        }

        await JS.InvokeVoidAsync("navigator.clipboard.writeText", createdToken.Token);
        copyTokenMessage = "복사되었습니다.";
    }

    private async Task CopyEndpointAsync()
    {
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", McpEndpoint);
        copySetupMessage = "엔드포인트가 복사되었습니다.";
    }

    private async Task CopySetupConfigAsync()
    {
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", SetupConfigJson);
        copySetupMessage = "설정이 복사되었습니다.";
    }

    private async Task RevokeTokenAsync(Guid tokenId)
    {
        if (CurrentUser is null)
        {
            return;
        }

        ClearMessages();
        var revoked = await ApiClient.RevokeLlmWikiTokenAsync(CurrentUser.UserName, tokenId);
        await LoadTokensAsync();
        message = revoked ? "토큰이 폐기되었습니다." : "폐기할 토큰을 찾지 못했습니다.";
    }

    private async Task CreateObsidianVaultAsync()
    {
        if (CurrentUser is null || isCreatingObsidianVault)
        {
            return;
        }

        obsidianMessage = string.Empty;
        obsidianErrorMessage = string.Empty;
        isCreatingObsidianVault = true;
        try
        {
            var vault = await ApiClient.GetOrCreateObsidianVaultAsync(CurrentUser.UserName, newObsidianVaultName);
            await LoadObsidianVaultsAsync();
            obsidianMessage = vault is null ? "Vault를 열지 못했습니다." : $"{vault.Name} Vault를 열었습니다.";
        }
        catch (Exception ex)
        {
            obsidianErrorMessage = ex.Message;
        }
        finally
        {
            isCreatingObsidianVault = false;
        }
    }

    private void BeginDeleteObsidianVault(ObsidianVaultResponse vault)
    {
        obsidianMessage = string.Empty;
        obsidianErrorMessage = string.Empty;
        deletingObsidianVaultId = vault.Id;
        deleteObsidianVaultConfirmation = string.Empty;
    }

    private void CancelDeleteObsidianVault()
    {
        deletingObsidianVaultId = null;
        deleteObsidianVaultConfirmation = string.Empty;
    }

    private bool CanDeleteObsidianVault(ObsidianVaultResponse vault)
        => CurrentUser is not null
            && !isDeletingObsidianVault
            && deletingObsidianVaultId == vault.Id
            && string.Equals(deleteObsidianVaultConfirmation, vault.Name, StringComparison.Ordinal);

    private string GetObsidianVaultCardClass(Guid vaultId)
        => deletingObsidianVaultId == vaultId
            ? "obsidian-vault-card obsidian-vault-card--danger rounded-xl border px-3 py-3"
            : "obsidian-vault-card rounded-xl border border-slate-200 px-3 py-3";

    private async Task DeleteObsidianVaultAsync(ObsidianVaultResponse vault)
    {
        if (!CanDeleteObsidianVault(vault) || CurrentUser is null)
        {
            return;
        }

        obsidianMessage = string.Empty;
        obsidianErrorMessage = string.Empty;
        isDeletingObsidianVault = true;
        try
        {
            var deleted = await ApiClient.DeleteObsidianVaultAsync(CurrentUser.UserName, vault.Id, deleteObsidianVaultConfirmation);
            if (deleted)
            {
                obsidianMessage = $"{vault.Name} Vault가 완전히 삭제되었습니다.";
                CancelDeleteObsidianVault();
                await LoadObsidianVaultsAsync();
            }
            else
            {
                obsidianErrorMessage = "삭제할 Vault를 찾지 못했습니다.";
            }
        }
        catch (Exception ex)
        {
            obsidianErrorMessage = ex.Message;
        }
        finally
        {
            isDeletingObsidianVault = false;
        }
    }

    private void ClearMessages()
    {
        message = string.Empty;
        errorMessage = string.Empty;
        copyTokenMessage = string.Empty;
        copySetupMessage = string.Empty;
        copyObsidianMessage = string.Empty;
    }

