@page "/write"
@inject SlogsApiClient ApiClient
@inject SlogsAuthState AuthState
@inject NavigationManager Navigation
<PageTitle>글쓰기</PageTitle>
<SeoHead Title="글쓰기 | slogs" Description="slogs에 새 글을 작성합니다." NoIndex="true" />

@if (CurrentUser is null)
{
    <p class="rounded-2xl border border-slate-200 bg-white p-4 text-slate-500">로그인이 필요합니다. <a class="font-semibold underline" href="@GetLoginHref()">로그인</a>해 주세요.</p>
}
else
{
    <h1 class="text-2xl font-bold text-slate-900">새 글 쓰기</h1>

    <div class="mt-4 grid min-w-0 gap-3">
        <label class="text-sm font-semibold text-slate-700" for="write-title">제목</label>
        <input id="write-title" class="rounded-2xl border border-slate-300 px-3 py-2 text-sm" value="@title" @oninput="OnTitleInput" placeholder="제목을 입력하세요" />

        <label class="text-sm font-semibold text-slate-700" for="write-slug">주소 slug</label>
        <div class="flex flex-col gap-2 sm:flex-row">
            <input id="write-slug" class="min-w-0 flex-1 rounded-2xl border border-slate-300 px-3 py-2 text-sm" value="@slug" @oninput="OnSlugInput" placeholder="@SlugGenerator.Suggest(title)" />
            <button class="rounded-full border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-100"
                    type="button"
                    @onclick="ResetSlugSuggestion">
                제목으로 추천
            </button>
        </div>
        <p class="break-all text-xs text-slate-500">@($"/@{CurrentUser.UserName}/{CurrentSlug}")</p>

        <label class="text-sm font-semibold text-slate-700" for="write-summary">요약</label>
        <input id="write-summary" class="rounded-2xl border border-slate-300 px-3 py-2 text-sm" @bind="summary" placeholder="요약을 입력하세요" />

        <label class="text-sm font-semibold text-slate-700" for="write-tags">태그</label>
        <TagBadgeInput Id="write-tags" @bind-Value="tags" Placeholder="태그를 선택하거나 입력하세요" />

        <label class="text-sm font-semibold text-slate-700" for="write-series">시리즈</label>
        <input id="write-series" class="rounded-2xl border border-slate-300 px-3 py-2 text-sm" @bind="series" list="write-series-options" placeholder="시리즈명 입력 또는 선택(선택)" />
        <datalist id="write-series-options">
            @foreach (var option in seriesOptions)
            {
                <option value="@option"></option>
            }
        </datalist>

        <RepresentativeImageField InputId="write-representative-image" @bind-Value="thumbnailUrl" FallbackMarkdown="@body" />

        <label class="text-sm font-semibold text-slate-700">본문</label>
        <MarkdownEditor @bind-Value="body" Placeholder="Markdown으로 본문을 작성하세요." />

        <div class="flex flex-wrap gap-2">
            <button class="rounded-full border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-100 disabled:cursor-not-allowed disabled:opacity-60"
                    type="button" @onclick="SaveDraft" disabled="@isSaving">
                @((isSaving && savingAction == "draft") ? "게시전 저장 중..." : "게시전 저장")
            </button>
            <button class="rounded-full bg-slate-900 px-4 py-2 text-sm font-semibold text-white hover:bg-slate-800 disabled:cursor-not-allowed disabled:opacity-60"
                    type="button" @onclick="Publish" disabled="@isSaving">
                @((isSaving && savingAction == "publish") ? "게시 중..." : "게시")
            </button>
            <button class="rounded-full border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-100"
                    type="button" @onclick="Cancel">취소</button>
        </div>

        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <p class="text-sm text-red-700">@errorMessage</p>
        }
    </div>

    <section class="mt-6 min-w-0 rounded-2xl border border-slate-200 bg-white p-4">
        <h3 class="mb-2 text-lg font-bold text-slate-900">미리보기</h3>
        <p class="mb-2 font-semibold text-slate-900">@title</p>
        <p class="mb-2 text-slate-700">@summary</p>
        <div class="mb-2 flex flex-wrap gap-2 text-sm text-slate-600">
            @foreach (var tag in ParsedTags)
            {
                <span class="rounded-full border border-slate-200 bg-slate-50 px-2.5 py-1">#@tag</span>
            }
        </div>
        @if (!string.IsNullOrWhiteSpace(series))
        {
            <p class="mb-2 text-sm text-slate-500">시리즈: @series</p>
        }
        <MarkdownPreview Value="@body" />
    </section>
}

@code {
    private string title = string.Empty;
    private string slug = string.Empty;
    private bool slugEdited;
    private string summary = string.Empty;
    private string tags = string.Empty;
    private string series = string.Empty;
    private string thumbnailUrl = string.Empty;
    private string body = string.Empty;
    private bool isSaving;
    private string savingAction = string.Empty;
    private string errorMessage = string.Empty;
    private IReadOnlyList<string> seriesOptions = Array.Empty<string>();
    private IReadOnlyList<string> ParsedTags => ApiClient.ParseTagsForDisplay(tags);
    private string CurrentSlug => SlugGenerator.Normalize(string.IsNullOrWhiteSpace(slug) ? title : slug);
    [SupplyParameterFromQuery(Name = "returnUrl")] public string? ReturnUrl { get; set; }

    private AuthUser? CurrentUser => AuthState.CurrentUser;

    protected override async Task OnInitializedAsync()
    {
        await AuthState.EnsureInitializedAsync();
        if (CurrentUser is null)
        {

            Navigation.NavigateTo(GetLoginHref());
            return;
        }

        seriesOptions = await ApiClient.GetSeriesAsync(50);
    }

    private Task SaveDraft() => SaveAsync(isDraft: true);

    private Task Publish() => SaveAsync(isDraft: false);

    private async Task SaveAsync(bool isDraft)
    {
        errorMessage = string.Empty;

        if (CurrentUser is null)
        {
            errorMessage = "로그인이 필요합니다.";
            return;
        }

        if (!isDraft && (string.IsNullOrWhiteSpace(title) || string.IsNullOrWhiteSpace(body)))
        {
            errorMessage = "제목과 본문은 필수입니다.";
            return;
        }

        if (isDraft && string.IsNullOrWhiteSpace(title) && string.IsNullOrWhiteSpace(body))
        {
            errorMessage = "게시전 저장할 제목이나 본문을 입력해 주세요.";
            return;
        }

        if (isSaving)
        {
            return;
        }

        isSaving = true;
        savingAction = isDraft ? "draft" : "publish";
        try
        {
            var post = await ApiClient.CreatePostAsync(title, CurrentUser.UserName, summary, body, tags, series, thumbnailUrl, isDraft: isDraft, slug: CurrentSlug);
            var fallback = isDraft ? $"/edit/{Uri.EscapeDataString(post.Slug)}" : GetPostUrl(post);
            Navigation.NavigateTo(GetReturnDestination(fallback));
        }
        catch (Exception)
        {
            errorMessage = isDraft
                ? "게시전 저장에 실패했습니다. 잠시 후 다시 시도해 주세요."
                : "게시에 실패했습니다. 잠시 후 다시 시도해 주세요.";
        }
        finally
        {
            isSaving = false;
            savingAction = string.Empty;
        }
    }

    private string GetLoginHref()
    {
        var requestedReturnUrl = !string.IsNullOrWhiteSpace(ReturnUrl)
            ? ReturnUrl
            : "/write";

        var returnUrl = TryNormalizeRelativeReturnUrl(requestedReturnUrl, out var safeReturnUrl)
            ? safeReturnUrl
            : "/write";

        return $"/login?returnUrl={Uri.EscapeDataString(returnUrl)}";
    }

    private void Cancel()
    {
        Navigation.NavigateTo(GetReturnDestination("/me"));
    }

    private void OnTitleInput(ChangeEventArgs e)
    {
        title = e.Value?.ToString() ?? string.Empty;
        if (!slugEdited)
        {
            slug = SlugGenerator.Suggest(title);
        }
    }

    private void OnSlugInput(ChangeEventArgs e)
    {
        slugEdited = true;
        slug = SlugGenerator.Normalize(e.Value?.ToString());
    }

    private void ResetSlugSuggestion()
    {
        slugEdited = false;
        slug = SlugGenerator.Suggest(title);
    }

    private string GetReturnDestination(string fallback)
    {
        return (TryNormalizeRelativeReturnUrl(ReturnUrl, out var safeUrl), safeUrl) switch
        {
            (true, _) => safeUrl,
            _ => fallback
        };
    }

    private bool TryNormalizeRelativeReturnUrl(string? returnUrl, out string safeUrl)
    {
        safeUrl = string.Empty;

        if (string.IsNullOrWhiteSpace(returnUrl))
        {
            return false;
        }

        if (!Uri.TryCreate(returnUrl, UriKind.RelativeOrAbsolute, out var parsedUrl))
        {
            return false;
        }

        if (!parsedUrl.IsAbsoluteUri && parsedUrl.OriginalString.StartsWith("/"))
        {
            safeUrl = parsedUrl.OriginalString;
            return true;
        }

        if (parsedUrl.IsAbsoluteUri)
        {
            var baseUri = new Uri(Navigation.BaseUri);
            if (parsedUrl.Host.Equals(baseUri.Host, StringComparison.OrdinalIgnoreCase))
            {
                safeUrl = parsedUrl.PathAndQuery;
                return true;
            }
        }

        return false;
    }

    private static string GetPostUrl(BlogPost post)
        => $"/@{Uri.EscapeDataString(post.Author)}/{Uri.EscapeDataString(post.Slug)}";
}


