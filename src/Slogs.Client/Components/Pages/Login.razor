@page "/login"
@inject SlogsAuthState AuthState
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>로그인</PageTitle>
<SeoHead Title="로그인 | slogs" Description="slogs 계정으로 로그인합니다." NoIndex="true" />

<form class="grid max-w-xl gap-3 rounded-2xl border border-slate-200 bg-white p-4"
      @onsubmit="SubmitLogin"
      @onsubmit:preventDefault>
    <h1 class="text-2xl font-bold text-slate-900">로그인</h1>

    <label class="text-sm font-semibold text-slate-700" for="login-user-name">아이디</label>
    <input id="login-user-name" name="userName" class="rounded-2xl border border-slate-300 px-3 py-2 text-sm" autocomplete="username" @bind="userName" @bind:event="oninput" />

    <label class="text-sm font-semibold text-slate-700" for="login-password">비밀번호</label>
    <input id="login-password" name="password" class="rounded-2xl border border-slate-300 px-3 py-2 text-sm" type="password" autocomplete="current-password" @bind="password" @bind:event="oninput" />

    <button class="w-fit rounded-full bg-slate-900 px-4 py-2 text-sm font-semibold text-white hover:bg-slate-800 disabled:cursor-not-allowed disabled:opacity-60"
            type="submit" disabled="@isSubmitting">@((isSubmitting) ? "로그인 중..." : "로그인")</button>

    <div class="grid gap-2 border-t border-slate-200 pt-3">
        <a class="inline-flex w-fit items-center gap-2 rounded-full border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-800 transition hover:bg-slate-100"
           href="@GetGoogleLoginHref()">
            <span class="grid h-5 w-5 place-items-center rounded-full bg-white text-sm font-black text-slate-900">G</span>
            Google로 계속하기
        </a>

        @if (Error == "googleNotConfigured")
        {
            <div class="grid gap-1 text-xs leading-5 text-slate-600">
                <p class="font-semibold text-slate-800">Google OAuth 설정이 필요합니다.</p>
                <p>Authorized redirect URI: <code class="rounded bg-slate-100 px-1 py-0.5">@GoogleRedirectUri</code></p>
                <p>Secret keys: <code class="rounded bg-slate-100 px-1 py-0.5">Authentication:Google:ClientId</code>, <code class="rounded bg-slate-100 px-1 py-0.5">Authentication:Google:ClientSecret</code></p>
            </div>
        }

    </div>

    @if (!string.IsNullOrWhiteSpace(ErrorMessage))
    {
        <p class="text-sm text-red-700">@ErrorMessage</p>
    }

    <p class="text-sm text-slate-500">아직 계정이 없다면 <a class="font-semibold underline" href="@GetRegisterHref()">회원가입</a>을 진행하세요.</p>
</form>

@code {
    [SupplyParameterFromQuery(Name = "returnUrl")] public string? ReturnUrl { get; set; }
    [SupplyParameterFromQuery(Name = "error")] public string? Error { get; set; }

    private string userName = string.Empty;
    private string password = string.Empty;
    private string apiError = string.Empty;
    private bool isSubmitting;
    private string? SafeReturnUrl => TryNormalizeRelativeReturnUrl(ReturnUrl, out var safeUrl) ? safeUrl : null;
    private string GoogleRedirectUri => new Uri(new Uri(Navigation.BaseUri), "signin-google").ToString();
    private string ErrorMessage => !string.IsNullOrWhiteSpace(apiError)
        ? apiError
        : Error switch
    {
        "required" => "아이디와 비밀번호를 입력해 주세요.",
        "invalid" => "아이디 또는 비밀번호가 틀렸습니다.",
        "googleNotConfigured" => "Google 로그인 설정이 아직 완료되지 않았습니다.",
        "googleFailed" => "Google 로그인에 실패했습니다. 잠시 후 다시 시도해 주세요.",
        "googleCanceled" => "Google 계정 연결이 취소되었습니다.",
        _ => string.Empty
    };

    protected override async Task OnInitializedAsync()
    {
        await AuthState.EnsureInitializedAsync();
        if (AuthState.CurrentUser is not null)
        {
            Navigation.NavigateTo(SafeReturnUrl ?? "/me");
        }
    }

    private async Task SubmitLogin()
    {
        apiError = string.Empty;
        if (string.IsNullOrWhiteSpace(userName) || string.IsNullOrWhiteSpace(password))
        {
            apiError = "아이디와 비밀번호를 입력해 주세요.";
            return;
        }

        if (isSubmitting)
        {
            return;
        }

        isSubmitting = true;
        try
        {
            var result = await JS.InvokeAsync<AuthApiResult>(
                "slogsAuthApi.login",
                new
                {
                    userName,
                    password,
                    returnUrl = SafeReturnUrl ?? "/me"
                });

            if (result.Ok)
            {
                Navigation.NavigateTo(NormalizeApiReturnUrl(result.ReturnUrl, "/me"), forceLoad: true);
                return;
            }

            apiError = result.Status == 401
                ? "아이디 또는 비밀번호가 틀렸습니다."
                : MapAuthError(result.Error, "로그인에 실패했습니다.");
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private bool TryNormalizeRelativeReturnUrl(string? returnUrl, out string safeUrl)
    {
        safeUrl = string.Empty;

        if (string.IsNullOrWhiteSpace(returnUrl))
        {
            return false;
        }

        if (!Uri.TryCreate(returnUrl, UriKind.RelativeOrAbsolute, out var returnUri))
        {
            return false;
        }

        if (!returnUri.IsAbsoluteUri && returnUri.OriginalString.StartsWith("/"))
        {
            safeUrl = returnUri.OriginalString;
            return true;
        }

        if (returnUri.IsAbsoluteUri)
        {
            var baseUri = new Uri(Navigation.BaseUri);
            if (returnUri.Host.Equals(baseUri.Host, StringComparison.OrdinalIgnoreCase))
            {
                safeUrl = returnUri.PathAndQuery;
                return true;
            }
        }

        return false;
    }

    private string GetRegisterHref()
    {
        if (string.IsNullOrWhiteSpace(ReturnUrl) || !TryNormalizeRelativeReturnUrl(ReturnUrl, out var safeUrl))
        {
            return $"/register";
        }

        return $"/register?returnUrl={Uri.EscapeDataString(safeUrl)}";
    }

    private string GetGoogleLoginHref()
    {
        var returnUrl = SafeReturnUrl ?? "/me";
        return $"/auth/google?returnUrl={Uri.EscapeDataString(returnUrl)}";
    }

    private string NormalizeApiReturnUrl(string? returnUrl, string fallback)
    {
        return TryNormalizeRelativeReturnUrl(returnUrl, out var safeUrl)
            ? safeUrl
            : fallback;
    }

    private static string MapAuthError(string? error, string fallback)
    {
        return error switch
        {
            "required" => "아이디와 비밀번호를 입력해 주세요.",
            _ => fallback
        };
    }

    private sealed class AuthApiResult
    {
        public bool Ok { get; set; }

        public int Status { get; set; }

        public string? Error { get; set; }

        public string? ReturnUrl { get; set; }
    }

}


