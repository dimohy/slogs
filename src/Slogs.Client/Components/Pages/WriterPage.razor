@page "/writer/{Writer}"
@page "/@{Writer}"
@inject SlogsApiClient ApiClient
@inject SlogsAuthState AuthState
@inject NavigationManager NavigationManager

<PageTitle>@($"{GetSloggerDisplayName()} | slogs")</PageTitle>
<SeoHead Title="@($"{GetSloggerDisplayName()} | slogs")"
         Description="@GetSloggerSeoDescription()"
         CanonicalPath="@GetWriterPath()"
         Type="profile"
         ImageUrl="@writerProfile?.ProfileImageUrl"
         NoIndex="@(!isWriterKnown)"
         JsonLd="@(isWriterKnown ? SeoMetadata.ProfilePageJsonLd(NavigationManager.BaseUri, GetWriterPath(), GetSloggerDisplayName(), GetSloggerSeoDescription(), writerProfile?.ProfileImageUrl) : null)" />

@if (!isWriterKnown)
{
    <section class="rounded-2xl border border-slate-200 bg-white p-6">
        <p class="text-sm font-semibold text-slate-500">슬로거를 찾을 수 없습니다.</p>
        <h1 class="mt-2 text-2xl font-bold text-slate-900">@Writer</h1>
        <a class="mt-4 inline-flex rounded-full border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700 transition hover:bg-slate-100"
           href="/writer">슬로거 둘러보기</a>
    </section>
}
else
{
    <section class="slogger-hero rounded-2xl border border-slate-200 bg-white">
        <div class="slogger-hero__cover"></div>
        <div class="slogger-hero__body">
            <div class="slogger-hero__header">
                <div class="slogger-hero__identity">
                    <div class="slogger-hero__avatar">
                        @if (!string.IsNullOrWhiteSpace(writerProfile?.ProfileImageUrl))
                        {
                            <img class="h-full w-full object-cover"
                                 src="@writerProfile.ProfileImageUrl"
                                 alt="@($"{GetSloggerDisplayName()} 프로필 이미지")"
                                 loading="lazy"
                                 decoding="async" />
                        }
                        else
                        {
                            <span class="slogger-hero__initials">@GetInitials()</span>
                        }
                    </div>
                    <div class="slogger-hero__copy">
                        <p class="slogger-hero__eyebrow">슬로거 홈</p>
                        <h1 class="slogger-hero__name">@GetSloggerDisplayName()</h1>
                        <p class="slogger-hero__address">@GetSloggerAddress()</p>
                    </div>
                </div>

                <div class="slogger-hero__actions">
                    <a class="rounded-full border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700 transition hover:bg-slate-100"
                       href="@GetFollowersPath()">팔로워 @followerCount</a>
                    <a class="rounded-full border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700 transition hover:bg-slate-100"
                       href="@GetFollowingPath()">팔로잉 @followingCount</a>
                    @if (IsCurrentUsersPage)
                    {
                        <a class="rounded-full bg-slate-900 px-4 py-2 text-sm font-semibold text-white transition hover:bg-slate-800"
                           href="/write">새 글 쓰기</a>
                    }
                    else if (CurrentUser is not null)
                    {
                        <button class="rounded-full bg-slate-900 px-4 py-2 text-sm font-semibold text-white transition hover:bg-slate-800 disabled:cursor-wait disabled:opacity-60"
                                disabled="@isFollowBusy"
                                @onclick="ToggleFollowAsync">
                            @(isFollowing ? "팔로우 해제" : "팔로우")
                        </button>
                    }
                    else
                    {
                        <a class="rounded-full bg-slate-900 px-4 py-2 text-sm font-semibold text-white transition hover:bg-slate-800"
                           href="@GetLoginReturnUrl()">팔로우</a>
                    }
                </div>
            </div>

            <p class="mt-5 max-w-3xl text-base leading-7 text-slate-700">@GetSloggerBio()</p>

            <div class="mt-5 grid grid-cols-2 gap-2 md:grid-cols-5">
                <div class="rounded-xl border border-slate-200 bg-slate-50 px-3 py-3">
                    <p class="text-xs font-semibold text-slate-500">글</p>
                    <p class="mt-1 text-xl font-black text-slate-900">@totalCount</p>
                </div>
                <div class="rounded-xl border border-slate-200 bg-slate-50 px-3 py-3">
                    <p class="text-xs font-semibold text-slate-500">좋아요</p>
                    <p class="mt-1 text-xl font-black text-slate-900">@totalLikeCount</p>
                </div>
                <div class="rounded-xl border border-slate-200 bg-slate-50 px-3 py-3">
                    <p class="text-xs font-semibold text-slate-500">댓글</p>
                    <p class="mt-1 text-xl font-black text-slate-900">@totalCommentCount</p>
                </div>
                <div class="rounded-xl border border-slate-200 bg-slate-50 px-3 py-3">
                    <p class="text-xs font-semibold text-slate-500">조회</p>
                    <p class="mt-1 text-xl font-black text-slate-900">@totalViewCount</p>
                </div>
                <div class="rounded-xl border border-slate-200 bg-slate-50 px-3 py-3">
                    <p class="text-xs font-semibold text-slate-500">가입</p>
                    <p class="mt-1 text-base font-black text-slate-900">@FormatDate(writerProfile?.RegisteredAt ?? DateTime.UtcNow)</p>
                </div>
            </div>
        </div>
    </section>

    <section class="mt-4 grid grid-cols-1 gap-4 lg:grid-cols-3">
        <article class="rounded-2xl border border-slate-200 bg-white p-5 lg:col-span-2">
            <div class="flex flex-wrap items-center justify-between gap-2">
                <div>
                    <p class="text-xs font-bold text-slate-500">대표</p>
                    <h2 class="mt-1 text-xl font-black text-slate-900">대표 글</h2>
                </div>
                @if (featuredPost is not null)
                {
                    <a class="rounded-full border border-slate-300 px-3 py-1.5 text-sm font-semibold text-slate-700 transition hover:bg-slate-100"
                       href="@GetPostUrl(featuredPost)">읽기</a>
                }
            </div>

            @if (featuredPost is null)
            {
                <div class="mt-4 rounded-xl border border-dashed border-slate-300 bg-slate-50 p-5">
                    <p class="text-sm font-semibold text-slate-500">아직 대표로 보여줄 글이 없습니다.</p>
                    @if (IsCurrentUsersPage)
                    {
                        <a class="mt-3 inline-flex rounded-full bg-slate-900 px-4 py-2 text-sm font-semibold text-white transition hover:bg-slate-800"
                           href="/write">첫 글 쓰기</a>
                    }
                </div>
            }
            else
            {
                <div class="mt-4">
                    <PostCardImage Post="featuredPost" PostUrl="@GetPostUrl(featuredPost)" Priority="true" />
                    <a class="block text-2xl font-black leading-tight text-slate-900 hover:underline"
                       href="@GetPostUrl(featuredPost)">@featuredPost.Title</a>
                    <p class="mt-2 text-sm leading-6 text-slate-700">@Shorten(featuredPost.Summary, 220)</p>
                    <div class="mt-3 flex flex-wrap items-center gap-2 text-sm text-slate-500">
                        <span>@FormatDate(featuredPost.PublishedAt)</span>
                        <span>·</span>
                        <span>@featuredPost.ReadTimeMinutes 분</span>
                        <span>·</span>
                        <span>좋아요 @featuredPost.LikeCount</span>
                        <span>·</span>
                        <span>댓글 @featuredPost.CommentCount</span>
                    </div>
                </div>
            }
        </article>

        <aside class="rounded-2xl border border-slate-200 bg-white p-5">
            <p class="text-xs font-bold text-slate-500">프로필</p>
            <h2 class="mt-1 text-xl font-black text-slate-900">슬로거 카드</h2>
            <dl class="mt-4 grid gap-3 text-sm">
                <div>
                    <dt class="font-semibold text-slate-500">주소</dt>
                    <dd class="mt-1 font-bold text-slate-900">@GetSloggerAddress()</dd>
                </div>
                <div>
                    <dt class="font-semibold text-slate-500">관심 태그</dt>
                    <dd class="mt-2 flex flex-wrap gap-2">
                        @if (tagCloud.Count == 0)
                        {
                            <span class="text-slate-500">태그 없음</span>
                        }
                        else
                        {
                            @foreach (var item in tagCloud.Take(6))
                            {
                                <a class="rounded-full border border-sky-200 bg-sky-50 px-2.5 py-1 text-xs font-semibold text-sky-900 hover:bg-sky-100"
                                   href="@($"/tag/{Uri.EscapeDataString(item.Tag)}")">#@item.Tag</a>
                            }
                        }
                    </dd>
                </div>
                <div>
                    <dt class="font-semibold text-slate-500">시리즈</dt>
                    <dd class="mt-2 flex flex-wrap gap-2">
                        @if (seriesCloud.Count == 0)
                        {
                            <span class="text-slate-500">시리즈 없음</span>
                        }
                        else
                        {
                            @foreach (var item in seriesCloud.Take(5))
                            {
                                <a class="rounded-full border border-slate-300 bg-slate-50 px-2.5 py-1 text-xs font-semibold text-slate-700 hover:bg-slate-100"
                                   href="@($"/series/{Uri.EscapeDataString(item.Series)}")">@item.Series</a>
                            }
                        }
                    </dd>
                </div>
            </dl>
        </aside>
    </section>

    <section class="mt-4 rounded-2xl border border-slate-200 bg-white p-5">
        <div class="flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
            <div>
                <p class="text-xs font-bold text-slate-500">보관함</p>
                <h2 class="mt-1 text-xl font-black text-slate-900">글 보관함</h2>
                <p class="mt-1 text-sm text-slate-500">@($"{totalCount}개 글")</p>
            </div>
            <div class="flex flex-wrap gap-2">
                <a class="@GetSortChipClass(null)" href="@GetSortQuery(null)">최신</a>
                <a class="@GetSortChipClass("popular")" href="@GetSortQuery("popular")">인기</a>
                <a class="@GetSortChipClass("updated")" href="@GetSortQuery("updated")">최신 업데이트</a>
            </div>
        </div>

        <div class="mt-4 grid grid-cols-1 gap-3 md:grid-cols-2">
            @if (!posts.Any())
            {
                <div class="rounded-xl border border-dashed border-slate-300 bg-slate-50 p-5 md:col-span-2">
                    <p class="text-sm font-semibold text-slate-500">아직 발행한 글이 없습니다.</p>
                    @if (IsCurrentUsersPage)
                    {
                        <a class="mt-3 inline-flex rounded-full bg-slate-900 px-4 py-2 text-sm font-semibold text-white transition hover:bg-slate-800"
                           href="/write">새 글 쓰기</a>
                    }
                </div>
            }
            else
            {
                for (var index = 0; index < posts.Count; index++)
                {
                    var post = posts[index];
                    <article class="clickable-post-card rounded-2xl border border-slate-200 bg-white p-4"
                             data-card-click-href="@GetPostUrl(post)"
                             tabindex="0"
                             role="link"
                             aria-label="@($"{post.Title} 상세 보기")">
                        <PostCardImage Post="post" PostUrl="@GetPostUrl(post)" Priority="@IsPriorityCardImage(index)" />
                        <a class="mb-2 block text-xl font-bold text-slate-900 hover:underline" href="@GetPostUrl(post)">@post.Title</a>
                        <div class="mb-2 flex flex-wrap items-center gap-1 text-sm text-slate-500">
                            <span>@FormatDate(post.PublishedAt)</span>
                            <span>·</span>
                            <span>@post.ReadTimeMinutes 분</span>
                            <span>·</span>
                            <span>@post.CommentCount 개 댓글</span>
                            <span>·</span>
                            <span>@post.ViewCount 회 조회</span>
                            @if (post.Series.Count > 0)
                            {
                                <span>·</span>
                                @foreach (var series in post.Series)
                                {
                                    <a class="hover:underline" href="@($"/series/{Uri.EscapeDataString(series)}")">시리즈: @series</a>
                                }
                            }
                        </div>
                        <p class="text-slate-700">@Shorten(post.Summary, 150)</p>
                        <div class="mt-2 flex flex-wrap gap-2">
                            @foreach (var tag in post.Tags)
                            {
                                <a class="rounded-full border border-sky-200 bg-sky-50 px-2.5 py-1 text-xs font-semibold text-sky-900 hover:bg-sky-100"
                                   href="@($"/tag/{Uri.EscapeDataString(tag)}")">#@tag</a>
                            }
                        </div>

                        <div class="mt-3 flex flex-wrap gap-2">
                            <button class="rounded-full border border-slate-300 px-3 py-1.5 text-sm font-semibold transition hover:bg-slate-100 @(IsPostBusy(post.Slug, pendingLikeSlugs) ? "opacity-60" : "")"
                                    disabled="@IsPostBusy(post.Slug, pendingLikeSlugs)"
                                    @onclick="() => ToggleLikeAsync(post.Slug)">
                                @((post.IsLikedBy(CurrentUserName) ? "좋아요 취소" : "좋아요")) (@post.LikeCount)
                            </button>
                            <button class="rounded-full border border-slate-300 px-3 py-1.5 text-sm font-semibold transition hover:bg-slate-100 @(IsPostBusy(post.Slug, pendingBookmarkSlugs) ? "opacity-60" : "")"
                                    disabled="@IsPostBusy(post.Slug, pendingBookmarkSlugs)"
                                    @onclick="() => ToggleBookmarkAsync(post.Slug)">
                                @(post.IsBookmarkedBy(CurrentUserName) ? "북마크 해제" : "북마크")
                            </button>
                            <a class="rounded-full border border-slate-300 px-3 py-1.5 text-sm font-semibold transition hover:bg-slate-100"
                               href="@GetPostCommentsUrl(post)">댓글 @post.CommentCount</a>
                        </div>
                    </article>
                }
            }
        </div>
    </section>

    <InfiniteScrollSentinel Visible="@(posts.Count > 0)"
                            HasMore="@HasMorePosts"
                            IsLoading="@isLoadingMorePosts"
                            OnLoadMore="LoadMorePostsAsync"
                            ShowDoneText="@(allVisiblePosts.Count > PageSize)"
                            DoneText="모든 글을 불러왔습니다." />
}

@code {
    private const int PageSize = 6;

    [Parameter] public string Writer { get; set; } = string.Empty;
    [SupplyParameterFromQuery(Name = "sort")] public string? Sort { get; set; }

    private IReadOnlyList<BlogPost> posts = Array.Empty<BlogPost>();
    private IReadOnlyList<BlogPost> allAuthorPosts = Array.Empty<BlogPost>();
    private IReadOnlyList<BlogPost> allVisiblePosts = Array.Empty<BlogPost>();
    private IReadOnlyList<(string Tag, int Count)> tagCloud = Array.Empty<(string Tag, int Count)>();
    private IReadOnlyList<(string Series, int Count)> seriesCloud = Array.Empty<(string Series, int Count)>();
    private BlogPost? featuredPost;
    private AuthUser? writerProfile;
    private int totalCount;
    private int totalPages;
    private int totalLikeCount;
    private int totalCommentCount;
    private int totalViewCount;
    private HashSet<string> pendingLikeSlugs = [];
    private HashSet<string> pendingBookmarkSlugs = [];
    private int followerCount;
    private int followingCount;
    private bool isWriterKnown;
    private bool isFollowing;
    private bool isFollowBusy;
    private bool isLoadingMorePosts;
    private string? normalizedSort;
    private string currentStateKey = string.Empty;
    private bool HasMorePosts => posts.Count < allVisiblePosts.Count;

    [PersistentState]
    public WriterPageState? PrerenderedState { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        normalizedSort = ListQueryUrlBuilder.NormalizeSortValue(Sort, "latest", "popular", "updated");
        currentStateKey = PageStateKeyBuilder.FromNavigation(NavigationManager);
        var restoredPrerenderedState = TryRestorePrerenderedState(currentStateKey);

        await AuthState.EnsureInitializedAsync();

        if (restoredPrerenderedState)
        {
            return;
        }

        await LoadPostsAsync();
        CapturePrerenderedState(currentStateKey);
    }

    private IReadOnlyList<BlogPost> SortPosts(IEnumerable<BlogPost> source)
    {
        return normalizedSort switch
        {
            "popular" => source.OrderByDescending(x => x.LikeCount * 2 + x.ViewCount).ThenByDescending(x => x.PublishedAt).ToList(),
            "updated" => source.OrderByDescending(x => x.UpdatedAt).ThenByDescending(x => x.PublishedAt).ToList(),
            _ => source.OrderByDescending(x => x.PublishedAt).ToList()
        };
    }

    private string GetSortQuery(string? sort)
    {
        return ListQueryUrlBuilder.Build(GetWriterPath(), sort, query: null, page: 1, totalPages: totalPages);
    }

    private string GetSortChipClass(string? sort)
    {
        var target = (sort ?? string.Empty).Trim().ToLowerInvariant();
        var current = string.IsNullOrWhiteSpace(normalizedSort) ? "latest" : normalizedSort!;
        var isActive = (target == "latest" ? string.IsNullOrWhiteSpace(current) || current == "latest" : current == target);

        return isActive
            ? "rounded-full bg-slate-900 px-3 py-1.5 text-sm font-semibold text-white"
            : "rounded-full border border-slate-300 bg-white px-3 py-1.5 text-sm font-semibold text-slate-700 hover:bg-slate-100";
    }

    private string CurrentUserName => AuthState.CurrentUser?.UserName ?? string.Empty;

    private bool IsCurrentUsersPage => CurrentUser is not null
        && string.Equals(CurrentUserName, GetSloggerUserName(), StringComparison.OrdinalIgnoreCase);

    private bool IsPostBusy(string slug, HashSet<string> busySet) => busySet.Contains(slug);

    private static bool IsPriorityCardImage(int index) => index < 2;

    private static string GetPostUrl(BlogPost post)
        => $"/@{Uri.EscapeDataString(post.Author)}/{Uri.EscapeDataString(post.Slug)}";

    private static string GetPostCommentsUrl(BlogPost post)
        => $"{GetPostUrl(post)}#comments";

    private AuthUser? CurrentUser => AuthState.CurrentUser;

    private async Task ToggleLikeAsync(string slug)
    {
        if (AuthState.CurrentUser is null)
        {
            NavigateToLogin(GetLoginReturnUrl());
            return;
        }

        if (pendingLikeSlugs.Contains(slug))
        {
            return;
        }

        pendingLikeSlugs.Add(slug);
        try
        {
            await ApiClient.ToggleLikeAsync(slug, AuthState.CurrentUser.UserName);
            await LoadPostsAsync(Math.Max(posts.Count, PageSize));
            CapturePrerenderedState(currentStateKey);
        }
        finally
        {
            pendingLikeSlugs.Remove(slug);
        }
    }

    private async Task ToggleBookmarkAsync(string slug)
    {
        if (AuthState.CurrentUser is null)
        {
            NavigateToLogin(GetLoginReturnUrl());
            return;
        }

        if (pendingBookmarkSlugs.Contains(slug))
        {
            return;
        }

        pendingBookmarkSlugs.Add(slug);
        try
        {
            await ApiClient.ToggleBookmarkAsync(slug, AuthState.CurrentUser.UserName);
            await LoadPostsAsync(Math.Max(posts.Count, PageSize));
            CapturePrerenderedState(currentStateKey);
        }
        finally
        {
            pendingBookmarkSlugs.Remove(slug);
        }
    }

    private void NavigateToLogin(string returnUrl)
    {
        var encoded = Uri.EscapeDataString(string.IsNullOrWhiteSpace(returnUrl) ? "/" : returnUrl);
        NavigationManager.NavigateTo($"/login?returnUrl={encoded}");
    }

    private string GetLoginReturnUrl()
    {
        return ListQueryUrlBuilder.Build(GetWriterPath(), normalizedSort, query: null, page: 1, totalPages: totalPages);
    }

    private async Task LoadPostsAsync(int minimumVisibleCount = PageSize)
    {
        writerProfile = await ApiClient.GetUserAsync(Writer);
        var allPostsRaw = await ApiClient.GetByAuthorAsync(Writer);
        isWriterKnown = writerProfile is not null || allPostsRaw.Count > 0;

        if (!isWriterKnown)
        {

            totalCount = 0;
            totalPages = 0;
            posts = Array.Empty<BlogPost>();
            allAuthorPosts = Array.Empty<BlogPost>();
            allVisiblePosts = Array.Empty<BlogPost>();
            featuredPost = null;
            tagCloud = Array.Empty<(string Tag, int Count)>();
            seriesCloud = Array.Empty<(string Series, int Count)>();
            followerCount = 0;
            followingCount = 0;
            isFollowing = false;
            totalLikeCount = 0;
            totalCommentCount = 0;
            totalViewCount = 0;
            isLoadingMorePosts = false;
            return;
        }

        writerProfile ??= CreateSyntheticProfile(Writer, allPostsRaw);
        allAuthorPosts = allPostsRaw.OrderByDescending(x => x.PublishedAt).ToList();
        featuredPost = GetFeaturedPost(allPostsRaw);
        tagCloud = BuildTagCloud(allPostsRaw);
        seriesCloud = BuildSeriesCloud(allPostsRaw);
        totalLikeCount = allPostsRaw.Sum(x => x.LikeCount);
        totalCommentCount = allPostsRaw.Sum(x => x.CommentCount);
        totalViewCount = allPostsRaw.Sum(x => x.ViewCount);

        allVisiblePosts = SortPosts(allPostsRaw);
        totalCount = allVisiblePosts.Count;
        totalPages = totalCount == 0 ? 0 : (int)Math.Ceiling(totalCount / (double)PageSize);
        posts = allVisiblePosts.Take(Math.Min(allVisiblePosts.Count, Math.Max(PageSize, minimumVisibleCount))).ToList();
        isLoadingMorePosts = false;
        followerCount = await ApiClient.GetFollowerCountAsync(GetSloggerUserName());
        followingCount = (await ApiClient.GetFollowingAsync(GetSloggerUserName())).Count;
        isFollowing = CurrentUser is not null
            ? await ApiClient.IsFollowingAsync(CurrentUserName, GetSloggerUserName())
            : false;
    }

    private Task LoadMorePostsAsync()
    {
        if (isLoadingMorePosts || !HasMorePosts)
        {
            return Task.CompletedTask;
        }

        isLoadingMorePosts = true;
        try
        {
            posts = allVisiblePosts.Take(Math.Min(allVisiblePosts.Count, posts.Count + PageSize)).ToList();
            CapturePrerenderedState(currentStateKey);
        }
        finally
        {
            isLoadingMorePosts = false;
        }

        return Task.CompletedTask;
    }

    private static AuthUser CreateSyntheticProfile(string writer, IReadOnlyList<BlogPost> posts)
    {
        var firstAuthor = posts.FirstOrDefault()?.Author;
        var userName = string.IsNullOrWhiteSpace(firstAuthor) ? writer.Trim().ToLowerInvariant() : firstAuthor;
        return new AuthUser
        {
            UserName = userName,
            DisplayName = string.IsNullOrWhiteSpace(writer) ? userName : writer,
            Bio = "slogs에서 글을 발행하는 슬로거입니다.",
            RegisteredAt = posts.OrderBy(x => x.PublishedAt).FirstOrDefault()?.PublishedAt ?? DateTime.UtcNow
        };
    }

    private static BlogPost? GetFeaturedPost(IEnumerable<BlogPost> source)
    {
        return source
            .OrderByDescending(x => x.LikeCount * 4 + x.CommentCount * 3 + x.ViewCount + x.Tags.Count)
            .ThenByDescending(x => x.PublishedAt)
            .FirstOrDefault();
    }

    private static IReadOnlyList<(string Tag, int Count)> BuildTagCloud(IEnumerable<BlogPost> source)
    {
        return source
            .SelectMany(x => x.Tags)
            .Where(x => !string.IsNullOrWhiteSpace(x))
            .GroupBy(x => x.Trim(), StringComparer.OrdinalIgnoreCase)
            .OrderByDescending(x => x.Count())
            .ThenBy(x => x.Key, StringComparer.OrdinalIgnoreCase)
            .Select(x => (Tag: x.Key, Count: x.Count()))
            .ToList();
    }

    private static IReadOnlyList<(string Series, int Count)> BuildSeriesCloud(IEnumerable<BlogPost> source)
    {
        return source
            .SelectMany(x => x.Series)
            .Where(x => !string.IsNullOrWhiteSpace(x))
            .GroupBy(x => x.Trim(), StringComparer.OrdinalIgnoreCase)
            .OrderByDescending(x => x.Count())
            .ThenBy(x => x.Key, StringComparer.OrdinalIgnoreCase)
            .Select(x => (Series: x.Key, Count: x.Count()))
            .ToList();
    }

    private string GetWriterPath()
    {
        return $"/@{Uri.EscapeDataString(GetSloggerUserName())}";
    }

    private async Task ToggleFollowAsync()
    {
        if (CurrentUser is null)
        {
            NavigationManager.NavigateTo(GetLoginReturnUrlForWriter());
            return;
        }

        if (isFollowBusy)
        {
            return;
        }

        isFollowBusy = true;
        try
        {
            var isNowFollowing = await ApiClient.ToggleFollowAsync(CurrentUserName, GetSloggerUserName());
            isFollowing = isNowFollowing;
            followerCount = await ApiClient.GetFollowerCountAsync(GetSloggerUserName());
            CapturePrerenderedState(currentStateKey);
        }
        finally
        {
            isFollowBusy = false;
        }
    }

    private string GetLoginReturnUrlForWriter()
    {
        return $"/login?returnUrl={Uri.EscapeDataString(GetWriterPath())}";
    }

    private string GetFollowersPath()
    {
        return $"/@{Uri.EscapeDataString(GetSloggerUserName())}/followers";
    }

    private string GetFollowingPath()
    {
        return $"/@{Uri.EscapeDataString(GetSloggerUserName())}/following";
    }

    private string GetSloggerUserName()
    {
        return string.IsNullOrWhiteSpace(writerProfile?.UserName)
            ? Writer.Trim().ToLowerInvariant()
            : writerProfile.UserName;
    }

    private string GetSloggerDisplayName()
    {
        if (!string.IsNullOrWhiteSpace(writerProfile?.DisplayName))
        {
            return writerProfile.DisplayName;
        }

        return string.IsNullOrWhiteSpace(Writer) ? "슬로거" : Writer;
    }

    private string GetSloggerAddress() => $"/@{GetSloggerUserName()}";

    private string GetSloggerBio()
    {
        return string.IsNullOrWhiteSpace(writerProfile?.Bio)
            ? "slogs에서 생각과 작업 기록을 발행하는 슬로거입니다."
            : writerProfile.Bio;
    }

    private string GetSloggerSeoDescription()
    {
        return $"{GetSloggerDisplayName()}의 slogs 홈입니다. {GetSloggerBio()} 발행 글 {totalCount}개, 팔로워 {followerCount}명.";
    }

    private string GetInitials()
    {
        var source = GetSloggerDisplayName().Trim();
        if (string.IsNullOrWhiteSpace(source))
        {
            return "S";
        }

        var parts = source.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length > 1)
        {
            return string.Concat(parts.Take(2).Select(x => x[0])).ToUpperInvariant();
        }

        return source.Length == 1 ? source : source[..Math.Min(2, source.Length)].ToUpperInvariant();
    }

    private static string FormatDate(DateTime dateTime) => dateTime.ToLocalTime().ToString("yyyy.MM.dd");

    private static string Shorten(string text, int maxLength)
    {
        if (string.IsNullOrWhiteSpace(text))
        {
            return string.Empty;
        }

        return text.Length <= maxLength ? text : text[..maxLength] + "...";
    }

    private bool TryRestorePrerenderedState(string stateKey)
    {
        if (PrerenderedState?.StateKey != stateKey)
        {
            return false;
        }

        posts = PrerenderedState.Posts;
        allAuthorPosts = PrerenderedState.AllAuthorPosts;
        allVisiblePosts = PrerenderedState.AllVisiblePosts;
        tagCloud = PrerenderedState.TagCloud.Select(x => (x.Tag, x.Count)).ToList();
        seriesCloud = PrerenderedState.SeriesCloud.Select(x => (x.Series, x.Count)).ToList();
        featuredPost = PrerenderedState.FeaturedPost;
        writerProfile = PrerenderedState.WriterProfile;
        totalCount = PrerenderedState.TotalCount;
        totalPages = PrerenderedState.TotalPages;
        totalLikeCount = PrerenderedState.TotalLikeCount;
        totalCommentCount = PrerenderedState.TotalCommentCount;
        totalViewCount = PrerenderedState.TotalViewCount;
        followerCount = PrerenderedState.FollowerCount;
        followingCount = PrerenderedState.FollowingCount;
        isWriterKnown = PrerenderedState.IsWriterKnown;
        isFollowing = PrerenderedState.IsFollowing;
        normalizedSort = PrerenderedState.NormalizedSort;
        isLoadingMorePosts = false;
        return true;
    }

    private void CapturePrerenderedState(string stateKey)
    {
        PrerenderedState = new WriterPageState
        {
            StateKey = stateKey,
            Posts = posts.ToList(),
            AllAuthorPosts = allAuthorPosts.ToList(),
            AllVisiblePosts = allVisiblePosts.ToList(),
            TagCloud = tagCloud.Select(x => new TagSummary(x.Tag, x.Count)).ToList(),
            SeriesCloud = seriesCloud.Select(x => new SeriesSummary(x.Series, x.Count)).ToList(),
            FeaturedPost = featuredPost,
            WriterProfile = writerProfile,
            TotalCount = totalCount,
            TotalPages = totalPages,
            TotalLikeCount = totalLikeCount,
            TotalCommentCount = totalCommentCount,
            TotalViewCount = totalViewCount,
            FollowerCount = followerCount,
            FollowingCount = followingCount,
            IsWriterKnown = isWriterKnown,
            IsFollowing = isFollowing,
            NormalizedSort = normalizedSort
        };
    }
}
