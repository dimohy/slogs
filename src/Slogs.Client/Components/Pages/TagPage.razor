@page "/tag/{Tag}"
@inject SlogsApiClient ApiClient
@inject SlogsAuthState AuthState
@inject NavigationManager NavigationManager

<PageTitle>태그 - @Tag</PageTitle>
<SeoHead Title="@($"#{Tag} 글 | slogs")"
         Description="@($"slogs에서 #{Tag} 태그가 붙은 개발 글 {totalCount}개를 확인합니다.")"
         CanonicalPath="@GetTagPath()"
         NoIndex="@(totalCount == 0)"
         JsonLd="@(SeoMetadata.CollectionPageJsonLd(NavigationManager.BaseUri, GetTagPath(), $"#{Tag} 글", $"slogs에서 #{Tag} 태그가 붙은 개발 글을 확인합니다."))" />

<h1 class="text-2xl font-bold text-slate-900">#@Tag</h1>

<div class="mb-3 mt-1 flex flex-wrap gap-2">
    <a class="@GetSortChipClass(null)" href="@GetSortQuery(null)">최신</a>
    <a class="@GetSortChipClass("popular")" href="@GetSortQuery("popular")">인기</a>
    <a class="@GetSortChipClass("updated")" href="@GetSortQuery("updated")">최신 업데이트</a>
</div>

<section class="mt-4 grid grid-cols-1 gap-3 md:grid-cols-2">
    @if (!posts.Any())
    {
        <p class="rounded-2xl border border-slate-200 bg-white p-4 text-slate-500">해당 태그 글이 없습니다.</p>
    }
    else
    {
        @for (var index = 0; index < posts.Count; index++)
        {
            var post = posts[index];
            <article class="clickable-post-card rounded-2xl border border-slate-200 bg-white p-4"
                     data-card-click-href="@GetPostUrl(post)"
                     tabindex="0"
                     role="link"
                     aria-label="@($"{post.Title} 상세 보기")">
                <PostCardImage Post="post" PostUrl="@GetPostUrl(post)" Priority="@IsPriorityCardImage(index)" />
                <a class="mb-2 block text-xl font-bold text-slate-900 hover:underline" href="@GetPostUrl(post)">@post.Title</a>
                <PostMetaLine Post="post" ShowComments="true" />
                <p class="text-slate-700">@post.Summary</p>
                <div class="mt-2 flex flex-wrap gap-2">
                    @foreach (var tag in post.Tags)
                    {
                        <a class="rounded-full border border-sky-200 bg-sky-50 px-2.5 py-1 text-xs font-semibold text-sky-900 hover:bg-sky-100"
                           href="@($"/tag/{Uri.EscapeDataString(tag)}")">#@tag</a>
                    }
                </div>

                <PostActionBar Post="post"
                               CurrentUserName="@CurrentUserName"
                               CommentsUrl="@GetPostCommentsUrl(post)"
                               IsLikeBusy="@IsPostBusy(post.Slug, pendingLikeSlugs)"
                               IsBookmarkBusy="@IsPostBusy(post.Slug, pendingBookmarkSlugs)"
                               OnToggleLike="ToggleLikeAsync"
                               OnToggleBookmark="ToggleBookmarkAsync" />
            </article>
        }
    }
</section>

<InfiniteScrollSentinel Visible="@(posts.Count > 0)"
                        HasMore="@HasMorePosts"
                        IsLoading="@isLoadingMorePosts"
                        OnLoadMore="LoadMorePostsAsync"
                        ShowDoneText="@(allPosts.Count > PageSize)"
                        DoneText="모든 글을 불러왔습니다." />

@code {
    private const int PageSize = 6;

    [Parameter] public string Tag { get; set; } = string.Empty;
    [SupplyParameterFromQuery(Name = "sort")] public string? Sort { get; set; }

    private IReadOnlyList<BlogPost> posts = Array.Empty<BlogPost>();
    private IReadOnlyList<BlogPost> allPosts = Array.Empty<BlogPost>();
    private int totalCount;
    private int totalPages;
    private HashSet<string> pendingLikeSlugs = [];
    private HashSet<string> pendingBookmarkSlugs = [];
    private string? normalizedSort;
    private bool isLoadingMorePosts;
    private string currentStateKey = string.Empty;
    private bool HasMorePosts => posts.Count < allPosts.Count;

    [PersistentState]
    public ListPageState<BlogPost>? PrerenderedState { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        normalizedSort = ListQueryUrlBuilder.NormalizeSortValue(Sort, "latest", "popular", "updated");
        currentStateKey = PageStateKeyBuilder.FromNavigation(NavigationManager);
        var restoredPrerenderedState = TryRestorePrerenderedState(currentStateKey);

        await AuthState.EnsureInitializedAsync();

        if (restoredPrerenderedState)
        {
            return;
        }

        await LoadPostsAsync();
        CapturePrerenderedState(currentStateKey);
    }

    private IReadOnlyList<BlogPost> SortPosts(IEnumerable<BlogPost> source)
    {
        return normalizedSort switch
        {
            "popular" => source.OrderByDescending(x => x.LikeCount * 2 + x.ViewCount).ThenByDescending(x => x.PublishedAt).ToList(),
            "updated" => source.OrderByDescending(x => x.UpdatedAt).ThenByDescending(x => x.PublishedAt).ToList(),
            _ => source.OrderByDescending(x => x.PublishedAt).ToList()
        };
    }

    private string GetSortQuery(string? sort)
    {
        var normalizedSortValue = ListQueryUrlBuilder.NormalizeSortValue(sort, "latest", "popular", "updated") ?? normalizedSort;
        return ListQueryUrlBuilder.Build(GetTagPath(), normalizedSortValue, query: null, page: 1, totalPages: totalPages);
    }

    private string GetSortChipClass(string? sort)
    {
        var target = (sort ?? string.Empty).Trim().ToLowerInvariant();
        var current = string.IsNullOrWhiteSpace(normalizedSort) ? "latest" : normalizedSort!;
        var isActive = (target == "latest" ? string.IsNullOrWhiteSpace(current) || current == "latest" : current == target);

        return isActive
            ? "rounded-full bg-slate-900 px-3 py-1.5 text-sm font-semibold text-white"
            : "rounded-full border border-slate-300 bg-white px-3 py-1.5 text-sm font-semibold text-slate-700 hover:bg-slate-100";
    }

    private static string FormatDate(DateTime dateTime) => dateTime.ToLocalTime().ToString("yyyy.MM.dd");

    private string CurrentUserName => AuthState.CurrentUser?.UserName ?? string.Empty;

    private bool IsPostBusy(string slug, HashSet<string> busySet) => busySet.Contains(slug);

    private static bool IsPriorityCardImage(int index) => index < 2;

    private static string GetPostUrl(BlogPost post)
        => $"/@{Uri.EscapeDataString(post.Author)}/{Uri.EscapeDataString(post.Slug)}";

    private static string GetPostCommentsUrl(BlogPost post)
        => $"{GetPostUrl(post)}#comments";

    private bool IsLikeActionDisabled(string slug) => IsPostBusy(slug, pendingLikeSlugs) || IsPostBusy(slug, pendingBookmarkSlugs);

    private async Task ToggleLikeAsync(string slug)
    {
        if (AuthState.CurrentUser is null)
        {
            NavigateToLogin(GetLoginReturnUrl());
            return;
        }

        if (pendingLikeSlugs.Contains(slug))
        {
            return;
        }

        pendingLikeSlugs.Add(slug);
        try
        {
            await ApiClient.ToggleLikeAsync(slug, AuthState.CurrentUser.UserName);
            await LoadPostsAsync(Math.Max(posts.Count, PageSize));
            CapturePrerenderedState(currentStateKey);
        }
        finally
        {
            pendingLikeSlugs.Remove(slug);
        }
    }

    private async Task ToggleBookmarkAsync(string slug)
    {
        if (AuthState.CurrentUser is null)
        {
            NavigateToLogin(GetLoginReturnUrl());
            return;
        }

        if (pendingBookmarkSlugs.Contains(slug))
        {
            return;
        }

        pendingBookmarkSlugs.Add(slug);
        try
        {
            await ApiClient.ToggleBookmarkAsync(slug, AuthState.CurrentUser.UserName);
            await LoadPostsAsync(Math.Max(posts.Count, PageSize));
            CapturePrerenderedState(currentStateKey);
        }
        finally
        {
            pendingBookmarkSlugs.Remove(slug);
        }
    }

    private void NavigateToLogin(string returnUrl)
    {
        var encoded = Uri.EscapeDataString(string.IsNullOrWhiteSpace(returnUrl) ? "/" : returnUrl);
        NavigationManager.NavigateTo($"/login?returnUrl={encoded}");
    }

    private string GetLoginReturnUrl()
    {
        return ListQueryUrlBuilder.Build(GetTagPath(), normalizedSort, query: null, page: 1, totalPages: totalPages);
    }

    private async Task LoadPostsAsync(int minimumVisibleCount = PageSize)
    {
        var allPostsRaw = await ApiClient.GetByTagAsync(Tag);
        allPosts = SortPosts(allPostsRaw);
        totalCount = allPosts.Count;
        totalPages = totalCount == 0 ? 0 : (int)Math.Ceiling(totalCount / (double)PageSize);
        posts = allPosts.Take(Math.Min(allPosts.Count, Math.Max(PageSize, minimumVisibleCount))).ToList();
        isLoadingMorePosts = false;
    }

    private Task LoadMorePostsAsync()
    {
        if (isLoadingMorePosts || !HasMorePosts)
        {
            return Task.CompletedTask;
        }

        isLoadingMorePosts = true;
        try
        {
            posts = allPosts.Take(Math.Min(allPosts.Count, posts.Count + PageSize)).ToList();
            CapturePrerenderedState(currentStateKey);
        }
        finally
        {
            isLoadingMorePosts = false;
        }

        return Task.CompletedTask;
    }

    private string GetTagPath()
    {
        return $"/tag/{Uri.EscapeDataString(Tag)}";
    }

    private bool TryRestorePrerenderedState(string stateKey)
    {
        if (PrerenderedState?.StateKey != stateKey)
        {
            return false;
        }

        posts = PrerenderedState.Items;
        allPosts = PrerenderedState.AllItems;
        totalCount = PrerenderedState.TotalCount;
        totalPages = PrerenderedState.TotalPages;
        normalizedSort = PrerenderedState.NormalizedSort;
        isLoadingMorePosts = false;
        return true;
    }

    private void CapturePrerenderedState(string stateKey)
    {
        PrerenderedState = new ListPageState<BlogPost>
        {
            StateKey = stateKey,
            Items = posts.ToList(),
            AllItems = allPosts.ToList(),
            TotalCount = totalCount,
            TotalPages = totalPages,
            NormalizedSort = normalizedSort
        };
    }
}

