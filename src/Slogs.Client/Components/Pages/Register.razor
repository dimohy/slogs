@page "/register"
@inject SlogsAuthState AuthState
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>회원가입</PageTitle>
<SeoHead Title="회원가입 | slogs" Description="slogs 계정을 만듭니다." NoIndex="true" />

<form class="grid max-w-xl gap-3 rounded-2xl border border-slate-200 bg-white p-4"
      @onsubmit="SubmitRegister"
      @onsubmit:preventDefault>
    <h1 class="text-2xl font-bold text-slate-900">회원가입</h1>

    <label class="text-sm font-semibold text-slate-700" for="register-user-name">아이디</label>
    <input id="register-user-name" name="userName" class="rounded-2xl border border-slate-300 px-3 py-2 text-sm" autocomplete="username" @bind="userName" @bind:event="oninput" />

    <label class="text-sm font-semibold text-slate-700" for="register-display-name">표시 이름</label>
    <input id="register-display-name" name="displayName" class="rounded-2xl border border-slate-300 px-3 py-2 text-sm" autocomplete="name" @bind="displayName" @bind:event="oninput" />

    <label class="text-sm font-semibold text-slate-700" for="register-password">비밀번호</label>
    <input id="register-password" name="password" class="rounded-2xl border border-slate-300 px-3 py-2 text-sm" type="password" autocomplete="new-password" @bind="password" @bind:event="oninput" />

    <label class="text-sm font-semibold text-slate-700" for="register-confirm-password">비밀번호 확인</label>
    <input id="register-confirm-password" name="confirmPassword" class="rounded-2xl border border-slate-300 px-3 py-2 text-sm" type="password" autocomplete="new-password" @bind="confirmPassword" @bind:event="oninput" />

    <button class="w-fit rounded-full bg-slate-900 px-4 py-2 text-sm font-semibold text-white hover:bg-slate-800 disabled:cursor-not-allowed disabled:opacity-60"
            type="submit" disabled="@isSubmitting">@((isSubmitting) ? "가입 중..." : "가입하기")</button>

    @if (!string.IsNullOrWhiteSpace(ErrorMessage))
    {
        <p class="text-sm text-red-700">@ErrorMessage</p>
    }

    <p class="text-sm text-slate-500">이미 계정이 있다면 <a class="font-semibold underline" href="@GetLoginHref()">로그인</a>하세요.</p>
</form>

@code {
    [SupplyParameterFromQuery(Name = "returnUrl")] public string? ReturnUrl { get; set; }
    [SupplyParameterFromQuery(Name = "error")] public string? Error { get; set; }

    private string userName = string.Empty;
    private string displayName = string.Empty;
    private string password = string.Empty;
    private string confirmPassword = string.Empty;
    private string apiError = string.Empty;
    private bool isSubmitting;
    private string? SafeReturnUrl => TryNormalizeRelativeReturnUrl(ReturnUrl, out var safeUrl) ? safeUrl : null;
    private string ErrorMessage => !string.IsNullOrWhiteSpace(apiError)
        ? apiError
        : Error switch
    {
        "required" => "아이디와 비밀번호는 필수입니다.",
        "passwordLength" => "비밀번호는 4자 이상이어야 합니다.",
        "passwordMismatch" => "비밀번호가 일치하지 않습니다.",
        "displayNameLength" => "표시 이름은 30자 이하여야 합니다.",
        "duplicate" => "이미 사용 중인 아이디입니다.",
        _ => string.Empty
    };

    protected override async Task OnInitializedAsync()
    {
        await AuthState.EnsureInitializedAsync();
        if (AuthState.CurrentUser is not null)
        {
            Navigation.NavigateTo(SafeReturnUrl ?? "/me");
        }
    }

    private async Task SubmitRegister()
    {
        apiError = string.Empty;
        if (string.IsNullOrWhiteSpace(userName) || string.IsNullOrWhiteSpace(password))
        {
            apiError = "아이디와 비밀번호는 필수입니다.";
            return;
        }

        if (password.Length < 4)
        {
            apiError = "비밀번호는 4자 이상이어야 합니다.";
            return;
        }

        if (!string.Equals(password, confirmPassword, StringComparison.Ordinal))
        {
            apiError = "비밀번호가 일치하지 않습니다.";
            return;
        }

        if (displayName.Length > 30)
        {
            apiError = "표시 이름은 30자 이하여야 합니다.";
            return;
        }

        if (isSubmitting)
        {
            return;
        }

        isSubmitting = true;
        try
        {
            var result = await JS.InvokeAsync<AuthApiResult>(
                "slogsAuthApi.register",
                new
                {
                    userName,
                    displayName,
                    password,
                    confirmPassword,
                    returnUrl = SafeReturnUrl ?? "/me"
                });

            if (result.Ok)
            {
                Navigation.NavigateTo(NormalizeApiReturnUrl(result.ReturnUrl, "/me"), forceLoad: true);
                return;
            }

            apiError = MapAuthError(result.Error, result.Status == 409 ? "이미 사용 중인 아이디입니다." : "회원가입에 실패했습니다.");
        }
        catch (Exception)
        {
            apiError = "회원가입 처리 중 오류가 발생했습니다. 잠시 후 다시 시도해 주세요.";
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private bool TryNormalizeRelativeReturnUrl(string? returnUrl, out string safeUrl)
    {
        safeUrl = string.Empty;

        if (string.IsNullOrWhiteSpace(returnUrl))
        {
            return false;
        }

        if (!Uri.TryCreate(returnUrl, UriKind.RelativeOrAbsolute, out var returnUri))
        {
            return false;
        }

        if (!returnUri.IsAbsoluteUri && returnUri.OriginalString.StartsWith("/"))
        {
            safeUrl = returnUri.OriginalString;
            return true;
        }

        if (returnUri.IsAbsoluteUri)
        {
            var baseUri = new Uri(Navigation.BaseUri);
            if (returnUri.Host.Equals(baseUri.Host, StringComparison.OrdinalIgnoreCase))
            {
                safeUrl = returnUri.PathAndQuery;
                return true;
            }
        }

        return false;
    }

    private string GetLoginHref()
    {
        if (string.IsNullOrWhiteSpace(ReturnUrl) || !TryNormalizeRelativeReturnUrl(ReturnUrl, out var safeUrl))
        {
            return "/login";
        }

        return $"/login?returnUrl={Uri.EscapeDataString(safeUrl)}";
    }

    private string NormalizeApiReturnUrl(string? returnUrl, string fallback)
    {
        return TryNormalizeRelativeReturnUrl(returnUrl, out var safeUrl)
            ? safeUrl
            : fallback;
    }

    private static string MapAuthError(string? error, string fallback)
    {
        return error switch
        {
            "required" => "아이디와 비밀번호는 필수입니다.",
            "passwordLength" => "비밀번호는 4자 이상이어야 합니다.",
            "passwordMismatch" => "비밀번호가 일치하지 않습니다.",
            "displayNameLength" => "표시 이름은 30자 이하여야 합니다.",
            "duplicate" => "이미 사용 중인 아이디입니다.",
            _ => fallback
        };
    }

    private sealed class AuthApiResult
    {
        public bool Ok { get; set; }

        public int Status { get; set; }

        public string? Error { get; set; }

        public string? ReturnUrl { get; set; }
    }

}


