@page "/me/likes"
@inject SlogsAuthState AuthState
@inject SlogsApiClient ApiClient
@inject NavigationManager Navigation
<PageTitle>내 좋아요</PageTitle>
<SeoHead Title="내 좋아요 | slogs" Description="내가 좋아요한 slogs 글을 확인합니다." NoIndex="true" />

@if (CurrentUser is null)
{
    <p class="rounded-2xl border border-slate-200 bg-white p-4 text-slate-500">로그인이 필요합니다. <a class="font-semibold underline" href="@GetLoginHref()">로그인</a>해 주세요.</p>
}
else
{
    <div class="border-b border-slate-200 pb-4">
        <h1 class="text-2xl font-bold text-slate-900">내 좋아요</h1>
        <p class="mt-1 text-sm text-slate-500">좋아요한 글을 모아봅니다.</p>
    </div>

    @if (!string.IsNullOrWhiteSpace(message))
    {
        <p class="mt-3 rounded-lg border border-sky-200 bg-sky-50 px-3 py-2 text-sm text-sky-800">@message</p>
    }
    @if (totalCount > 0)
    {
        <p class="mt-2 text-sm text-slate-500">@($"{totalCount}개 글")</p>

        <div class="mt-3 flex flex-wrap gap-2 text-sm">
            <a class="@GetSortChipClass("latest")" href="@GetSortHref("latest")">최신순</a>
            <a class="@GetSortChipClass("popular")" href="@GetSortHref("popular")">인기순</a>
        </div>
    }

    <section class="slogs-post-list-grid mt-4 grid grid-cols-1 gap-3 md:grid-cols-2">
        @if (!likedPosts.Any())
        {
            <div class="slogs-post-list-empty grid min-h-64 place-items-center rounded-xl border border-dashed border-slate-300 bg-slate-50 px-6 py-10 text-center md:col-span-2">
                <div class="max-w-sm">
                    <p class="text-sm font-semibold text-slate-500">좋아요한 글이 없습니다.</p>
                </div>
            </div>
        }
        else
        {
            for (var index = 0; index < likedPosts.Count; index++)
            {
                var post = likedPosts[index];
                <article class="clickable-post-card rounded-2xl border border-slate-200 bg-white p-4"
                         data-card-click-href="@GetPostUrl(post)"
                         tabindex="0"
                         role="link"
                         aria-label="@($"{post.Title} 상세 보기")">
                    <PostCardImage Post="post" PostUrl="@GetPostUrl(post)" Priority="@IsPriorityCardImage(index)" />
                    <a class="mb-2 block text-xl font-bold text-slate-900 hover:underline" href="@GetPostUrl(post)">@post.Title</a>
                    <PostMetaLine Post="post" Class="flex flex-wrap items-center gap-2 text-sm text-slate-500" ShowLikes="true" ShowComments="true" />
                    @if (!string.IsNullOrWhiteSpace(post.Summary))
                    {
                        <p class="mt-2 text-sm text-slate-700">@Shorten(post.Summary, 140)</p>
                    }
                    <div class="mt-3 flex flex-wrap gap-2">
                        @foreach (var tag in post.Tags)
                        {
                            <a class="rounded-full border border-sky-200 bg-sky-50 px-2.5 py-1 text-xs font-semibold text-sky-900 hover:bg-sky-100"
                               href="@($"/tag/{Uri.EscapeDataString(tag)}")">#@tag</a>
                        }
                    </div>

                    <div class="mt-3">
                        <button class="rounded-full border border-rose-300 px-3 py-1.5 text-xs font-semibold text-rose-700 transition hover:bg-rose-50 disabled:cursor-not-allowed disabled:opacity-60"
                                disabled="@(!string.IsNullOrWhiteSpace(pendingRemoveSlug) && pendingRemoveSlug == post.Slug)"
                                type="button" @onclick="() => ToggleLike(post.Slug)">
                            @((!string.IsNullOrWhiteSpace(pendingRemoveSlug) && pendingRemoveSlug == post.Slug) ? "좋아요 해제 중..." : "좋아요 해제")
                        </button>
                    </div>
                </article>
            }
        }
    </section>

    <InfiniteScrollSentinel Visible="@(likedPosts.Count > 0)"
                            HasMore="@HasMoreLikedPosts"
                            IsLoading="@isLoadingMoreLikedPosts"
                            OnLoadMore="LoadMoreLikedPostsAsync"
                            ShowDoneText="@(allLikedPosts.Count > PageSize)"
                            DoneText="모든 좋아요 글을 불러왔습니다." />
}

@code {
    private const int PageSize = 6;

    private AuthUser? CurrentUser => AuthState.CurrentUser;
    [SupplyParameterFromQuery(Name = "sort")] public string? SortQuery { get; set; }
    private IReadOnlyList<BlogPost> likedPosts = Array.Empty<BlogPost>();
    private IReadOnlyList<BlogPost> allLikedPosts = Array.Empty<BlogPost>();
    private int totalCount;
    private int totalPages;
    private bool isLoadingMoreLikedPosts;
    private string pendingRemoveSlug = string.Empty;
    private string message = string.Empty;
    private string currentSort = "latest";
    private string currentStateKey = string.Empty;
    private bool HasMoreLikedPosts => likedPosts.Count < allLikedPosts.Count;

    [PersistentState]
    public ListPageState<BlogPost>? PrerenderedState { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await AuthState.EnsureInitializedAsync();
        if (CurrentUser is null)
        {

            Navigation.NavigateTo(GetLoginHref());
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        await AuthState.EnsureInitializedAsync();
        message = string.Empty;

        if (CurrentUser is null)
        {
            pendingRemoveSlug = string.Empty;
            return;
        }

        currentSort = ListQueryUrlBuilder.NormalizeSortValue(SortQuery, "latest", "popular") ?? "latest";
        currentStateKey = PageStateKeyBuilder.FromNavigation(Navigation);
        if (TryRestorePrerenderedState(currentStateKey))
        {
            return;
        }

        await LoadLikedPostsAsync();
        CapturePrerenderedState(currentStateKey);
    }

    private string GetSortHref(string sort)
    {
        var normalized = ListQueryUrlBuilder.NormalizeSortValue(sort, "latest", "popular") ?? "latest";
        return ListQueryUrlBuilder.Build("/me/likes", sort: normalized, query: null, page: 1, totalPages: totalPages);
    }

    private string GetSortChipClass(string sort)
    {
        return string.Equals(currentSort, sort, StringComparison.OrdinalIgnoreCase)
            ? "rounded-full bg-slate-900 px-3 py-1.5 text-sm font-semibold text-white"
            : "rounded-full border border-slate-300 bg-white px-3 py-1.5 text-sm font-semibold text-slate-700 hover:bg-slate-100";
    }

    private async Task ToggleLike(string slug)
    {
        message = string.Empty;

        if (CurrentUser is null)
        {
            message = "로그인이 필요합니다.";
            Navigation.NavigateTo(GetLoginHref());
            return;
        }

        if (!string.IsNullOrWhiteSpace(pendingRemoveSlug))
        {
            return;
        }

        pendingRemoveSlug = slug;
        StateHasChanged();

        try
        {
            var wasLiked = likedPosts.Any(x => x.Slug.Equals(slug, StringComparison.OrdinalIgnoreCase));
            var newState = await ApiClient.ToggleLikeAsync(slug, CurrentUser.UserName);
            await LoadLikedPostsAsync(Math.Max(likedPosts.Count, PageSize));
            CapturePrerenderedState(currentStateKey);

            message = (wasLiked && !newState)
                ? "좋아요가 해제되었습니다."
                : (!wasLiked && newState)
                    ? "좋아요가 추가되었습니다."
                    : "좋아요 변경에 실패했습니다.";
        }
        finally
        {
            pendingRemoveSlug = string.Empty;
        }
    }

    private async Task LoadLikedPostsAsync(int minimumVisibleCount = PageSize)
    {
        if (CurrentUser is null)
        {
            return;
        }

        currentSort = ListQueryUrlBuilder.NormalizeSortValue(SortQuery, "latest", "popular") ?? "latest";
        var allLiked = await ApiClient.GetLikedPostsAsync(CurrentUser.UserName);
        if (currentSort == "popular")
        {
            allLiked = allLiked.OrderByDescending(x => x.LikeCount).ThenByDescending(x => x.PublishedAt).ToList();
        }

        allLikedPosts = allLiked;
        totalCount = allLikedPosts.Count;
        totalPages = totalCount == 0 ? 0 : (int)Math.Ceiling(totalCount / (double)PageSize);
        likedPosts = allLikedPosts.Take(Math.Min(allLikedPosts.Count, Math.Max(PageSize, minimumVisibleCount))).ToList();
        isLoadingMoreLikedPosts = false;
    }

    private Task LoadMoreLikedPostsAsync()
    {
        if (isLoadingMoreLikedPosts || !HasMoreLikedPosts)
        {
            return Task.CompletedTask;
        }

        isLoadingMoreLikedPosts = true;
        try
        {
            likedPosts = allLikedPosts.Take(Math.Min(allLikedPosts.Count, likedPosts.Count + PageSize)).ToList();
            CapturePrerenderedState(currentStateKey);
        }
        finally
        {
            isLoadingMoreLikedPosts = false;
        }

        return Task.CompletedTask;
    }

    private string GetLoginHref()
    {
        var pathWithQuery = GetCurrentPathWithQuery();
        return $"/login?returnUrl={Uri.EscapeDataString(pathWithQuery)}";
    }

    private string GetCurrentPathWithQuery()
    {
        var uri = new Uri(Navigation.Uri);
        return string.IsNullOrWhiteSpace(uri.Query) ? uri.AbsolutePath : uri.PathAndQuery;
    }

    private static string GetPostUrl(BlogPost post)
        => $"/@{Uri.EscapeDataString(post.Author)}/{Uri.EscapeDataString(post.Slug)}";

    private static bool IsPriorityCardImage(int index) => index < 2;

    private static string FormatDate(DateTime dateTime) => dateTime.ToLocalTime().ToString("yyyy.MM.dd");

    private static string Shorten(string text, int maxLength)
    {
        if (string.IsNullOrWhiteSpace(text))
        {
            return string.Empty;
        }

        return text.Length <= maxLength ? text : text[..maxLength] + "...";
    }

    private bool TryRestorePrerenderedState(string stateKey)
    {
        if (PrerenderedState?.StateKey != stateKey)
        {
            return false;
        }

        likedPosts = PrerenderedState.Items;
        allLikedPosts = PrerenderedState.AllItems;
        totalCount = PrerenderedState.TotalCount;
        totalPages = PrerenderedState.TotalPages;
        currentSort = PrerenderedState.NormalizedSort ?? currentSort;
        message = PrerenderedState.Message ?? string.Empty;
        isLoadingMoreLikedPosts = false;
        return true;
    }

    private void CapturePrerenderedState(string stateKey)
    {
        PrerenderedState = new ListPageState<BlogPost>
        {
            StateKey = stateKey,
            Items = likedPosts.ToList(),
            AllItems = allLikedPosts.ToList(),
            TotalCount = totalCount,
            TotalPages = totalPages,
            NormalizedSort = currentSort,
            Message = message
        };
    }
}
