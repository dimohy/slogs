@page "/writer"
@inject SlogsApiClient ApiClient
@inject NavigationManager Navigation

<PageTitle>작성자</PageTitle>
<SeoHead Title="슬로거 | slogs"
         Description="slogs에서 글을 발행하는 슬로거를 찾고 개인 홈페이지로 이동합니다."
         CanonicalPath="/writer"
         NoIndex="@(!string.IsNullOrWhiteSpace(Query))"
         JsonLd="@(SeoMetadata.CollectionPageJsonLd(Navigation.BaseUri, "/writer", "slogs 슬로거", "slogs에서 글을 발행하는 슬로거를 찾고 개인 홈페이지로 이동합니다."))" />

<h1 class="text-2xl font-bold text-slate-900">작성자</h1>
<p class="mb-3 text-sm text-slate-500">작성자 목록에서 프로필을 선택하세요.</p>

<div class="mb-4 flex flex-wrap gap-2">
    <input class="min-w-0 flex-1 rounded-full border border-slate-300 bg-white px-3 py-2 text-sm outline-none transition focus:border-slate-900"
           value="@searchText"
           @oninput="HandleSearchInputChanged"
           @onkeydown="HandleSearchKeyDown"
           placeholder="작성자 검색"
           aria-label="작성자 검색어 입력" />
    <a class="rounded-full border border-slate-300 bg-slate-900 px-3 py-2 text-sm font-semibold text-white transition hover:bg-slate-700"
       href="@GetSearchResultHref()">
        검색
    </a>
    @if (!string.IsNullOrWhiteSpace(Query))
    {
        <a class="rounded-full border border-slate-300 px-3 py-2 text-sm font-semibold text-slate-700 transition hover:bg-slate-100"
           href="@GetListQuery(Sort)">
            검색 초기화
        </a>
    }
</div>

<div class="mb-4 flex flex-wrap gap-2">
    <a class="@GetSortChipClass(null)" href="@GetListQuery(null)">글 수</a>
    <a class="@GetSortChipClass("name")" href='@GetListQuery("name")'>이름순</a>
</div>

<section class="grid grid-cols-1 gap-3 sm:grid-cols-2">
@if (writers.Count == 0)
{
        <p class="rounded-2xl border border-slate-200 bg-white p-4 text-sm text-slate-500">
            @GetEmptyMessage()
        </p>
    }
    else
    {
        @foreach (var item in writers)
        {
            <a class="group rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-800 transition hover:bg-slate-900 hover:text-white"
               href="@($"/@{Uri.EscapeDataString(item.Author)}")">
                @item.Author
                <span class="ml-2 text-xs text-slate-500 transition group-hover:text-slate-200">(@item.Count)</span>
            </a>
        }
    }
</section>

<InfiniteScrollSentinel Visible="@(writers.Count > 0)"
                        HasMore="@HasMoreWriters"
                        IsLoading="@isLoadingMoreWriters"
                        OnLoadMore="LoadMoreWritersAsync"
                        ShowDoneText="@(allWriters.Count > PageSize)"
                        DoneText="모든 작성자를 불러왔습니다." />

@code {
    private const int PageSize = 12;

    [SupplyParameterFromQuery(Name = "sort")] public string? Sort { get; set; }
    [SupplyParameterFromQuery(Name = "q")] public string? Query { get; set; }

    private IReadOnlyList<AuthorSummary> writers = [];
    private IReadOnlyList<AuthorSummary> allWriters = [];
    private int totalPages;
    private bool isLoadingMoreWriters;
    private string searchText = string.Empty;
    private string? normalizedSort;
    private string currentStateKey = string.Empty;
    private bool HasMoreWriters => writers.Count < allWriters.Count;

    [PersistentState]
    public ListPageState<AuthorSummary>? PrerenderedState { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        searchText = Query ?? string.Empty;
        normalizedSort = ListQueryUrlBuilder.NormalizeSortValue(Sort, "count", "name");
        currentStateKey = PageStateKeyBuilder.FromNavigation(Navigation);
        if (TryRestorePrerenderedState(currentStateKey))
        {
            return;
        }

        await LoadWritersAsync();
        CapturePrerenderedState(currentStateKey);
    }

    private async Task LoadWritersAsync()
    {
        var loadedWriters = (await ApiClient.GetAuthorCloudAsync(200))
            .Select(x => new AuthorSummary(x.Author, x.Count))
            .ToList();

        if (!string.IsNullOrWhiteSpace(Query))
        {
            var normalized = Query.Trim();
            loadedWriters = [.. loadedWriters.Where(x => x.Author.Contains(normalized, StringComparison.OrdinalIgnoreCase))];
        }

        allWriters = normalizedSort switch
        {
            "name" => loadedWriters.OrderBy(x => x.Author, StringComparer.OrdinalIgnoreCase).ToList(),
            _ => loadedWriters.OrderByDescending(x => x.Count).ThenBy(x => x.Author, StringComparer.OrdinalIgnoreCase).ToList()
        };

        totalPages = allWriters.Count == 0 ? 0 : (int)Math.Ceiling(allWriters.Count / (double)PageSize);
        writers = allWriters.Take(PageSize).ToList();
        isLoadingMoreWriters = false;
    }

    private Task LoadMoreWritersAsync()
    {
        if (isLoadingMoreWriters || !HasMoreWriters)
        {
            return Task.CompletedTask;
        }

        isLoadingMoreWriters = true;
        try
        {
            writers = allWriters.Take(Math.Min(allWriters.Count, writers.Count + PageSize)).ToList();
            CapturePrerenderedState(currentStateKey);
        }
        finally
        {
            isLoadingMoreWriters = false;
        }

        return Task.CompletedTask;
    }

    private string GetListQuery(string? sort)
    {
        return BuildListQuery(sort: sort, query: Query);
    }

    private string GetEmptyMessage()
    {
        if (!string.IsNullOrWhiteSpace(Query))
        {
            return $"\"{Query.Trim()}\"에 대한 작성자 검색 결과가 없습니다.";
        }

        return "등록된 작성자가 아직 없습니다.";
    }

    private string GetSearchResultHref()
    {
        return BuildListQuery(sort: normalizedSort, query: searchText);
    }

    private string BuildListQuery(string? sort = null, string? query = null, int? page = null)
    {
        var normalizedSortValue = ListQueryUrlBuilder.NormalizeSortValue(sort, "count", "name") ?? normalizedSort;
        return ListQueryUrlBuilder.Build("/writer", normalizedSortValue, query ?? Query, page ?? 1, totalPages);
    }

    private string GetSortChipClass(string? sort)
    {
        var target = (sort ?? string.Empty).Trim().ToLowerInvariant();
        var current = string.IsNullOrWhiteSpace(normalizedSort) ? "count" : normalizedSort!;
        var isActive = (target == "count" ? string.IsNullOrWhiteSpace(current) || current == "count" : current == target);

        return isActive
            ? "rounded-full bg-slate-900 px-3 py-1.5 text-sm font-semibold text-white"
            : "rounded-full border border-slate-300 bg-white px-3 py-1.5 text-sm font-semibold text-slate-700 hover:bg-slate-100";
    }

    private void HandleSearchInputChanged(ChangeEventArgs e)
    {
        searchText = e?.Value?.ToString() ?? string.Empty;
    }

    private void HandleSearchKeyDown(KeyboardEventArgs e)
    {
        if (string.Equals(e.Key, "Enter", StringComparison.OrdinalIgnoreCase))
        {
            Navigation.NavigateTo(GetSearchResultHref());
        }
    }

    private bool TryRestorePrerenderedState(string stateKey)
    {
        if (PrerenderedState?.StateKey != stateKey)
        {
            return false;
        }

        writers = PrerenderedState.Items;
        allWriters = PrerenderedState.AllItems;
        totalPages = PrerenderedState.TotalPages;
        normalizedSort = PrerenderedState.NormalizedSort;
        isLoadingMoreWriters = false;
        return true;
    }

    private void CapturePrerenderedState(string stateKey)
    {
        PrerenderedState = new ListPageState<AuthorSummary>
        {
            StateKey = stateKey,
            Items = writers.ToList(),
            AllItems = allWriters.ToList(),
            TotalCount = allWriters.Count,
            TotalPages = totalPages,
            NormalizedSort = normalizedSort
        };
    }
}


