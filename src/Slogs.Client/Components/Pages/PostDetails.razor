@page "/@{Author}/{Slug}"
@page "/post/{Slug}"
@inject SlogsApiClient ApiClient
@inject SlogsAuthState AuthState
@inject NavigationManager Navigation
<PageTitle>@(post?.Title ?? "글을 찾을 수 없습니다")</PageTitle>
@if (post is null)
{
    <SeoHead Title="글을 찾을 수 없습니다 | slogs"
             Description="요청한 slogs 글을 찾을 수 없습니다."
             CanonicalPath="@GetCurrentCanonicalPath()"
             NoIndex="true" />
}
else
{
    <SeoHead Title="@($"{post.Title} | slogs")"
             Description="@post.Summary"
             CanonicalPath="@GetPostUrl(post)"
             Type="article"
             ImageUrl="@GetPostSeoImageUrl(post)"
             Author="@post.Author"
             Tags="@post.Tags"
             PublishedAt="@post.PublishedAt"
             UpdatedAt="@post.UpdatedAt"
             NoIndex="@post.IsDraft"
             JsonLd="@(post.IsDraft ? null : SeoMetadata.BlogPostingJsonLd(Navigation.BaseUri, post, GetPostUrl(post), GetPostSeoImageUrl(post)))" />
}

@if (post is null)
{
    <div class="rounded-2xl border border-slate-200 bg-white p-4">
        <h2 class="mb-2 text-xl font-bold text-slate-900">요청한 글을 찾지 못했습니다.</h2>
        <a class="font-semibold text-slate-800 underline" href="/">목록으로</a>
    </div>
}
else
{
    <article class="rounded-2xl border border-slate-200 bg-white p-4">
        <div class="flex flex-wrap items-center gap-2">
            <h1 class="text-2xl font-bold text-slate-900">@post.Title</h1>
            @if (post.IsDraft)
            {
                <span class="rounded-full border border-amber-200 bg-amber-50 px-2.5 py-1 text-xs font-semibold text-amber-800">게시전</span>
            }
            else
            {
                <span class="rounded-full border border-emerald-200 bg-emerald-50 px-2.5 py-1 text-xs font-semibold text-emerald-800">게시후</span>
            }
        </div>
        <div class="mt-2 flex flex-wrap items-center gap-2 text-xs text-slate-500">
            <a class="rounded-full border border-slate-200 bg-slate-50 px-2.5 py-1 hover:bg-slate-100" href="/">홈</a>
            <a class="rounded-full border border-slate-200 bg-slate-50 px-2.5 py-1 hover:bg-slate-100" href="@GetPostAuthorUrl()">작성자 페이지</a>
            <a class="rounded-full border border-slate-200 bg-slate-50 px-2.5 py-1 hover:bg-slate-100" href="#comments">댓글로 이동</a>
            <a class="rounded-full border border-slate-200 bg-slate-50 px-2.5 py-1 hover:bg-slate-100" href="#related-posts">연관 글 보기</a>
            @if (previousPost is not null)
            {
                <a class="rounded-full border border-slate-200 bg-slate-50 px-2.5 py-1 hover:bg-slate-100"
                   href="@GetPostUrl(previousPost)">이전 글 이동</a>
            }
            @if (nextPost is not null)
            {
                <a class="rounded-full border border-slate-200 bg-slate-50 px-2.5 py-1 hover:bg-slate-100"
                   href="@GetPostUrl(nextPost)">다음 글 이동</a>
            }
        </div>

        <div class="mt-2 flex flex-wrap items-center gap-2 text-sm text-slate-500">
            <a class="font-semibold text-slate-800 hover:underline"
               href="@($"/@{Uri.EscapeDataString(post.Author)}")">@FormatUserName(post.Author)</a>
            <span>@($"{authorFollowerCount}명 팔로워")</span>
            @if (post.IsDraft)
            {
                <span>게시전</span>
                <span>수정 @FormatDateTime(post.UpdatedAt)</span>
            }
            else
            {
                <span class="inline-flex items-center gap-1">
                    <SlogsIcon Name="calendar" Class="h-3.5 w-3.5" />
                    <span>@FormatDate(post.PublishedAt)</span>
                </span>
            }
            <span class="inline-flex items-center gap-1">
                <SlogsIcon Name="clock" Class="h-3.5 w-3.5" />
                <span>@post.ReadTimeMinutes 분</span>
            </span>
            <span class="inline-flex items-center gap-1">
                <SlogsIcon Name="eye" Class="h-3.5 w-3.5" />
                <span>@post.ViewCount</span>
            </span>
            @if (CanFollowAuthor)
            {
                <button class="ml-2 rounded-full border border-slate-300 px-3 py-1 text-sm font-semibold transition hover:bg-slate-100 @(isWriterFollowBusy ? "cursor-wait opacity-60" : "")"
                        disabled="@isWriterFollowBusy"
                        @onclick="ToggleFollowAuthor">
                    @(isFollowingAuthor ? "팔로우 해제" : "팔로우")
                </button>
            }
            else if (CurrentUser is null)
            {
                <a class="ml-2 rounded-full border border-slate-300 px-3 py-1 text-sm font-semibold transition hover:bg-slate-100"
                   href="@GetLoginReturnUrl()">팔로우</a>
            }
            @if (post.UpdatedAt > post.PublishedAt.AddMinutes(1))
            {
                <span>수정 @FormatDateTime(post.UpdatedAt)</span>
            }
        </div>

        <p class="mt-3 text-slate-700">@post.Summary</p>

        <div class="mt-3 flex flex-wrap gap-2">
            @foreach (var tag in post.Tags)
            {
                <a class="rounded-full border border-sky-200 bg-sky-50 px-2.5 py-1 text-xs font-semibold text-sky-900 hover:bg-sky-100"
                   href="@($"/tag/{Uri.EscapeDataString(tag)}")">#@tag</a>
            }
        </div>

        <MarkdownPreview Value="@post.Body" Class="mt-4" />

        <div class="mt-4 flex flex-wrap gap-2">
            @if (!post.IsDraft)
            {
                <PostActionBar Post="post"
                               CurrentUserName="@CurrentUserName"
                               CommentsUrl="#comments"
                               IsLikeBusy="@isLikeBusy"
                               IsBookmarkBusy="@isBookmarkBusy"
                               OnToggleLike="ToggleLikeFromActionBar"
                               OnToggleBookmark="ToggleBookmarkFromActionBar"
                               Class="flex flex-wrap gap-2" />
            }

            @if (CanEditCurrentPost)
            {
                <a class="rounded-full border border-slate-300 px-3 py-1.5 text-sm font-semibold transition hover:bg-slate-100" href="@GetEditHref()">@(post.IsDraft ? "게시전 수정" : "리비전 작성")</a>
                <button class="rounded-full border border-rose-300 px-3 py-1.5 text-sm font-semibold text-rose-700 transition hover:bg-rose-50"
                        disabled="@isDeletingPost"
                        type="button" @onclick="ShowDeleteConfirm">
                    @(isDeletingPost ? "삭제 중..." : "삭제")
                </button>
            }
        </div>
        @if (showDeleteConfirm)
        {
            <div class="mt-3 flex flex-col gap-2 rounded-xl border border-rose-200 bg-rose-50 p-3">
                <p class="text-sm font-semibold text-rose-900">이 글을 정말 삭제하시겠습니까?</p>
                <div class="flex flex-wrap gap-2">
                    <button class="rounded-full border border-rose-300 bg-rose-600 px-3 py-1.5 text-sm font-semibold text-white transition hover:bg-rose-700"
                            disabled="@isDeletingPost"
                            type="button" @onclick="DeletePost">
                        @(isDeletingPost ? "삭제 중..." : "삭제 진행")
                    </button>
                    <button class="rounded-full border border-slate-300 px-3 py-1.5 text-sm font-semibold transition hover:bg-slate-100"
                            disabled="@isDeletingPost"
                            type="button" @onclick="CancelDelete">
                        취소
                    </button>
                </div>
            </div>
        }
        @if (!string.IsNullOrWhiteSpace(message))
        {
            <div class="mt-3 rounded-lg border border-amber-200 bg-amber-50 px-3 py-2 text-sm text-amber-800">
                @message
            </div>
        }
    </article>

    @if (!post.IsDraft && revisions.Count > 0)
    {
        <section id="revisions" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4">
            <div class="mb-3 flex flex-wrap items-center justify-between gap-2">
                <h3 class="text-lg font-bold text-slate-900">리비전</h3>
                <span class="text-sm font-semibold text-slate-500">@($"{revisions.Count}개")</span>
            </div>
            <div class="grid gap-2">
                @foreach (var revision in revisions.OrderByDescending(x => x.RevisionNumber))
                {
                    <details class="rounded-xl border border-slate-200 bg-slate-50 p-3">
                        <summary class="cursor-pointer list-none">
                            <span class="flex flex-wrap items-center gap-2">
                                <span class="font-bold text-slate-900">@($"v{revision.RevisionNumber}")</span>
                                <span class="text-sm text-slate-500">@FormatDateTime(revision.CreatedAt)</span>
                                @foreach (var field in revision.ChangedFields)
                                {
                                    <span class="rounded-full border border-slate-200 bg-white px-2 py-0.5 text-xs font-semibold text-slate-700">@field</span>
                                }
                            </span>
                        </summary>
                        <div class="mt-3 grid gap-2 text-sm text-slate-700">
                            <p><span class="font-semibold text-slate-900">제목</span> @revision.Title</p>
                            @if (!string.IsNullOrWhiteSpace(revision.Summary))
                            {
                                <p><span class="font-semibold text-slate-900">요약</span> @revision.Summary</p>
                            }
                            @if (revision.Tags.Count > 0)
                            {
                                <p><span class="font-semibold text-slate-900">태그</span> @(string.Join(", ", revision.Tags.Select(x => $"#{x}")))</p>
                            }
                            @if (revision.Series.Count > 0)
                            {
                                <p><span class="font-semibold text-slate-900">시리즈</span> @(string.Join(", ", revision.Series))</p>
                            }
                        </div>
                        <MarkdownPreview Value="@revision.Body" Class="mt-3" />
                    </details>
                }
            </div>
        </section>
    }

    <section id="related-posts" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4">
        <h3 class="mb-3 text-lg font-bold text-slate-900">연관 글</h3>
        @if (relatedPosts.Count > 0)
        {
            <div class="grid grid-cols-1 gap-3 md:grid-cols-3">
                @for (var index = 0; index < relatedPosts.Count; index++)
                {
                    var item = relatedPosts[index];
            <article class="clickable-post-card rounded-2xl border border-slate-200 bg-white p-3"
                     data-card-click-href="@GetPostUrl(item)"
                     tabindex="0"
                     role="link"
                     aria-label="@($"{item.Title} 상세 보기")">
                <PostCardImage Post="item" PostUrl="@GetPostUrl(item)" Priority="@IsPriorityCardImage(index)" />
                <a class="mb-2 block text-base font-bold text-slate-800 hover:underline" href="@GetPostUrl(item)">@item.Title</a>
                <PostMetaLine Post="item" Class="flex flex-wrap items-center gap-2 text-sm text-slate-500" ShowReadTime="false" ShowViews="false" ShowSeries="false" />
            </article>
                }
            </div>
        }
        else
        {
            <p class="text-sm text-slate-500">연관 글이 없습니다.</p>
        }
    </section>

    @if (previousPost is not null || nextPost is not null)
    {
        <section class="mt-4 grid grid-cols-1 gap-3 md:grid-cols-2">
            <article class="clickable-post-card rounded-2xl border border-slate-200 bg-white p-4"
                     data-card-click-href="@(previousPost is null ? null : GetPostUrl(previousPost))"
                     tabindex="@(previousPost is null ? null : "0")"
                     role="@(previousPost is null ? null : "link")"
                     aria-label="@(previousPost is null ? null : $"{previousPost.Title} 상세 보기")">
                <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">이전 글</p>
                @if (previousPost is null)
                {
                    <p class="mt-2 text-sm text-slate-500">이전 글이 없습니다.</p>
                }
                else
                {
                    <a class="mt-2 block text-lg font-bold text-slate-900 transition hover:underline" href="@GetPostUrl(previousPost)">
                        @previousPost.Title
                    </a>
                    <a class="mt-1 block text-sm text-slate-500 hover:underline" href="@GetWriterUrl(previousPost.Author)">@FormatUserName(previousPost.Author)</a>
                }
            </article>

            <article class="clickable-post-card rounded-2xl border border-slate-200 bg-white p-4"
                     data-card-click-href="@(nextPost is null ? null : GetPostUrl(nextPost))"
                     tabindex="@(nextPost is null ? null : "0")"
                     role="@(nextPost is null ? null : "link")"
                     aria-label="@(nextPost is null ? null : $"{nextPost.Title} 상세 보기")">
                <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">다음 글</p>
                @if (nextPost is null)
                {
                    <p class="mt-2 text-sm text-slate-500">다음 글이 없습니다.</p>
                }
                else
                {
                    <a class="mt-2 block text-lg font-bold text-slate-900 transition hover:underline" href="@GetPostUrl(nextPost)">
                        @nextPost.Title
                    </a>
                    <a class="mt-1 block text-sm text-slate-500 hover:underline" href="@GetWriterUrl(nextPost.Author)">@FormatUserName(nextPost.Author)</a>
                }
            </article>
        </section>
    }

    <section id="comments" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4">
        <h3 class="mb-3 text-lg font-bold text-slate-900">댓글 (@post.CommentCount)</h3>

        @if (CurrentUser is null)
        {
            <p class="text-sm text-slate-500">댓글을 작성하려면 <a class="font-semibold underline" href="@GetLoginReturnUrl()">로그인</a>해 주세요.</p>
        }
        else
        {
            <div class="mt-2 flex flex-col gap-2">
                <div class="text-right text-xs text-slate-500">@($"{newComment?.Length ?? 0}/1000")</div>
                <div class="comment-compose">
                    <textarea class="comment-compose__input rounded-2xl border border-slate-300 p-3 text-sm"
                              disabled="@isCommentSaving"
                              rows="4" maxlength="1000" @bind="newComment" @bind:event="oninput"
                              @onkeydown="HandleCommentKeyDown" placeholder="의견을 남겨주세요"></textarea>
                    <button class="comment-compose__submit rounded-2xl bg-slate-900 px-4 py-2 text-sm font-semibold text-white hover:bg-slate-800 disabled:cursor-not-allowed disabled:opacity-60"
                            @onclick="SubmitComment" disabled="@(!CanSubmitComment)">
                        등록
                    </button>
                </div>
            </div>
        }

        @if (!post.Comments.Any())
        {
            <p class="mt-3 text-sm text-slate-500">첫 번째 댓글을 작성해 보세요.</p>
        }
        else
        {
            <div class="mt-2 flex flex-wrap gap-2 text-sm">
                <a class="@GetCommentSortChipClass("latest")" href="@GetCommentSortHref("latest")">최신순</a>
                <a class="@GetCommentSortChipClass("oldest")" href="@GetCommentSortHref("oldest")">오래된순</a>
            </div>

            @if (commentTotalCount > 0)
            {
                <p class="mt-1 text-xs text-slate-500">@($"정렬: {GetCommentSortLabel(commentSortOrder)} · 상위 댓글 {commentTotalCount}개")</p>
            }
            <div class="mt-3 flex flex-col gap-2">
                @foreach (var comment in topLevelComments)
                {
                    <article class="rounded-xl border-t border-slate-200 pt-2">
                        <div class="flex flex-wrap items-center gap-1 text-sm text-slate-500">
                            <a class="hover:underline" href="@GetCommentAuthorUrl(comment)">@FormatUserName(comment.Author)</a>
                            <span>·</span>
                            <span>@FormatDateTime(comment.CreatedAt)</span>
                            @if (CurrentUser is not null)
                            {
                                <span>·</span>
                                <button class="text-slate-700 transition hover:text-slate-900" type="button" disabled="@isCommentSaving" @onclick="() => StartReply(comment.Id)">
                                    답글
                                </button>
                            }
                            @if (CanEditComment(comment))
                            {
                                <span>·</span>
                                <button class="text-slate-700 transition hover:text-slate-900" type="button" disabled="@isCommentSaving" @onclick="() => StartEditComment(comment.Id)">
                                    수정
                                </button>
                            }
                            @if (CanDeleteComment(comment))
                            {
                                <span>·</span>
                                <button class="text-rose-600 transition hover:text-rose-700" type="button" disabled="@isCommentSaving" @onclick="() => RequestDeleteComment(comment.Id)">
                                    삭제
                                </button>
                            }
                        </div>

                        @if (pendingDeleteCommentId == comment.Id)
                        {
                            <div class="mt-2 rounded-lg border border-rose-200 bg-rose-50 p-2 text-sm text-rose-800">
                                <p class="mb-2">이 댓글을 삭제할까요?</p>
                                <div class="flex flex-wrap gap-2">
                                    <button class="rounded-full border border-rose-300 bg-rose-600 px-3 py-1 text-xs font-semibold text-white transition hover:bg-rose-700"
                                            type="button" disabled="@isCommentSaving" @onclick="ConfirmDeleteComment">
                                        삭제
                                    </button>
                                    <button class="rounded-full border border-slate-300 px-3 py-1 text-xs font-semibold transition hover:bg-slate-100"
                                            type="button" @onclick="CancelDeleteComment">
                                        취소
                                    </button>
                                </div>
                            </div>
                        }

                        @if (editingCommentId == comment.Id)
                        {
                            <textarea class="mt-1 min-h-20 w-full rounded-xl border border-slate-300 p-3 text-sm"
                                      disabled="@isCommentSaving"
                                      rows="3" maxlength="1000" @bind="editingCommentText" @bind:event="oninput"
                                      @onkeydown="(e) => HandleEditKeyDown(e, comment.Id)"></textarea>
                            <div class="mt-1 text-right text-xs text-slate-500">@($"{editingCommentText?.Length ?? 0}/1000")</div>
                            <div class="mt-2 flex flex-wrap gap-2">
                                <button class="rounded-full bg-slate-900 px-3 py-1.5 text-sm font-semibold text-white disabled:cursor-not-allowed disabled:opacity-60"
                                        type="button" @onclick="() => SubmitEditComment(comment.Id)"
                                        disabled="@(string.IsNullOrWhiteSpace(editingCommentText) || isCommentSaving)">
                                    수정 저장
                                </button>
                                <button class="rounded-full border border-slate-300 px-3 py-1.5 text-sm font-semibold text-slate-700 transition hover:bg-slate-100"
                                        type="button" @onclick="CancelEditComment">
                                    취소
                                </button>
                            </div>
                        }
                        else
                        {
                            <p class="mt-1 text-slate-700">@comment.Content</p>
                            @if (comment.IsEdited)
                            {
                                <p class="text-xs text-slate-400">수정됨</p>
                            }
                        }
                    </article>
                    @if (replyingToCommentId == comment.Id)
                    {
                        <div class="mt-2 rounded-2xl border border-slate-300 bg-slate-50 p-3">
                            <p class="mb-1 text-xs text-slate-500">[@FormatUserName(comment.Author)]에 대한 답글</p>
                            <div class="text-right text-xs text-slate-500">@($"{replyComment?.Length ?? 0}/1000")</div>
                            <textarea class="min-h-20 w-full rounded-xl border border-slate-300 p-3 text-sm"
                                      disabled="@isCommentSaving"
                                      rows="3" maxlength="1000" @bind="replyComment" @bind:event="oninput"
                                      placeholder="답글을 작성해 주세요"
                                      @onkeydown="(e) => HandleReplyKeyDown(e, comment.Id)"></textarea>
                            <div class="mt-2 flex flex-wrap gap-2">
                                <button class="rounded-full bg-slate-900 px-3 py-1.5 text-sm font-semibold text-white disabled:cursor-not-allowed disabled:opacity-60"
                                        type="button" @onclick="() => SubmitReply(comment.Id)" disabled="@(string.IsNullOrWhiteSpace(replyComment) || isCommentSaving)">
                                    답글 등록
                                </button>
                                <button class="rounded-full border border-slate-300 px-3 py-1.5 text-sm font-semibold text-slate-700 transition hover:bg-slate-100"
                                        type="button" @onclick="CancelReply">
                                    취소
                                </button>
                            </div>
                        </div>
                    }

                    @foreach (var reply in GetReplies(comment.Id))
                    {
                        <article class="ml-6 rounded-xl border-l-2 border-slate-200 pl-3 pt-2">
                            <div class="flex flex-wrap items-center gap-1 text-sm text-slate-500">
                                <a class="hover:underline" href="@GetCommentAuthorUrl(reply)">@FormatUserName(reply.Author)</a>
                                <span>·</span>
                                <span>@FormatDateTime(reply.CreatedAt)</span>
                            @if (CanDeleteComment(reply))
                            {
                                <span>·</span>
                                    <button class="text-rose-600 transition hover:bg-rose-200 hover:text-rose-700" type="button" disabled="@isCommentSaving" @onclick="() => RequestDeleteComment(reply.Id)">
                                    삭제
                                </button>
                            }
                            @if (CanEditComment(reply))
                            {
                                <span>·</span>
                                    <button class="text-slate-700 transition hover:bg-slate-100 hover:text-slate-900" type="button" disabled="@isCommentSaving" @onclick="() => StartEditComment(reply.Id)">
                                    수정
                                </button>
                            }
                            </div>

                            @if (pendingDeleteCommentId == reply.Id)
                            {
                                <div class="mt-2 rounded-lg border border-rose-200 bg-rose-50 p-2 text-sm text-rose-800">
                                    <p class="mb-2">이 답글을 삭제할까요?</p>
                                    <div class="flex flex-wrap gap-2">
                                        <button class="rounded-full border border-rose-300 bg-rose-600 px-3 py-1 text-xs font-semibold text-white transition hover:bg-rose-700"
                                                type="button" @onclick="ConfirmDeleteComment">
                                            삭제
                                        </button>
                                        <button class="rounded-full border border-slate-300 px-3 py-1 text-xs font-semibold transition hover:bg-slate-100"
                                                type="button" @onclick="CancelDeleteComment">
                                            취소
                                        </button>
                                    </div>
                                </div>
                            }

                            @if (editingCommentId == reply.Id)
                            {
                                <textarea class="mt-1 min-h-20 w-full rounded-xl border border-slate-300 p-3 text-sm"
                                          disabled="@isCommentSaving"
                                          rows="3" maxlength="1000" @bind="editingCommentText" @bind:event="oninput"
                                          @onkeydown="(e) => HandleEditKeyDown(e, reply.Id)"></textarea>
                                <div class="mt-1 text-right text-xs text-slate-500">@($"{editingCommentText?.Length ?? 0}/1000")</div>
                                <div class="mt-2 flex flex-wrap gap-2">
                                    <button class="rounded-full bg-slate-900 px-3 py-1.5 text-sm font-semibold text-white disabled:cursor-not-allowed disabled:opacity-60"
                                            type="button" @onclick="() => SubmitEditComment(reply.Id)"
                                            disabled="@(string.IsNullOrWhiteSpace(editingCommentText) || isCommentSaving)">
                                        수정 저장
                                    </button>
                                    <button class="rounded-full border border-slate-300 px-3 py-1.5 text-sm font-semibold text-slate-700 transition hover:bg-slate-100"
                                            type="button" @onclick="CancelEditComment">
                                        취소
                                    </button>
                                </div>
                            }
                            else
                            {
                                <p class="mt-1 text-slate-700">@reply.Content</p>
                                @if (reply.IsEdited)
                                {
                                    <p class="text-xs text-slate-400">수정됨</p>
                                }
                            }
                        </article>
                    }
                }
            </div>

            <InfiniteScrollSentinel Visible="@(topLevelComments.Count > 0)"
                                    HasMore="@HasMoreComments"
                                    IsLoading="@isLoadingMoreComments"
                                    OnLoadMore="LoadMoreCommentsAsync"
                                    ShowDoneText="@(allTopLevelComments.Count > CommentPageSize)"
                                    DoneText="모든 댓글을 불러왔습니다." />
        }
    </section>
}

@code {
    [Parameter] public string Author { get; set; } = string.Empty;
    [Parameter] public string Slug { get; set; } = string.Empty;
