    private async Task HandleReplyKeyDown(KeyboardEventArgs e, Guid parentCommentId)
    {
        if (e.Key == "Enter" && (e.CtrlKey || e.MetaKey))
        {
            await SubmitReply(parentCommentId);
        }
    }

    private async Task HandleEditKeyDown(KeyboardEventArgs e, Guid commentId)
    {
        if (e.Key == "Enter" && (e.CtrlKey || e.MetaKey))
        {
            await SubmitEditComment(commentId);
        }
    }

    private async Task ConfirmDeleteComment()
    {
        if (pendingDeleteCommentId is null)
        {
            return;
        }

        if (isCommentSaving)
        {
            message = "현재 댓글 작업이 진행 중입니다. 잠시 후 다시 시도해 주세요.";
            return;
        }

        await DeleteComment(pendingDeleteCommentId.Value);
    }

    private async Task DeleteComment(Guid commentId)
    {
        if (CurrentUser is null || post is null)
        {
            NavigateToLogin();
            return;
        }

        var target = FindComment(commentId);
        if (target is null)
        {
            message = "삭제할 댓글을 찾을 수 없습니다.";
            pendingDeleteCommentId = null;
            return;
        }

        if (!TryBeginCommentAction(CommentActionKind.DeleteComment, commentId))
        {
            return;
        }

        pendingDeleteCommentId = commentId;

        try
        {
        var deleted = await ApiClient.RemoveCommentAsync(post.Slug, commentId, CurrentUser.UserName);
        if (!deleted)
        {
            message = "댓글 삭제에 실패했습니다.";
            pendingDeleteCommentId = null;
            return;
        }

        await RefreshPostAsync();
        pendingDeleteCommentId = null;
        message = "댓글이 삭제되었습니다.";
        }
        finally
        {
            EndCommentAction();
        }
    }

    private const int MaxCommentLength = 1000;
    private const int CommentPageSize = 10;

    private void LoadCommentPage(int minimumVisibleCount = CommentPageSize)
    {
        if (post is null)
        {
            topLevelComments = Array.Empty<BlogComment>();
            allTopLevelComments = Array.Empty<BlogComment>();
            commentCurrentPage = 1;
            commentTotalPages = 1;
            commentTotalCount = 0;
            isLoadingMoreComments = false;
            return;
        }

        allTopLevelComments = (commentSortOrder is "oldest"
            ? post.Comments
                .Where(x => x.ParentCommentId is null)
                .OrderBy(x => x.CreatedAt)
            : post.Comments
                .Where(x => x.ParentCommentId is null)
                .OrderByDescending(x => x.CreatedAt))
            .ToArray();

        commentTotalCount = allTopLevelComments.Count;
        commentTotalPages = Math.Max(1, (int)Math.Ceiling(allTopLevelComments.Count / (double)CommentPageSize));
        commentCurrentPage = 1;
        topLevelComments = allTopLevelComments
            .Take(Math.Min(allTopLevelComments.Count, Math.Max(CommentPageSize, minimumVisibleCount)))
            .ToArray();
        isLoadingMoreComments = false;
    }

    private Task LoadMoreCommentsAsync()
    {
        if (isLoadingMoreComments || !HasMoreComments)
        {
            return Task.CompletedTask;
        }

        isLoadingMoreComments = true;
        try
        {
            topLevelComments = allTopLevelComments
                .Take(Math.Min(allTopLevelComments.Count, topLevelComments.Count + CommentPageSize))
                .ToArray();
            commentCurrentPage = Math.Max(1, (int)Math.Ceiling(topLevelComments.Count / (double)CommentPageSize));
            CapturePrerenderedState(currentStateKey);
        }
        finally
        {
            isLoadingMoreComments = false;
        }

        return Task.CompletedTask;
    }

    private string GetCommentSortHref(string sortOrder)
    {
        var normalizedSort = NormalizeCommentSortOrder(sortOrder);
        var query = new List<string>();
        if (!string.Equals(normalizedSort, "latest", StringComparison.OrdinalIgnoreCase))
        {
            query.Add($"commentOrder={Uri.EscapeDataString(normalizedSort)}");
        }

        return query.Count == 0
            ? $"{GetPostUrl(post!)}#comments"
            : $"{GetPostUrl(post!)}?{string.Join("&", query)}#comments";
    }

    private string GetCommentSortChipClass(string sortOrder)
    {
        var isActive = string.Equals(commentSortOrder, sortOrder, StringComparison.OrdinalIgnoreCase);
        return isActive
            ? "rounded-full bg-slate-900 px-3 py-1.5 text-sm font-semibold text-white"
            : "rounded-full border border-slate-300 bg-white px-3 py-1.5 text-sm font-semibold text-slate-700 hover:bg-slate-100";
    }

    private static string NormalizeCommentSortOrder(string? commentOrder)
    {
        if (string.Equals(commentOrder?.Trim(), "oldest", StringComparison.OrdinalIgnoreCase))
        {
            return "oldest";
        }

        return "latest";
    }

    private static string GetCommentSortLabel(string sortOrder)
        => string.Equals(sortOrder, "oldest", StringComparison.OrdinalIgnoreCase)
            ? "오래된순"
            : "최신순";

    private async Task ToggleFollowAuthor()
    {
        if (CurrentUser is null || post is null)
        {
            NavigateToLogin();
            return;
        }

        if (isWriterFollowBusy)
        {
            return;
        }

        isWriterFollowBusy = true;
        try
        {
            var isNowFollowing = await ApiClient.ToggleFollowAsync(CurrentUserName, post.Author);
            isFollowingAuthor = isNowFollowing;
            authorFollowerCount = await ApiClient.GetFollowerCountAsync(post.Author);
            CapturePrerenderedState(currentStateKey);
        }
        finally
        {
            isWriterFollowBusy = false;
        }
    }

    private bool TryRestorePrerenderedState(string stateKey)
    {
        if (PrerenderedState?.StateKey != stateKey)
        {
            return false;
        }

        post = PrerenderedState.Post;
        loadedPostSlug = PrerenderedState.LoadedPostSlug;
        relatedPosts = PrerenderedState.RelatedPosts;
        revisions = PrerenderedState.Revisions;
        previousPost = PrerenderedState.PreviousPost;
        nextPost = PrerenderedState.NextPost;
        topLevelComments = PrerenderedState.TopLevelComments;
        allTopLevelComments = PrerenderedState.AllTopLevelComments;
        commentCurrentPage = PrerenderedState.CommentCurrentPage;
        commentTotalPages = PrerenderedState.CommentTotalPages;
        commentTotalCount = PrerenderedState.CommentTotalCount;
        commentSortOrder = string.IsNullOrWhiteSpace(PrerenderedState.CommentSortOrder)
            ? commentSortOrder
            : PrerenderedState.CommentSortOrder;
        authorFollowerCount = PrerenderedState.AuthorFollowerCount;
        isFollowingAuthor = PrerenderedState.IsFollowingAuthor;
        message = PrerenderedState.Message;
        isLoadingMoreComments = false;
        return true;
    }

    private void CapturePrerenderedState(string stateKey)
    {
        PrerenderedState = new PostDetailsPageState
        {
            StateKey = stateKey,
            Post = post,
            LoadedPostSlug = loadedPostSlug,
            RelatedPosts = relatedPosts.ToList(),
            Revisions = revisions.ToList(),
            PreviousPost = previousPost,
            NextPost = nextPost,
            TopLevelComments = topLevelComments.ToList(),
            AllTopLevelComments = allTopLevelComments.ToList(),
            CommentCurrentPage = commentCurrentPage,
            CommentTotalPages = commentTotalPages,
            CommentTotalCount = commentTotalCount,
            CommentSortOrder = commentSortOrder,
            AuthorFollowerCount = authorFollowerCount,
            IsFollowingAuthor = isFollowingAuthor,
            Message = message
        };
    }
