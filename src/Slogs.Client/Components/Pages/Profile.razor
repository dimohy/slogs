@page "/me"
@inject SlogsAuthState AuthState
@inject SlogsApiClient ApiClient
@inject NavigationManager Navigation

<PageTitle>내 글</PageTitle>
<SeoHead Title="내 글 | slogs" Description="내가 작성한 slogs 글을 관리합니다." NoIndex="true" />

@if (CurrentUser is null)
{
    <p class="rounded-2xl border border-slate-200 bg-white p-4 text-slate-500">로그인이 필요합니다. <a class="font-semibold underline" href="@GetLoginHref()">로그인</a>해 주세요.</p>
}
else
{
    <section class="space-y-4">
        <div class="flex flex-wrap items-end justify-between gap-3 border-b border-slate-200 pb-4">
            <div>
                <h1 class="text-2xl font-bold text-slate-900">내 글</h1>
                <p class="mt-1 text-sm text-slate-500">@CurrentUser.DisplayName 님이 작성한 글을 관리합니다.</p>
            </div>
            <div class="flex flex-wrap items-center gap-2">
                @if (totalCount > 0)
                {
                    <span class="rounded-full border border-slate-200 bg-slate-100 px-3 py-1 text-sm font-semibold text-slate-600">@($"{totalCount}개 글")</span>
                }
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(message))
        {
            <p class="mt-2 rounded-lg border border-rose-200 bg-rose-50 px-3 py-2 text-sm text-rose-800">@message</p>
        }

        <section class="mt-4 grid grid-cols-1 gap-3 md:grid-cols-2">
            @if (!myPosts.Any())
            {
                <div class="grid min-h-64 place-items-center rounded-xl border border-dashed border-slate-300 bg-slate-50 px-6 py-10 text-center md:col-span-2">
                    <div class="max-w-sm">
                        <p class="text-sm font-semibold text-slate-500">저장한 글이 없습니다.</p>
                    </div>
                </div>
            }
            else
            {
                for (var index = 0; index < myPosts.Count; index++)
                {
                    var post = myPosts[index];
                    <article class="clickable-post-card rounded-2xl border border-slate-200 bg-white p-4"
                             data-card-click-href="@GetPostUrl(post)"
                             tabindex="0"
                             role="link"
                             aria-label="@GetPostCardAriaLabel(post)">
                        <PostCardImage Post="post" PostUrl="@GetPostUrl(post)" Priority="@IsPriorityCardImage(index)" />
                        <a class="mb-2 block text-xl font-bold text-slate-900 hover:underline" href="@GetPostUrl(post)">@post.Title</a>
                        <div class="flex flex-wrap items-center gap-2 text-sm text-slate-500">
                            <a class="font-semibold text-slate-800 hover:underline" href="@($"/@{Uri.EscapeDataString(post.Author)}")">@FormatUserName(post.Author)</a>
                            @if (post.IsDraft)
                            {
                                <span class="rounded-full border border-amber-200 bg-amber-50 px-2 py-0.5 text-xs font-semibold text-amber-800">게시전</span>
                                <span>수정 @FormatDate(post.UpdatedAt)</span>
                            }
                            else
                            {
                                <span class="rounded-full border border-emerald-200 bg-emerald-50 px-2 py-0.5 text-xs font-semibold text-emerald-800">게시후</span>
                            }
                            @if (!post.IsDraft)
                            {
                            <span class="inline-flex items-center gap-1">
                                <SlogsIcon Name="calendar" Class="h-3.5 w-3.5" />
                                <span>@FormatDate(post.PublishedAt)</span>
                            </span>
                            }
                            <span class="inline-flex items-center gap-1">
                                <SlogsIcon Name="clock" Class="h-3.5 w-3.5" />
                                <span>@post.ReadTimeMinutes 분</span>
                            </span>
                            <span class="inline-flex items-center gap-1">
                                <SlogsIcon Name="heart" Class="h-3.5 w-3.5" />
                                <span>@post.LikeCount</span>
                            </span>
                            <span class="inline-flex items-center gap-1">
                                <SlogsIcon Name="message-circle" Class="h-3.5 w-3.5" />
                                <span>@post.CommentCount</span>
                            </span>
                            <span class="inline-flex items-center gap-1">
                                <SlogsIcon Name="eye" Class="h-3.5 w-3.5" />
                                <span>@post.ViewCount</span>
                            </span>
                            @if (post.Series.Count > 0)
                            {
                                @foreach (var series in post.Series)
                                {
                                    <a class="rounded-full border border-slate-200 px-2 py-0.5 text-xs font-semibold text-slate-600 hover:bg-slate-50"
                                       href="@($"/series/{Uri.EscapeDataString(series)}")">시리즈: @series</a>
                                }
                            }
                        </div>
                        @if (!string.IsNullOrWhiteSpace(post.Summary))
                        {
                            <p class="mt-2 text-sm text-slate-700">@Shorten(post.Summary, 140)</p>
                        }

                        <div class="mt-2 flex flex-wrap gap-2">
                            @foreach (var tag in post.Tags)
                            {
                                @if (post.IsDraft)
                                {
                                    <span class="rounded-full border border-slate-200 bg-slate-50 px-2.5 py-1 text-xs font-semibold text-slate-600">#@tag</span>
                                }
                                else
                                {
                                    <a class="rounded-full border border-sky-200 bg-sky-50 px-2.5 py-1 text-xs font-semibold text-sky-900 hover:bg-sky-100"
                                       href="@($"/tag/{Uri.EscapeDataString(tag)}")">#@tag</a>
                                }
                            }
                        </div>

                        <div class="mt-3 flex flex-wrap gap-2">
                            <a class="rounded-full border border-slate-300 px-3 py-1.5 text-xs font-semibold text-slate-700 transition hover:bg-slate-100"
                               href="@($"/edit/{Uri.EscapeDataString(post.Slug)}")">@(post.IsDraft ? "게시전 수정" : "리비전 작성")</a>
                            <button class="rounded-full border border-rose-300 px-3 py-1.5 text-xs font-semibold text-rose-700 transition hover:bg-rose-50 disabled:cursor-not-allowed disabled:opacity-60"
                                    disabled="@(isDeleting && deletingSlug == post.Slug)"
                                    type="button" @onclick="() => RequestDelete(post.Slug)">
                                @((isDeleting && deletingSlug == post.Slug) ? "삭제 중..." : "삭제")
                            </button>
                        </div>
                    </article>
                }
            }
        </section>

        <InfiniteScrollSentinel Visible="@(myPosts.Count > 0)"
                                HasMore="@HasMoreMyPosts"
                                IsLoading="@isLoadingMorePosts"
                                OnLoadMore="LoadMorePostsAsync"
                                ShowDoneText="@(allPosts.Count > PageSize)"
                                DoneText="모든 글을 불러왔습니다." />
    </section>
}

@if (showDeleteConfirm)
{
    <div class="mt-4 rounded-xl border border-rose-200 bg-rose-50 p-4">
        <p class="text-sm font-semibold text-rose-900">이 글을 삭제하시겠습니까?</p>
        <p class="mb-2 text-sm text-rose-800">@($"\"{postToDeleteTitle}\"")</p>
        <div class="flex flex-wrap gap-2">
            <button class="rounded-full border border-rose-300 bg-rose-600 px-3 py-1.5 text-sm font-semibold text-white transition hover:bg-rose-700"
                    disabled="@isDeleting"
                    type="button" @onclick="ConfirmDelete">삭제 진행</button>
            <button class="rounded-full border border-slate-300 px-3 py-1.5 text-sm font-semibold transition hover:bg-slate-100"
                    type="button" @onclick="CancelDelete">취소</button>
        </div>
    </div>
}

@code {
    private const int PageSize = 6;

    private AuthUser? CurrentUser => AuthState.CurrentUser;
    private IReadOnlyList<BlogPost> myPosts = Array.Empty<BlogPost>();
    private IReadOnlyList<BlogPost> allPosts = Array.Empty<BlogPost>();
    private int totalCount;
    private int totalPages;
    private bool isLoadingMorePosts;
    private bool showDeleteConfirm;
    private bool isDeleting;
    private string deletingSlug = string.Empty;
    private string postToDeleteSlug = string.Empty;
    private string postToDeleteTitle = string.Empty;
    private string message = string.Empty;
    private string currentStateKey = string.Empty;
    private bool HasMoreMyPosts => myPosts.Count < allPosts.Count;

    [PersistentState]
    public ListPageState<BlogPost>? PrerenderedState { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await AuthState.EnsureInitializedAsync();
        if (CurrentUser is null)
        {
            Navigation.NavigateTo(GetLoginHref());
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        await AuthState.EnsureInitializedAsync();
        if (CurrentUser is null)
        {
            showDeleteConfirm = false;
            postToDeleteSlug = string.Empty;
            postToDeleteTitle = string.Empty;
            isDeleting = false;
            deletingSlug = string.Empty;
            return;
        }

        currentStateKey = PageStateKeyBuilder.FromNavigation(Navigation);
        if (TryRestorePrerenderedState(currentStateKey))
        {
            return;
        }

        await LoadPostsAsync();
        CapturePrerenderedState(currentStateKey);
    }

    private async Task LoadPostsAsync(int minimumVisibleCount = PageSize)
    {
        if (CurrentUser is null)
        {
            return;
        }

        allPosts = await ApiClient.GetMyPostsAsync(CurrentUser.UserName);
        totalCount = allPosts.Count;
        totalPages = totalCount == 0 ? 0 : (int)Math.Ceiling(totalCount / (double)PageSize);
        myPosts = allPosts.Take(Math.Min(allPosts.Count, Math.Max(PageSize, minimumVisibleCount))).ToList();
        isLoadingMorePosts = false;
    }

    private Task LoadMorePostsAsync()
    {
        if (isLoadingMorePosts || !HasMoreMyPosts)
        {
            return Task.CompletedTask;
        }

        isLoadingMorePosts = true;
        try
        {
            myPosts = allPosts.Take(Math.Min(allPosts.Count, myPosts.Count + PageSize)).ToList();
            CapturePrerenderedState(currentStateKey);
        }
        finally
        {
            isLoadingMorePosts = false;
        }

        return Task.CompletedTask;
    }

    private async Task ConfirmDelete()
    {
        if (isDeleting)
        {
            return;
        }

        if (string.IsNullOrWhiteSpace(postToDeleteSlug) || CurrentUser is null)
        {
            showDeleteConfirm = false;
            message = "삭제할 글을 찾을 수 없습니다.";
            isDeleting = false;
            return;
        }

        isDeleting = true;
        StateHasChanged();

        try
        {
            var deleted = await ApiClient.DeletePostAsync(postToDeleteSlug, CurrentUser.UserName);
            if (!deleted)
            {
                message = "삭제에 실패했습니다.";
                return;
            }

            showDeleteConfirm = false;
            postToDeleteSlug = string.Empty;
            postToDeleteTitle = string.Empty;
            deletingSlug = string.Empty;
            await LoadPostsAsync(Math.Max(myPosts.Count, PageSize));
            CapturePrerenderedState(currentStateKey);
            message = "게시글이 삭제되었습니다.";
        }
        catch (Exception ex)
        {
            showDeleteConfirm = false;
            message = $"삭제 요청 중 오류가 발생했습니다: {ex.Message}";
        }
        finally
        {
            isDeleting = false;
        }
    }

    private void RequestDelete(string slug)
    {
        if (CurrentUser is null)
        {
            return;
        }

        var target = myPosts.FirstOrDefault(x => x.Slug.Equals(slug, StringComparison.OrdinalIgnoreCase));
        if (target is null)
        {
            return;
        }

        showDeleteConfirm = true;
        postToDeleteSlug = target.Slug;
        postToDeleteTitle = target.Title;
        deletingSlug = slug;
        message = string.Empty;
    }

    private void CancelDelete()
    {
        showDeleteConfirm = false;
        postToDeleteSlug = string.Empty;
        postToDeleteTitle = string.Empty;
        deletingSlug = string.Empty;
        message = string.Empty;
    }

    private string GetLoginHref()
    {
        var pathWithQuery = GetCurrentPathWithQuery();
        return $"/login?returnUrl={Uri.EscapeDataString(pathWithQuery)}";
    }

    private string GetCurrentPathWithQuery()
    {
        var uri = new Uri(Navigation.Uri);
        return string.IsNullOrWhiteSpace(uri.Query) ? uri.AbsolutePath : uri.PathAndQuery;
    }

    private static string GetPostUrl(BlogPost post)
        => post.IsDraft
            ? $"/edit/{Uri.EscapeDataString(post.Slug)}"
            : $"/@{Uri.EscapeDataString(post.Author)}/{Uri.EscapeDataString(post.Slug)}";

    private static string GetPostCardAriaLabel(BlogPost post)
        => post.IsDraft ? $"{post.Title} 게시전 수정" : $"{post.Title} 상세 보기";

    private static bool IsPriorityCardImage(int index) => index < 2;

    private static string FormatDate(DateTime dateTime) => dateTime.ToLocalTime().ToString("yyyy.MM.dd");

    private static string FormatUserName(string userName)
        => string.IsNullOrWhiteSpace(userName) ? "@unknown" : $"@{userName.Trim().TrimStart('@')}";

    private static string Shorten(string text, int maxLength)
    {
        if (string.IsNullOrWhiteSpace(text))
        {
            return string.Empty;
        }

        return text.Length <= maxLength ? text : text[..maxLength] + "...";
    }

    private bool TryRestorePrerenderedState(string stateKey)
    {
        if (PrerenderedState?.StateKey != stateKey)
        {
            return false;
        }

        myPosts = PrerenderedState.Items;
        allPosts = PrerenderedState.AllItems;
        totalCount = PrerenderedState.TotalCount;
        totalPages = PrerenderedState.TotalPages;
        message = PrerenderedState.Message ?? string.Empty;
        isLoadingMorePosts = false;
        return true;
    }

    private void CapturePrerenderedState(string stateKey)
    {
        PrerenderedState = new ListPageState<BlogPost>
        {
            StateKey = stateKey,
            Items = myPosts.ToList(),
            AllItems = allPosts.ToList(),
            TotalCount = totalCount,
            TotalPages = totalPages,
            Message = message
        };
    }
}
