@inject SlogsApiClient ApiClient

@if (!imageFailed && image is not null)
{
    <a class="post-card-media mb-3 block overflow-hidden rounded-xl border border-slate-200 bg-slate-100"
       href="@PostUrl"
       aria-label="@($"{Post.Title} 대표 이미지로 상세 보기")">
        <img src="@image.Url"
             alt="@GetAltText()"
             loading="@LoadingMode"
             decoding="@DecodingMode"
             fetchpriority="@FetchPriority"
             @onerror="HandleImageError" />
    </a>
}

@code {
    [Parameter, EditorRequired] public BlogPost Post { get; set; } = default!;

    [Parameter, EditorRequired] public string PostUrl { get; set; } = string.Empty;

    [Parameter] public bool Priority { get; set; }

    private MarkdownImage? image;
    private bool imageFailed;
    private bool triedHydratingPost;
    private string? hydratedSlug;
    private string LoadingMode => Priority ? "eager" : "lazy";
    private string DecodingMode => Priority ? "sync" : "async";
    private string FetchPriority => Priority ? "high" : "auto";

    protected override async Task OnParametersSetAsync()
    {
        if (!string.Equals(hydratedSlug, Post.Slug, StringComparison.Ordinal))
        {
            hydratedSlug = Post.Slug;
            triedHydratingPost = false;
        }

        SetImage(GetRepresentativeImage());

        if (image is not null || triedHydratingPost || string.IsNullOrWhiteSpace(Post.Slug))
        {
            return;
        }

        triedHydratingPost = true;
        var fullPost = await ApiClient.GetBySlugAsync(Post.Slug);
        if (fullPost is null)
        {
            return;
        }

        Post.ThumbnailUrl = fullPost.ThumbnailUrl;
        Post.Body = fullPost.Body;
        SetImage(GetRepresentativeImage());
    }

    private void SetImage(MarkdownImage? nextImage)
    {
        if (!string.Equals(image?.Url, nextImage?.Url, StringComparison.Ordinal))
        {
            imageFailed = false;
        }

        image = nextImage;
    }

    private MarkdownImage? GetRepresentativeImage()
        => GetThumbnailImage() ?? MarkdownRenderer.FindFirstImage(Post.Body);

    private MarkdownImage? GetThumbnailImage()
    {
        var thumbnailUrl = MarkdownRenderer.NormalizeImageUrl(Post.ThumbnailUrl);
        return string.IsNullOrWhiteSpace(thumbnailUrl)
            ? null
            : new MarkdownImage(thumbnailUrl, Post.Title);
    }

    private string GetAltText()
    {
        if (!string.IsNullOrWhiteSpace(image?.AltText))
        {
            return image.AltText;
        }

        return string.IsNullOrWhiteSpace(Post.Title) ? "포스트 이미지" : Post.Title;
    }

    private void HandleImageError()
    {
        imageFailed = true;
    }
}
