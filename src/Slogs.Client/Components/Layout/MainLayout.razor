@using System
@implements IDisposable
@inject NavigationManager Navigation
@inject SlogsAuthState AuthState
@inject IJSRuntime JS
@inherits LayoutComponentBase

<div class="min-h-screen bg-slate-100">
    <header class="slogs-app-header sticky top-0 z-20 border-b border-slate-200 bg-white bg-opacity-90 backdrop-blur-md" data-slogs-mobile-header>
        <div class="slogs-reconnect-slot">
            <ReconnectModal />
        </div>

        <div class="slogs-app-header__inner mx-auto flex w-full max-w-6xl flex-wrap items-center gap-3 px-4 py-3 md:flex-nowrap">
            <a class="slogs-brand" href="/" aria-label="slogs 홈">
                <img class="slogs-brand__icon" src="@Assets["favicon.svg"]" alt="" width="32" height="32" />
                <span class="slogs-brand__wordmark">slogs</span>
            </a>

            <div class="slogs-header-search order-3 flex w-full min-w-0 items-center gap-2 rounded-full border border-slate-200 bg-white px-3 py-2 xl:order-none xl:w-auto xl:flex-1">
                <input class="min-w-0 flex-1 border-0 bg-transparent text-sm text-slate-700 outline-none"
                       @bind="searchTerm" @bind:event="oninput" placeholder="검색어, #태그, @@작성자, series:시리즈"
                       aria-label="전역 검색어 입력"
                       @onkeydown="HandleSearchKeyDown" />
                <button class="rounded-full bg-slate-900 px-3 py-1 text-sm font-semibold text-white transition hover:bg-slate-800"
                        type="button" @onclick="GoSearch">
                    검색
                </button>
            </div>

            <nav class="slogs-header-actions ml-auto flex items-center gap-2" aria-label="header actions">
                @if (CurrentUser is null)
                {
                    <a class="rounded-full bg-slate-900 px-3 py-1.5 text-sm font-semibold text-white transition hover:bg-slate-800"
                       href="@GetLoginHref()">로그인</a>
                }
                else
                {
                    <a class="rounded-full border border-slate-300 px-3 py-1.5 text-sm font-semibold text-slate-800 transition hover:bg-slate-100"
                       href="/me">내 글</a>
                    <a class="rounded-full border border-slate-300 px-3 py-1.5 text-sm font-semibold text-slate-800 transition hover:bg-slate-100"
                       href="/write">글쓰기</a>
                    <details class="slogs-account-menu relative">
                        <summary class="list-none rounded-full border border-slate-200 bg-slate-100 px-3 py-1.5 text-sm font-semibold text-slate-700 transition hover:bg-slate-200">
                            @CurrentUser.DisplayName
                        </summary>
                        <div class="absolute right-0 z-40 mt-2 w-56 overflow-hidden rounded-xl border border-slate-200 bg-white py-1 text-sm shadow-lg"
                             role="menu">
                            @if (CurrentUser.IsAdminMode)
                            {
                                <div class="border-b border-slate-100 px-4 py-2 text-xs leading-5 text-slate-500">
                                    <span class="block font-bold text-slate-800">관리자 모드</span>
                                    <span class="block">@($"원래 사용자 @{CurrentUser.AdminModeSourceUserName}")</span>
                                </div>
                            }
                            <a class="block px-4 py-2 font-semibold text-slate-800 transition hover:bg-slate-100"
                               href="@GetCurrentUserPath()"
                               role="menuitem"
                               @onclick="CloseAccountMenuAsync">@GetCurrentUserMenuText()</a>
                            @if (CurrentUser.CanSwitchToAdminMode)
                            {
                                <button class="block w-full px-4 py-2 text-left text-slate-700 transition hover:bg-slate-100"
                                        type="button"
                                        role="menuitem"
                                        @onclick="EnterAdminMode">어드민 전환</button>
                            }
                            @if (CurrentUser.CanExitAdminMode)
                            {
                                <button class="block w-full px-4 py-2 text-left text-slate-700 transition hover:bg-slate-100"
                                        type="button"
                                        role="menuitem"
                                        @onclick="ExitAdminMode">일반 모드로 전환</button>
                            }
                            <a class="block px-4 py-2 text-slate-700 transition hover:bg-slate-100"
                               href="/me/settings"
                               role="menuitem"
                               @onclick="CloseAccountMenuAsync">설정</a>
                            <button class="block w-full px-4 py-2 text-left text-slate-700 transition hover:bg-slate-100"
                                    type="button"
                                    role="menuitem"
                                    @onclick="Logout">로그아웃</button>
                        </div>
                    </details>
                }
                <button class="slogs-mobile-menu-toggle rounded-full border border-slate-300 bg-white p-2 text-slate-800 transition hover:bg-slate-100"
                        type="button"
                        title="메뉴"
                        aria-label="메뉴 열기"
                        aria-controls="slogs-mobile-menu"
                        aria-expanded="@isMobileMenuOpen"
                        @onclick="ToggleMobileMenu">
                    <SlogsIcon Name="menu" Class="h-5 w-5" />
                </button>
            </nav>
        </div>
    </header>

    <button class="@GetMobileMenuBackdropClass()"
            type="button"
            aria-label="메뉴 닫기"
            tabindex="-1"
            @onclick="CloseMobileMenu"></button>
    <aside id="slogs-mobile-menu"
           class="@GetMobileMenuClass()"
           role="dialog"
           aria-modal="true"
           aria-label="모바일 메뉴"
           aria-hidden="@(!isMobileMenuOpen)">
        <div class="slogs-mobile-menu-panel">
            <div class="mb-4 flex items-center justify-between gap-3">
                <span class="text-base font-bold text-slate-900">메뉴</span>
                <button class="rounded-full border border-slate-300 bg-white p-2 text-slate-800 transition hover:bg-slate-100"
                        type="button"
                        title="닫기"
                        aria-label="메뉴 닫기"
                        @onclick="CloseMobileMenu">
                    <SlogsIcon Name="x" Class="h-5 w-5" />
                </button>
            </div>
            <NavMenu OnNavigate="CloseMobileMenu" />
        </div>
    </aside>

    <div class="slogs-page-shell mx-auto grid w-full max-w-6xl grid-cols-1 gap-4 px-4 py-4 lg:grid-cols-12">
        <aside class="slogs-desktop-sidebar lg:sticky lg:top-24 lg:self-start lg:col-span-4 xl:col-span-3">
            <NavMenu />
        </aside>

        <main class="min-w-0 lg:col-span-8 xl:col-span-9">
            @Body
        </main>
    </div>
</div>

<div id="blazor-error-ui" data-nosnippet>
    오류가 발생했습니다.
    <a href="." class="reload">다시 시도</a>
    <span class="dismiss">×</span>
</div>

@code {
    private string searchTerm = string.Empty;
    private bool isMobileMenuOpen;

    private AuthUser? CurrentUser => AuthState.CurrentUser;

    protected override async Task OnInitializedAsync()
    {
        AuthState.AuthStateChanged += OnAuthStateChanged;
        Navigation.LocationChanged += OnLocationChanged;
        searchTerm = GetSearchTermFromCurrentUrl();
        await AuthState.EnsureInitializedAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        try
        {
            await JS.InvokeVoidAsync("slogsInteractivity.markReady");
        }
        catch (JSDisconnectedException)
        {
            // The circuit can be gone during refresh/navigation.
        }
        catch (InvalidOperationException)
        {
            // Static rendering can run before browser JS interop is available.
        }
    }

    public void Dispose()
    {
        AuthState.AuthStateChanged -= OnAuthStateChanged;
        Navigation.LocationChanged -= OnLocationChanged;
    }

    private void OnAuthStateChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        searchTerm = GetSearchTermFromCurrentUrl();
        CloseMobileMenu();
        InvokeAsync(StateHasChanged);
    }

    private void ToggleMobileMenu()
    {
        isMobileMenuOpen = !isMobileMenuOpen;
    }

    private void CloseMobileMenu()
    {
        isMobileMenuOpen = false;
    }

    private string GetMobileMenuBackdropClass()
        => isMobileMenuOpen
            ? "slogs-mobile-menu-backdrop is-open"
            : "slogs-mobile-menu-backdrop";

    private string GetMobileMenuClass()
        => isMobileMenuOpen
            ? "slogs-mobile-menu-drawer is-open"
            : "slogs-mobile-menu-drawer";

    private async Task Logout()
    {
        await CloseAccountMenuAsync();
        await JS.InvokeAsync<AuthApiResult>("slogsAuthApi.logout");
        await AuthState.LogoutAsync();
        Navigation.NavigateTo("/", forceLoad: true);
    }

    private async Task EnterAdminMode()
    {
        await CloseAccountMenuAsync();
        var result = await JS.InvokeAsync<AuthApiResult>("slogsAuthApi.enterAdminMode");
        if (result.Ok)
        {
            await AuthState.RefreshAsync();
            Navigation.NavigateTo(GetCurrentPathWithQuery(), forceLoad: true);
        }
    }

    private async Task ExitAdminMode()
    {
        await CloseAccountMenuAsync();
        var result = await JS.InvokeAsync<AuthApiResult>("slogsAuthApi.exitAdminMode");
        if (result.Ok)
        {
            await AuthState.RefreshAsync();
            Navigation.NavigateTo(GetCurrentPathWithQuery(), forceLoad: true);
        }
    }

    private async Task CloseAccountMenuAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("slogsAccountMenu.closeAll");
        }
        catch (JSDisconnectedException)
        {
            // The circuit can be gone during navigation.
        }
        catch (InvalidOperationException)
        {
            // Static rendering can run before browser JS interop is available.
        }
    }

    private string GetCurrentUserPath()
    {
        return CurrentUser is null
            ? "/"
            : $"/@{Uri.EscapeDataString(CurrentUser.UserName)}";
    }

    private string GetCurrentUserMenuText()
    {
        return CurrentUser is null
            ? "@"
            : $"@{CurrentUser.UserName} 홈";
    }

    private string GetLoginHref()
    {
        var safeReturn = GetCurrentPathWithQuery();
        return $"/login?returnUrl={Uri.EscapeDataString(safeReturn)}";
    }

    private string GetCurrentPathWithQuery()
    {
        var uri = new Uri(Navigation.Uri);
        if (uri.AbsolutePath.Equals("/login", StringComparison.OrdinalIgnoreCase)
            || uri.AbsolutePath.Equals("/register", StringComparison.OrdinalIgnoreCase))
        {
            var explicitReturnUrl = GetExplicitReturnUrlFromQuery(uri.Query);
            var baseHost = new Uri(Navigation.BaseUri).Host;
            if (!string.IsNullOrWhiteSpace(explicitReturnUrl)
                && TryNormalizeRelativeReturnUrl(explicitReturnUrl, baseHost, out var safeReturnUrl))
            {
                return safeReturnUrl;
            }

            return "/";
        }

        return string.IsNullOrWhiteSpace(uri.Query) ? uri.AbsolutePath : uri.PathAndQuery;
    }

    private string GetSearchTermFromCurrentUrl()
    {
        var uri = new Uri(Navigation.Uri);
        return GetQueryParameter(uri.Query, "q") ?? string.Empty;
    }

    private static string? GetQueryParameter(string? query, string name)
    {
        if (string.IsNullOrWhiteSpace(query) || query.Length <= 1)
        {
            return null;
        }

        var raw = query[1..];
        foreach (var segment in raw.Split('&', StringSplitOptions.RemoveEmptyEntries))
        {
            var split = segment.Split('=', 2);
            if (!split[0].Equals(name, StringComparison.OrdinalIgnoreCase))
            {
                continue;
            }

            if (split.Length < 2)
            {
                return string.Empty;
            }

            return Uri.UnescapeDataString(split[1].Replace("+", " "));
        }

        return null;
    }

    private static string? GetExplicitReturnUrlFromQuery(string? query)
    {
        if (string.IsNullOrWhiteSpace(query) || query.Length <= 1)
        {
            return null;
        }

        var raw = query[1..];
        foreach (var segment in raw.Split('&', StringSplitOptions.RemoveEmptyEntries))
        {
            var split = segment.Split('=', 2);
            if (!split[0].Equals("returnUrl", StringComparison.OrdinalIgnoreCase) || split.Length < 2)
            {
                continue;
            }

            var decoded = Uri.UnescapeDataString(split[1]);
            return string.IsNullOrWhiteSpace(decoded) ? null : decoded;
        }

        return null;
    }

    private static bool TryNormalizeRelativeReturnUrl(string? returnUrl, string? baseHost, out string safeReturnUrl)
    {
        safeReturnUrl = string.Empty;

        if (string.IsNullOrWhiteSpace(returnUrl))
        {
            return false;
        }

        if (!Uri.TryCreate(returnUrl, UriKind.RelativeOrAbsolute, out var parsedReturn))
        {
            return false;
        }

        if (!parsedReturn.IsAbsoluteUri && parsedReturn.OriginalString.StartsWith("/"))
        {
            safeReturnUrl = parsedReturn.OriginalString;
            return true;
        }

        if (parsedReturn.IsAbsoluteUri && !string.IsNullOrWhiteSpace(baseHost)
            && parsedReturn.Host.Equals(baseHost, StringComparison.OrdinalIgnoreCase))
        {
            safeReturnUrl = parsedReturn.PathAndQuery;
            return true;
        }

        return false;
    }

    private void GoSearch()
    {
        if (string.IsNullOrWhiteSpace(searchTerm))
        {
            Navigation.NavigateTo("/");
            return;
        }

        Navigation.NavigateTo(ParseSearchDestination(searchTerm.Trim()));
    }

    private void HandleSearchKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            GoSearch();
        }
    }

    private static string ParseSearchDestination(string term)
    {
        var trimmed = term.Trim();
        if (string.IsNullOrWhiteSpace(trimmed))
        {
            return "/";
        }

        if (trimmed.StartsWith("#", StringComparison.Ordinal))
        {
            var tag = trimmed[1..].Trim();
            if (!string.IsNullOrWhiteSpace(tag))
            {
                return $"/tag/{Uri.EscapeDataString(tag)}";
            }

            return "/tag";
        }

        if (trimmed.StartsWith("@@", StringComparison.Ordinal))
        {
            var writer = trimmed[2..].Trim();
            if (!string.IsNullOrWhiteSpace(writer))
            {
                return $"/@{Uri.EscapeDataString(writer)}";
            }

            return "/writer";
        }

        if (trimmed.StartsWith("@", StringComparison.Ordinal))
        {
            var writer = trimmed[1..].Trim();
            if (!string.IsNullOrWhiteSpace(writer))
            {
                return $"/@{Uri.EscapeDataString(writer)}";
            }

            return "/writer";
        }

        if (trimmed.StartsWith("tag:", StringComparison.OrdinalIgnoreCase))
        {
            var tag = trimmed[4..].Trim();
            if (!string.IsNullOrWhiteSpace(tag))
            {
                return $"/tag/{Uri.EscapeDataString(tag)}";
            }

            return "/tag";
        }

        if (trimmed.StartsWith("writer:", StringComparison.OrdinalIgnoreCase))
        {
            var writer = trimmed[7..].Trim();
            if (!string.IsNullOrWhiteSpace(writer))
            {
                return $"/@{Uri.EscapeDataString(writer)}";
            }

            return "/writer";
        }

        if (trimmed.StartsWith("series:", StringComparison.OrdinalIgnoreCase))
        {
            var series = trimmed[7..].Trim();
            if (!string.IsNullOrWhiteSpace(series))
            {
                return $"/series/{Uri.EscapeDataString(series)}";
            }

            return "/series";
        }

        return $"/?q={Uri.EscapeDataString(trimmed)}";
    }

    private sealed class AuthApiResult
    {
        public bool Ok { get; set; }
        public int Status { get; set; }
        public string? Error { get; set; }
        public string? ReturnUrl { get; set; }
        public AuthUser? User { get; set; }
    }
}
