@page "/me"
@using Microsoft.AspNetCore.Http
@inject AuthService AuthService
@inject BlogService BlogService
@inject NavigationManager Navigation
@inject IHttpContextAccessor HttpContextAccessor

<PageTitle>내 글</PageTitle>
<SeoHead Title="내 글 | slogs" Description="내가 작성한 slogs 글을 관리합니다." NoIndex="true" />

@if (CurrentUser is null)
{
    <p class="rounded-2xl border border-slate-200 bg-white p-4 text-slate-500">로그인이 필요합니다. <a class="font-semibold underline" href="@GetLoginHref()">로그인</a>해 주세요.</p>
}
else
{
    <section class="space-y-4">
        <div class="flex flex-wrap items-end justify-between gap-3 border-b border-slate-200 pb-4">
            <div>
                <h1 class="text-2xl font-bold text-slate-900">내가 쓴 글</h1>
                <p class="mt-1 text-sm text-slate-500">@CurrentUser.DisplayName 님이 작성한 글을 관리합니다.</p>
            </div>
            <div class="flex flex-wrap items-center gap-2">
                @if (totalCount > 0)
                {
                    <span class="rounded-full border border-slate-200 bg-slate-100 px-3 py-1 text-sm font-semibold text-slate-600">@($"{totalCount}개 글")</span>
                }
                @if (myPosts.Any())
                {
                    <a class="rounded-full bg-slate-900 px-4 py-2 text-sm font-semibold text-white transition hover:bg-slate-800" href="/write">새 글 쓰기</a>
                }
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(message))
        {
            <p class="mt-2 rounded-lg border border-rose-200 bg-rose-50 px-3 py-2 text-sm text-rose-800">@message</p>
        }

        <section class="mt-4 grid grid-cols-1 gap-3 md:grid-cols-2">
            @if (!myPosts.Any())
            {
                <div class="grid min-h-64 place-items-center rounded-xl border border-dashed border-slate-300 bg-slate-50 px-6 py-10 text-center md:col-span-2">
                    <div class="max-w-sm">
                        <p class="text-sm font-semibold text-slate-500">아직 발행한 글이 없습니다.</p>
                        <h2 class="mt-2 text-xl font-bold text-slate-900">첫 글을 작성해 보세요.</h2>
                        <a class="mt-5 inline-flex rounded-full bg-slate-900 px-4 py-2 text-sm font-semibold text-white transition hover:bg-slate-800"
                           href="/write">새 글 쓰기</a>
                    </div>
                </div>
            }
            else
            {
                foreach (var post in myPosts)
                {
                    <article class="clickable-post-card rounded-2xl border border-slate-200 bg-white p-4"
                             data-card-click-href="@GetPostUrl(post)"
                             tabindex="0"
                             role="link"
                             aria-label="@($"{post.Title} 상세 보기")">
                        <PostCardImage Post="post" PostUrl="@GetPostUrl(post)" />
                        <a class="mb-2 block text-xl font-bold text-slate-900 hover:underline" href="@GetPostUrl(post)">@post.Title</a>
                        <div class="flex flex-wrap items-center gap-1 text-sm text-slate-500">
                            <a class="hover:underline" href="@($"/@{Uri.EscapeDataString(post.Author)}")">@post.Author</a>
                            <span>·</span>
                            <span>@FormatDate(post.PublishedAt)</span>
                            <span>·</span>
                            <span>@post.ReadTimeMinutes 분</span>
                            <span>·</span>
                            <span>@post.LikeCount 개 좋아요</span>
                            <span>·</span>
                            <span>@post.CommentCount 개 댓글</span>
                            <span>·</span>
                            <span>@post.ViewCount 회 조회</span>
                            @if (post.Series.Count > 0)
                            {
                                <span>·</span>
                                @foreach (var series in post.Series)
                                {
                                    <a class="hover:underline" href="@($"/series/{Uri.EscapeDataString(series)}")">시리즈: @series</a>
                                }
                            }
                        </div>
                        @if (!string.IsNullOrWhiteSpace(post.Summary))
                        {
                            <p class="mt-2 text-sm text-slate-700">@Shorten(post.Summary, 140)</p>
                        }

                        <div class="mt-2 flex flex-wrap gap-2">
                            @foreach (var tag in post.Tags)
                            {
                                <a class="rounded-full border border-sky-200 bg-sky-50 px-2.5 py-1 text-xs font-semibold text-sky-900 hover:bg-sky-100"
                                   href="@($"/tag/{Uri.EscapeDataString(tag)}")">#@tag</a>
                            }
                        </div>

                        <div class="mt-3 flex flex-wrap gap-2">
                            <a class="rounded-full border border-slate-300 px-3 py-1.5 text-xs font-semibold text-slate-700 transition hover:bg-slate-100"
                               href="@($"/edit/{Uri.EscapeDataString(post.Slug)}")">수정</a>
                            <button class="rounded-full border border-rose-300 px-3 py-1.5 text-xs font-semibold text-rose-700 transition hover:bg-rose-50 disabled:cursor-not-allowed disabled:opacity-60"
                                    disabled="@(isDeleting && deletingSlug == post.Slug)"
                                    type="button" @onclick="() => RequestDelete(post.Slug)">
                                @((isDeleting && deletingSlug == post.Slug) ? "삭제 중..." : "삭제")
                            </button>
                        </div>
                    </article>
                }
            }
        </section>

        @if (totalPages > 1)
        {
            <div class="mt-4 flex flex-wrap items-center justify-center gap-2">
                <a class="rounded-full border border-slate-300 px-3 py-1.5 text-sm font-semibold text-slate-700 hover:bg-slate-100 @(currentPage == 1 ? "pointer-events-none opacity-50" : string.Empty)"
                   href="@GetPageHref(currentPage - 1)">이전</a>

                @foreach (var pageNumber in GetPageNumbers())
                {
                    <a class="@(pageNumber == currentPage
                        ? "rounded-full bg-slate-900 px-3 py-1.5 text-sm font-semibold text-white"
                        : "rounded-full border border-slate-300 bg-white px-3 py-1.5 text-sm font-semibold text-slate-700 hover:bg-slate-100")"
                       href="@GetPageHref(pageNumber)">
                        @pageNumber
                    </a>
                }

                <a class="rounded-full border border-slate-300 px-3 py-1.5 text-sm font-semibold text-slate-700 hover:bg-slate-100 @(currentPage == totalPages ? "pointer-events-none opacity-50" : string.Empty)"
                   href="@GetPageHref(currentPage + 1)">다음</a>
            </div>
        }
    </section>

    @if (totalPages > 1)
    {
        <p class="mt-2 text-xs text-slate-500">페이지 @currentPage/@totalPages</p>
    }
}

@if (showDeleteConfirm)
{
    <div class="mt-4 rounded-xl border border-rose-200 bg-rose-50 p-4">
        <p class="text-sm font-semibold text-rose-900">이 글을 삭제하시겠습니까?</p>
        <p class="mb-2 text-sm text-rose-800">@($"\"{postToDeleteTitle}\"")</p>
        <div class="flex flex-wrap gap-2">
            <button class="rounded-full border border-rose-300 bg-rose-600 px-3 py-1.5 text-sm font-semibold text-white transition hover:bg-rose-700"
                    disabled="@isDeleting"
                    type="button" @onclick="ConfirmDelete">삭제 진행</button>
            <button class="rounded-full border border-slate-300 px-3 py-1.5 text-sm font-semibold transition hover:bg-slate-100"
                    type="button" @onclick="CancelDelete">취소</button>
        </div>
    </div>
}

@code {
    private AuthUser? CurrentUser => AuthService.CurrentUser;
    [SupplyParameterFromQuery(Name = "page")] public string? PageQuery { get; set; }
    private IReadOnlyList<BlogPost> myPosts = Array.Empty<BlogPost>();
    private int currentPage;
    private int totalCount;
    private int totalPages;
    private bool showDeleteConfirm;
    private bool isDeleting;
    private string deletingSlug = string.Empty;
    private string postToDeleteSlug = string.Empty;
    private string postToDeleteTitle = string.Empty;
    private string message = string.Empty;

    protected override void OnInitialized()
    {
        if (CurrentUser is null)
        {
            var response = HttpContextAccessor.HttpContext?.Response;
            if (response is not null)
            {
                response.StatusCode = StatusCodes.Status401Unauthorized;
                response.Headers["Cache-Control"] = "no-store";
            }

            Navigation.NavigateTo(GetLoginHref());
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        if (CurrentUser is null)
        {
            showDeleteConfirm = false;
            postToDeleteSlug = string.Empty;
            postToDeleteTitle = string.Empty;
            isDeleting = false;
            deletingSlug = string.Empty;
            return;
        }

        await LoadPostsAsync();
    }

    private async Task LoadPostsAsync()
    {
        if (CurrentUser is null)
        {
            return;
        }

        currentPage = ListQueryUrlBuilder.ParsePage(PageQuery);
        var allPosts = await BlogService.GetByAuthorAsync(CurrentUser.UserName);
        totalCount = allPosts.Count;
        totalPages = totalCount == 0 ? 0 : (int)Math.Ceiling(totalCount / 6d);
        currentPage = Math.Min(currentPage, Math.Max(1, totalPages));
        myPosts = allPosts.Skip((currentPage - 1) * 6).Take(6).ToList();
    }

    private string GetPageHref(int targetPage)
    {
        var page = Math.Max(1, targetPage);
        return ListQueryUrlBuilder.Build("/me", sort: null, query: null, page: page, totalPages: totalPages);
    }

    private IEnumerable<int> GetPageNumbers()
    {
        if (totalPages <= 1)
        {
            yield break;
        }

        const int maxButtons = 7;
        var half = maxButtons / 2;
        var start = Math.Max(1, currentPage - half);
        var end = Math.Min(totalPages, start + maxButtons - 1);
        if (end - start + 1 < maxButtons)
        {
            start = Math.Max(1, end - maxButtons + 1);
        }

        for (var pageNumber = start; pageNumber <= end; pageNumber++)
        {
            yield return pageNumber;
        }
    }

    private async Task ConfirmDelete()
    {
        if (isDeleting)
        {
            return;
        }

        if (string.IsNullOrWhiteSpace(postToDeleteSlug) || CurrentUser is null)
        {
            showDeleteConfirm = false;
            message = "삭제할 글을 찾을 수 없습니다.";
            isDeleting = false;
            return;
        }

        isDeleting = true;
        StateHasChanged();

        try
        {
            var deleted = await BlogService.DeletePostAsync(postToDeleteSlug, CurrentUser.UserName);
            if (!deleted)
            {
                message = "삭제에 실패했습니다.";
                return;
            }

            showDeleteConfirm = false;
            postToDeleteSlug = string.Empty;
            postToDeleteTitle = string.Empty;
            deletingSlug = string.Empty;
            await LoadPostsAsync();
            message = "게시글이 삭제되었습니다.";
        }
        finally
        {
            isDeleting = false;
        }
    }

    private void RequestDelete(string slug)
    {
        if (CurrentUser is null)
        {
            return;
        }

        var target = myPosts.FirstOrDefault(x => x.Slug.Equals(slug, StringComparison.OrdinalIgnoreCase));
        if (target is null)
        {
            return;
        }

        showDeleteConfirm = true;
        postToDeleteSlug = target.Slug;
        postToDeleteTitle = target.Title;
        deletingSlug = slug;
        message = string.Empty;
    }

    private void CancelDelete()
    {
        showDeleteConfirm = false;
        postToDeleteSlug = string.Empty;
        postToDeleteTitle = string.Empty;
        deletingSlug = string.Empty;
        message = string.Empty;
    }

    private string GetLoginHref()
    {
        var pathWithQuery = GetCurrentPathWithQuery();
        return $"/login?returnUrl={Uri.EscapeDataString(pathWithQuery)}";
    }

    private string GetCurrentPathWithQuery()
    {
        var uri = new Uri(Navigation.Uri);
        return string.IsNullOrWhiteSpace(uri.Query) ? uri.AbsolutePath : uri.PathAndQuery;
    }

    private static string GetPostUrl(BlogPost post)
        => $"/@{Uri.EscapeDataString(post.Author)}/{Uri.EscapeDataString(post.Slug)}";

    private static string FormatDate(DateTime dateTime) => dateTime.ToLocalTime().ToString("yyyy.MM.dd");

    private static string Shorten(string text, int maxLength)
    {
        if (string.IsNullOrWhiteSpace(text))
        {
            return string.Empty;
        }

        return text.Length <= maxLength ? text : text[..maxLength] + "...";
    }

}


