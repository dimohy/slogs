@page "/write"
@using Microsoft.AspNetCore.Http
@inject BlogService BlogService
@inject AuthService AuthService
@inject NavigationManager Navigation
@inject IHttpContextAccessor HttpContextAccessor

<PageTitle>글쓰기</PageTitle>
<SeoHead Title="글쓰기 | slogs" Description="slogs에 새 글을 작성합니다." NoIndex="true" />

@if (CurrentUser is null)
{
    <p class="rounded-2xl border border-slate-200 bg-white p-4 text-slate-500">로그인이 필요합니다. <a class="font-semibold underline" href="@GetLoginHref()">로그인</a>해 주세요.</p>
}
else
{
    <h1 class="text-2xl font-bold text-slate-900">새 글 쓰기</h1>

    <div class="mt-4 grid gap-3">
        <label class="text-sm font-semibold text-slate-700">제목</label>
        <input class="rounded-2xl border border-slate-300 px-3 py-2 text-sm" @bind="title" />

        <label class="text-sm font-semibold text-slate-700">요약</label>
        <input class="rounded-2xl border border-slate-300 px-3 py-2 text-sm" @bind="summary" />

        <label class="text-sm font-semibold text-slate-700">태그 (쉼표 구분)</label>
        <input class="rounded-2xl border border-slate-300 px-3 py-2 text-sm" @bind="tags" placeholder="blazor, csharp, dotnet" />

        <label class="text-sm font-semibold text-slate-700">시리즈</label>
        <input class="rounded-2xl border border-slate-300 px-3 py-2 text-sm" @bind="series" placeholder="시리즈명 입력(선택)" />

        <label class="text-sm font-semibold text-slate-700">본문</label>
        <MarkdownEditor @bind-Value="body" Placeholder="Markdown으로 본문을 작성하세요." />

        <button class="w-fit rounded-full bg-slate-900 px-4 py-2 text-sm font-semibold text-white hover:bg-slate-800 disabled:cursor-not-allowed disabled:opacity-60"
                @onclick="Publish" disabled="@isSaving">@((isSaving) ? "발행 중..." : "발행")</button>
        <button class="rounded-full border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-100"
                type="button" @onclick="Cancel">취소</button>

        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <p class="text-sm text-red-700">@errorMessage</p>
        }
    </div>

    <section class="mt-6 rounded-2xl border border-slate-200 bg-white p-4">
        <h3 class="mb-2 text-lg font-bold text-slate-900">미리보기</h3>
        <p class="mb-2 font-semibold text-slate-900">@title</p>
        <p class="mb-2 text-slate-700">@summary</p>
        <div class="mb-2 flex flex-wrap gap-2 text-sm text-slate-600">
            @foreach (var tag in ParsedTags)
            {
                <span class="rounded-full border border-slate-200 bg-slate-50 px-2.5 py-1">#@tag</span>
            }
        </div>
        @if (!string.IsNullOrWhiteSpace(series))
        {
            <p class="mb-2 text-sm text-slate-500">시리즈: @series</p>
        }
        <div class="markdown-body max-w-none">
            @((MarkupString)MarkdownRenderer.Render(body))
        </div>
    </section>
}

@code {
    private string title = string.Empty;
    private string summary = string.Empty;
    private string tags = "blazor, csharp";
    private string series = string.Empty;
    private string body = "# 제목을 써주세요\n\n본문 내용을 Markdown 형식으로 작성할 수 있습니다.";
    private bool isSaving;
    private string errorMessage = string.Empty;
    private IReadOnlyList<string> ParsedTags => BlogService.ParseTagsForDisplay(tags);
    [SupplyParameterFromQuery(Name = "returnUrl")] public string? ReturnUrl { get; set; }

    private AuthUser? CurrentUser => AuthService.CurrentUser;

    protected override void OnInitialized()
    {
        if (CurrentUser is null)
        {
            var response = HttpContextAccessor.HttpContext?.Response;
            if (response is not null)
            {
                response.StatusCode = StatusCodes.Status401Unauthorized;
                response.Headers["Cache-Control"] = "no-store";
            }

            Navigation.NavigateTo(GetLoginHref());
        }
    }

    private async Task Publish()
    {
        errorMessage = string.Empty;

        if (CurrentUser is null)
        {
            errorMessage = "로그인이 필요합니다.";
            return;
        }

        if (string.IsNullOrWhiteSpace(title) || string.IsNullOrWhiteSpace(body))
        {
            errorMessage = "제목과 본문은 필수입니다.";
            return;
        }

        if (isSaving)
        {
            return;
        }

        isSaving = true;
        try
        {
            var post = await BlogService.CreatePostAsync(title, CurrentUser.UserName, summary, body, tags, series);
            Navigation.NavigateTo(GetReturnDestination(GetPostUrl(post)));
        }
        finally
        {
            isSaving = false;
        }
    }

    private string GetLoginHref()
    {
        var requestedReturnUrl = !string.IsNullOrWhiteSpace(ReturnUrl)
            ? ReturnUrl
            : "/write";

        var returnUrl = TryNormalizeRelativeReturnUrl(requestedReturnUrl, out var safeReturnUrl)
            ? safeReturnUrl
            : "/write";

        return $"/login?returnUrl={Uri.EscapeDataString(returnUrl)}";
    }

    private void Cancel()
    {
        Navigation.NavigateTo(GetReturnDestination("/me"));
    }

    private string GetReturnDestination(string fallback)
    {
        return (TryNormalizeRelativeReturnUrl(ReturnUrl, out var safeUrl), safeUrl) switch
        {
            (true, _) => safeUrl,
            _ => fallback
        };
    }

    private bool TryNormalizeRelativeReturnUrl(string? returnUrl, out string safeUrl)
    {
        safeUrl = string.Empty;

        if (string.IsNullOrWhiteSpace(returnUrl))
        {
            return false;
        }

        if (!Uri.TryCreate(returnUrl, UriKind.RelativeOrAbsolute, out var parsedUrl))
        {
            return false;
        }

        if (!parsedUrl.IsAbsoluteUri && parsedUrl.OriginalString.StartsWith("/"))
        {
            safeUrl = parsedUrl.OriginalString;
            return true;
        }

        if (parsedUrl.IsAbsoluteUri)
        {
            var baseUri = new Uri(Navigation.BaseUri);
            if (parsedUrl.Host.Equals(baseUri.Host, StringComparison.OrdinalIgnoreCase))
            {
                safeUrl = parsedUrl.PathAndQuery;
                return true;
            }
        }

        return false;
    }

    private static string GetPostUrl(BlogPost post)
        => $"/@{Uri.EscapeDataString(post.Author)}/{Uri.EscapeDataString(post.Slug)}";
}


