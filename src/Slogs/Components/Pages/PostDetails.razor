    private string GetPostAuthorUrl() => $"/@{Uri.EscapeDataString(post?.Author ?? string.Empty)}";

    private static string GetWriterUrl(string author)
        => $"/@{Uri.EscapeDataString(author)}";

    private static string GetCommentAuthorUrl(BlogComment comment)
        => GetWriterUrl(string.IsNullOrWhiteSpace(comment.AuthorNormalized) ? comment.Author : comment.AuthorNormalized);

    private void ShowDeleteConfirm()
    {
        message = string.Empty;
        if (!CanEditCurrentPost)
        {
            message = "삭제 권한이 없습니다.";
            return;
        }

        showDeleteConfirm = true;
    }

    private void CancelDelete()
    {
        showDeleteConfirm = false;
        message = string.Empty;
    }

    private async Task DeletePost()
    {
        if (post is null || CurrentUser is null || !post.IsAuthor(CurrentUser.UserName))
        {
            message = "삭제 권한이 없습니다.";
            showDeleteConfirm = false;
            return;
        }

        var deleted = await BlogService.DeletePostAsync(post.Slug, CurrentUser.UserName);
        if (!deleted)
        {
            showDeleteConfirm = false;
            message = "삭제에 실패했습니다.";
            return;
        }

        Navigation.NavigateTo("/");
    }

    private string GetEditHref() => $"/edit/{Uri.EscapeDataString(post?.Slug ?? Slug)}";

    private void NavigateToLogin()
    {
        var currentPath = GetCurrentPathWithQuery();
        var encoded = Uri.EscapeDataString(currentPath);
        Navigation.NavigateTo($"/login?returnUrl={encoded}");
    }

    private string GetCurrentPathWithQuery()
    {
        var uri = new Uri(Navigation.Uri);
        var path = uri.AbsolutePath;
        var query = uri.Query;
        var fragment = uri.Fragment;
        if (!string.IsNullOrWhiteSpace(query))
        {
            path = $"{path}{query}";
        }

        return string.IsNullOrWhiteSpace(fragment) ? path : $"{path}{fragment}";
    }

    private string GetLoginReturnUrl()
    {
        var currentPath = GetCurrentPathWithQuery();
        var encoded = Uri.EscapeDataString(currentPath);
        return $"/login?returnUrl={encoded}";
    }

    private static string FormatDate(DateTime dateTime) => dateTime.ToLocalTime().ToString("yyyy.MM.dd");

    private static string FormatDateTime(DateTime dateTime) => dateTime.ToLocalTime().ToString("yyyy.MM.dd HH:mm");

    private bool CanDeleteComment(BlogComment comment) => CurrentUser is not null
        && (comment.IsAuthor(CurrentUser.UserName) || string.Equals(CurrentUser.UserName, "admin", StringComparison.OrdinalIgnoreCase));

    private bool CanEditComment(BlogComment comment) => CurrentUser is not null
        && (comment.IsAuthor(CurrentUser.UserName) || string.Equals(CurrentUser.UserName, "admin", StringComparison.OrdinalIgnoreCase));

    private void RequestDeleteComment(Guid commentId)
    {
        if (!CanStartCommentAction)
        {
            message = "댓글 작업이 진행 중입니다. 잠시 후 다시 시도해 주세요.";
            return;
        }

        if (post is null)
        {
            return;
        }

        var target = FindComment(commentId);
        if (target is null)
        {
            message = "삭제할 댓글을 찾을 수 없습니다.";
            return;
        }

        if (!CanDeleteComment(target))
        {
            message = "삭제 권한이 없습니다.";
            return;
        }

        pendingDeleteCommentId = commentId;
        message = string.Empty;
    }

    private void CancelDeleteComment()
    {
        pendingDeleteCommentId = null;
        message = string.Empty;
    }

    private async Task HandleCommentKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && (e.CtrlKey || e.MetaKey))
        {
            await SubmitComment();
        }
    }

    private async Task HandleReplyKeyDown(KeyboardEventArgs e, Guid parentCommentId)
    {
        if (e.Key == "Enter" && (e.CtrlKey || e.MetaKey))
        {
            await SubmitReply(parentCommentId);
        }
    }

    private async Task HandleEditKeyDown(KeyboardEventArgs e, Guid commentId)
    {
        if (e.Key == "Enter" && (e.CtrlKey || e.MetaKey))
        {
            await SubmitEditComment(commentId);
        }
    }

    private async Task ConfirmDeleteComment()
    {
        if (pendingDeleteCommentId is null)
        {
            return;
        }

        if (isCommentSaving)
        {
            message = "현재 댓글 작업이 진행 중입니다. 잠시 후 다시 시도해 주세요.";
            return;
        }

        await DeleteComment(pendingDeleteCommentId.Value);
    }

    private async Task DeleteComment(Guid commentId)
    {
        if (CurrentUser is null || post is null)
        {
            NavigateToLogin();
            return;
        }

        var target = FindComment(commentId);
        if (target is null)
        {
            message = "삭제할 댓글을 찾을 수 없습니다.";
            pendingDeleteCommentId = null;
            return;
        }

        if (!TryBeginCommentAction(CommentActionKind.DeleteComment, commentId))
        {
            return;
        }

        pendingDeleteCommentId = commentId;

        try
        {
        var deleted = await BlogService.RemoveCommentAsync(post.Slug, commentId, CurrentUser.UserName);
        if (!deleted)
        {
            message = "댓글 삭제에 실패했습니다.";
            pendingDeleteCommentId = null;
            return;
        }

        await RefreshPostAsync();
        pendingDeleteCommentId = null;
        message = "댓글이 삭제되었습니다.";
        }
        finally
        {
            EndCommentAction();
        }
    }

    private const int MaxCommentLength = 1000;
    private const int CommentPageSize = 10;

    private void LoadCommentPage()
    {
        if (post is null)
        {
            topLevelComments = Array.Empty<BlogComment>();
            commentCurrentPage = 1;
            commentTotalPages = 1;
            commentTotalCount = 0;
            return;
        }

        var allTopLevelComments = (commentSortOrder is "oldest"
            ? post.Comments
                .Where(x => x.ParentCommentId is null)
                .OrderBy(x => x.CreatedAt)
            : post.Comments
                .Where(x => x.ParentCommentId is null)
                .OrderByDescending(x => x.CreatedAt))
            .ToArray();

        commentTotalCount = allTopLevelComments.Length;
        commentTotalPages = Math.Max(1, (int)Math.Ceiling(allTopLevelComments.Length / (double)CommentPageSize));
        commentCurrentPage = Math.Clamp(GetCommentPageFromQuery(), 1, commentTotalPages);

        topLevelComments = allTopLevelComments
            .Skip((commentCurrentPage - 1) * CommentPageSize)
            .Take(CommentPageSize)
            .ToArray();
    }

    private int GetCommentPageFromQuery()
    {
        if (int.TryParse(CommentPageQuery, out var requestedPage) && requestedPage > 0)
        {
            return requestedPage;
        }

        return 1;
    }

    private string GetCommentPageHref(int targetPage)
    {
        return GetCommentListQuery(commentSortOrder, includePage: targetPage > 1, explicitPage: targetPage);
    }

    private string GetCommentListQuery(string sortOrder, bool includePage, int? explicitPage)
    {
        if (post is null)
        {
            return "#comments";
        }

        var query = new List<string>();
        if (!string.IsNullOrWhiteSpace(sortOrder) && !string.Equals(sortOrder, "latest", StringComparison.OrdinalIgnoreCase))
        {
            query.Add($"commentOrder={Uri.EscapeDataString(sortOrder)}");
        }

        if (includePage)
        {
            var page = explicitPage ?? commentCurrentPage;
            if (page > 1)
            {
                query.Add($"commentPage={page}");
            }
        }

        return query.Count == 0
            ? $"{GetPostUrl(post)}#comments"
            : $"{GetPostUrl(post)}?{string.Join("&", query)}#comments";
    }

    private string GetCommentSortHref(string sortOrder)
    {
        var normalizedSort = NormalizeCommentSortOrder(sortOrder);
        var query = new List<string>();
        if (!string.Equals(normalizedSort, "latest", StringComparison.OrdinalIgnoreCase))
        {
            query.Add($"commentOrder={Uri.EscapeDataString(normalizedSort)}");
        }

        return query.Count == 0
            ? $"{GetPostUrl(post!)}#comments"
            : $"{GetPostUrl(post!)}?{string.Join("&", query)}#comments";
    }

    private string GetCommentSortChipClass(string sortOrder)
    {
        var isActive = string.Equals(commentSortOrder, sortOrder, StringComparison.OrdinalIgnoreCase);
        return isActive
            ? "rounded-full bg-slate-900 px-3 py-1.5 text-sm font-semibold text-white"
            : "rounded-full border border-slate-300 bg-white px-3 py-1.5 text-sm font-semibold text-slate-700 hover:bg-slate-100";
    }

    private static string NormalizeCommentSortOrder(string? commentOrder)
    {
        if (string.Equals(commentOrder?.Trim(), "oldest", StringComparison.OrdinalIgnoreCase))
        {
            return "oldest";
        }

        return "latest";
    }

    private static string GetCommentSortLabel(string sortOrder)
        => string.Equals(sortOrder, "oldest", StringComparison.OrdinalIgnoreCase)
            ? "오래된순"
            : "최신순";

    private IEnumerable<int> GetCommentPageNumbers()
    {
        if (commentTotalPages <= 1)
        {
            yield break;
        }

        const int maxButtons = 7;
        var half = maxButtons / 2;
        var start = Math.Max(1, commentCurrentPage - half);
        var end = Math.Min(commentTotalPages, start + maxButtons - 1);
        if (end - start + 1 < maxButtons)
        {
            start = Math.Max(1, end - maxButtons + 1);
        }

        for (var pageNumber = start; pageNumber <= end; pageNumber++)
        {
            yield return pageNumber;
        }
    }

    private async Task ToggleFollowAuthor()
    {
        if (CurrentUser is null || post is null)
        {
            NavigateToLogin();
            return;
        }

        if (isWriterFollowBusy)
        {
            return;
        }

        isWriterFollowBusy = true;
        try
        {
            var isNowFollowing = await AuthService.ToggleFollowAsync(CurrentUserName, post.Author);
            isFollowingAuthor = isNowFollowing;
            authorFollowerCount = await AuthService.GetFollowerCountAsync(post.Author);
        }
        finally
        {
            isWriterFollowBusy = false;
        }
    }
}


