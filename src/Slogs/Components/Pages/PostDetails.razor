    private async Task SubmitComment()
    {
        if (isCommentSaving)
        {
            return;
        }

        if (CurrentUser is null || post is null || string.IsNullOrWhiteSpace(newComment))
        {
            if (CurrentUser is null)
            {
                message = "댓글은 로그인 후 이용 가능합니다.";
                NavigateToLogin();
                return;
            }

            if (post is null)
            {
                message = "댓글을 등록할 수 없습니다.";
                return;
            }

            if (string.IsNullOrWhiteSpace(newComment))
            {
                message = "댓글 내용을 입력해 주세요.";
                return;
            }
        }

        var trimmedComment = newComment.Trim();
        if (trimmedComment.Length > 1000)
        {
            message = "댓글은 1000자 이하로 입력해 주세요.";
            return;
        }

        if (!TryBeginCommentAction(CommentActionKind.CreateTopLevelComment))
        {
            return;
        }

        try
        {
            var comment = await BlogService.AddCommentAsync(Slug, CurrentUser.UserName, CurrentUserDisplayName, trimmedComment);
            if (comment is null)
            {
                message = "댓글 등록에 실패했습니다.";
                return;
            }

            if (comment.ParentCommentId is not null)
            {
                message = "댓글 등록에 실패했습니다.";
                return;
            }

            newComment = string.Empty;
            await RefreshPostAsync();
            message = "댓글이 등록되었습니다.";
        }
        finally
        {
            EndCommentAction();
        }
    }

    private async Task SubmitReply(Guid parentCommentId)
    {
        if (isCommentSaving)
        {
            return;
        }

        if (CurrentUser is null || post is null || string.IsNullOrWhiteSpace(replyComment))
        {
            if (CurrentUser is null)
            {
                message = "댓글은 로그인 후 이용 가능합니다.";
                NavigateToLogin();
                return;
            }

            if (post is null)
            {
                message = "댓글을 등록할 수 없습니다.";
                return;
            }

            message = "답글 내용을 입력해 주세요.";
            return;
        }

        var trimmedReply = replyComment.Trim();
        if (trimmedReply.Length > MaxCommentLength)
        {
            message = "댓글은 1000자 이하로 입력해 주세요.";
            return;
        }

        if (post is null || !post.Comments.Any(x => x.Id == parentCommentId))
        {
            message = "답글 대상을 찾을 수 없습니다.";
            return;
        }

        if (!TryBeginCommentAction(CommentActionKind.CreateReplyComment, parentCommentId))
        {
            return;
        }

        try
        {
            var comment = await BlogService.AddCommentAsync(Slug, CurrentUser.UserName, CurrentUserDisplayName, trimmedReply, parentCommentId);
            if (comment is null)
            {
                message = "답글 등록에 실패했습니다.";
                return;
            }

            replyComment = string.Empty;
            replyingToCommentId = null;
            await RefreshPostAsync();
            message = "답글이 등록되었습니다.";
        }
        finally
        {
            EndCommentAction();
        }
    }

    private async Task SubmitEditComment(Guid commentId)
    {
        if (isCommentSaving)
        {
            return;
        }

        if (CurrentUser is null || post is null)
        {
            message = "수정할 수 없습니다.";
            NavigateToLogin();
            return;
        }

        if (string.IsNullOrWhiteSpace(editingCommentText))
        {
            message = "댓글 내용을 입력해 주세요.";
            return;
        }

        var trimmed = editingCommentText.Trim();
        if (trimmed.Length > MaxCommentLength)
        {
            message = "댓글은 1000자 이하로 입력해 주세요.";
            return;
        }

        var target = FindComment(commentId);
        if (target is null)
        {
            message = "댓글을 찾을 수 없습니다.";
            return;
        }

        if (!CanEditComment(target))
        {
            message = "수정 권한이 없습니다.";
            return;
        }

        if (!TryBeginCommentAction(CommentActionKind.EditComment, commentId))
        {
            return;
        }

        try
        {
            var updated = await BlogService.UpdateCommentAsync(Slug, commentId, CurrentUser.UserName, trimmed);
            if (!updated)
            {
                message = "댓글 수정에 실패했습니다.";
                return;
            }

            editingCommentId = null;
            editingCommentText = string.Empty;
            await RefreshPostAsync();
            message = "댓글이 수정되었습니다.";
        }
        finally
        {
            EndCommentAction();
        }
    }

    private async Task RefreshPostAsync()
    {
        post = await BlogService.GetBySlugAsync(Slug);
        if (post is null)
        {
            previousPost = null;
            nextPost = null;
            topLevelComments = Array.Empty<BlogComment>();
            commentCurrentPage = 1;
            commentTotalPages = 1;
            commentTotalCount = 0;
            loadedPostSlug = null;
            return;
        }

        loadedPostSlug = post.Slug;
        var adjacent = await BlogService.GetAdjacentPostsAsync(Slug);
        previousPost = adjacent.Previous;
        nextPost = adjacent.Next;
        authorFollowerCount = await AuthService.GetFollowerCountAsync(post.Author);
        isFollowingAuthor = CurrentUser is not null
            ? await AuthService.IsFollowingAsync(CurrentUserName, post.Author)
            : false;
        LoadCommentPage();
        StateHasChanged();
    }

    private bool CanEditCurrentPost => CurrentUser is not null && post is not null && post.IsAuthor(CurrentUser.UserName);
    private bool CanFollowAuthor => CurrentUser is not null
        && post is not null
        && !string.Equals(CurrentUserName, post.Author, StringComparison.OrdinalIgnoreCase);

    private static string GetPostUrl(BlogPost targetPost)
        => $"/@{Uri.EscapeDataString(targetPost.Author)}/{Uri.EscapeDataString(targetPost.Slug)}";

    private static string? GetPostSeoImageUrl(BlogPost targetPost)
    {
        if (!string.IsNullOrWhiteSpace(targetPost.ThumbnailUrl))
        {
            return targetPost.ThumbnailUrl;
        }

        return MarkdownRenderer.FindFirstImage(targetPost.Body)?.Url;
    }

