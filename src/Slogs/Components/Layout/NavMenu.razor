@implements IDisposable
@inject NavigationManager Navigation

<nav class="rounded-xl border border-slate-200 bg-slate-50 p-3" aria-label="main menu">
    <div class="mb-3 text-xs font-bold uppercase tracking-wide text-slate-500">메뉴</div>
    <NavLink class="mb-1 block rounded-lg px-3 py-2 text-sm font-semibold text-slate-800 transition hover:bg-slate-900 hover:text-white"
             ActiveClass="bg-slate-900 text-white" href="/" Match="NavLinkMatch.All">홈</NavLink>

    @if (ShowDiscoveryLinks)
    {
        <NavLink class="mb-1 block rounded-lg px-3 py-2 text-sm font-semibold text-slate-800 transition hover:bg-slate-900 hover:text-white"
                 ActiveClass="bg-slate-900 text-white" href="@GetFeaturedTagPath()" Match="NavLinkMatch.All">추천 태그</NavLink>
        <NavLink class="mb-1 block rounded-lg px-3 py-2 text-sm font-semibold text-slate-800 transition hover:bg-slate-900 hover:text-white"
                 ActiveClass="bg-slate-900 text-white" href="/tag" Match="NavLinkMatch.All">전체 태그</NavLink>
        <NavLink class="mb-1 block rounded-lg px-3 py-2 text-sm font-semibold text-slate-800 transition hover:bg-slate-900 hover:text-white"
                 ActiveClass="bg-slate-900 text-white" href="/writer" Match="NavLinkMatch.All">작성자</NavLink>
        <NavLink class="mb-1 block rounded-lg px-3 py-2 text-sm font-semibold text-slate-800 transition hover:bg-slate-900 hover:text-white"
                 ActiveClass="bg-slate-900 text-white" href="/series" Match="NavLinkMatch.All">전체 시리즈</NavLink>
    }

    @if (ShowPersonalLinks)
    {
        <NavLink class="mb-1 block rounded-lg px-3 py-2 text-sm font-semibold text-slate-800 transition hover:bg-slate-900 hover:text-white"
                 ActiveClass="bg-slate-900 text-white" href="/feed" Match="NavLinkMatch.All">팔로우 피드</NavLink>
        <NavLink class="mb-1 block rounded-lg px-3 py-2 text-sm font-semibold text-slate-800 transition hover:bg-slate-900 hover:text-white"
                 ActiveClass="bg-slate-900 text-white" href="/me" Match="NavLinkMatch.All">내 글</NavLink>
        <NavLink class="mb-1 block rounded-lg px-3 py-2 text-sm font-semibold text-slate-800 transition hover:bg-slate-900 hover:text-white"
                 ActiveClass="bg-slate-900 text-white" href="/me/bookmarks" Match="NavLinkMatch.All">내 북마크</NavLink>
        <NavLink class="mb-1 block rounded-lg px-3 py-2 text-sm font-semibold text-slate-800 transition hover:bg-slate-900 hover:text-white"
                 ActiveClass="bg-slate-900 text-white" href="/me/likes" Match="NavLinkMatch.All">내 좋아요</NavLink>
    }

    <div class="mt-4 mb-2 text-xs font-bold uppercase tracking-wide text-slate-500">@TagSectionTitle</div>

    @if (trendingTags.Length == 0)
    {
        <p class="text-sm text-slate-500">태그가 준비 중입니다.</p>
    }
    else
    {
        foreach (var tag in trendingTags)
        {
            <a class="mb-2 mr-2 inline-block rounded-full border border-slate-200 bg-slate-50 px-2.5 py-1 text-sm font-semibold text-slate-700 transition hover:bg-slate-900 hover:text-white"
               href="@($"/tag/{Uri.EscapeDataString(tag)}")">#@tag</a>
        }
    }

    @if (ShouldShowSeriesSection)
    {
        <div class="mt-4 mb-2 text-xs font-bold uppercase tracking-wide text-slate-500">@SeriesSectionTitle</div>
        @if (serieses.Length == 0)
        {
            <p class="text-sm text-slate-500">@EmptySeriesMessage</p>
        }
        else
        {
            foreach (var series in serieses)
            {
                <a class="mb-2 mr-2 inline-block rounded-full border border-slate-200 bg-slate-50 px-2.5 py-1 text-sm font-semibold text-slate-700 transition hover:bg-slate-900 hover:text-white"
                   data-side-series="@series.Series"
                   data-series-like-count="@series.LikeCount"
                   data-series-post-count="@series.Count"
                   href="@($"/series/{Uri.EscapeDataString(series.Series)}")">@series.Series</a>
            }
        }
    }
</nav>

@code {
    [Inject] private BlogService BlogService { get; set; } = default!;
    [Inject] private AuthService AuthService { get; set; } = default!;

    private string[] trendingTags = [];
    private (string Series, int Count, int LikeCount)[] serieses = [];
    private bool isLoaded;
    private string GetFeaturedTagPath() => trendingTags.Length > 0
        ? $"/tag/{Uri.EscapeDataString(trendingTags[0])}"
        : "/tag";

    private AuthUser? CurrentUser => AuthService.CurrentUser;

    private bool IsSloggerContext => CurrentPath.StartsWith("/@", StringComparison.Ordinal);

    private bool ShowDiscoveryLinks => !IsSloggerContext;

    private bool ShowPersonalLinks => CurrentUser is not null && IsSloggerContext;

    private string TagSectionTitle => IsSloggerContext ? "태그" : "인기 태그";

    private bool ShouldShowSeriesSection => ShowDiscoveryLinks || IsSloggerContext;

    private string SeriesSectionTitle => IsSloggerContext ? "시리즈" : "인기 시리즈";

    private string EmptySeriesMessage => IsSloggerContext ? "작성한 시리즈가 없습니다." : "시리즈가 없습니다.";

    private string CurrentSloggerUserName
    {
        get
        {
            if (!IsSloggerContext)
            {
                return string.Empty;
            }

            var firstSegment = CurrentPath.Split('/', StringSplitOptions.RemoveEmptyEntries).FirstOrDefault();
            if (string.IsNullOrWhiteSpace(firstSegment) || !firstSegment.StartsWith("@", StringComparison.Ordinal))
            {
                return string.Empty;
            }

            return Uri.UnescapeDataString(firstSegment[1..]).Trim().ToLowerInvariant();
        }
    }

    private string CurrentPath
    {
        get
        {
            var relativePath = Navigation.ToBaseRelativePath(Navigation.Uri);
            var pathOnly = relativePath.Split(['?', '#'], 2, StringSplitOptions.None)[0].Trim('/');
            return string.IsNullOrWhiteSpace(pathOnly)
                ? "/"
                : $"/{pathOnly}";
        }
    }

    protected override async Task OnInitializedAsync()
    {
        AuthService.AuthStateChanged += OnAuthStateChanged;
        Navigation.LocationChanged += OnLocationChanged;
        await LoadSideMenuDataAsync();
        isLoaded = true;
    }

    public void Dispose()
    {
        AuthService.AuthStateChanged -= OnAuthStateChanged;
        Navigation.LocationChanged -= OnLocationChanged;
    }

    private void OnAuthStateChanged()
    {
        _ = RefreshSideMenuAsync();
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        _ = RefreshSideMenuAsync();
    }

    private async Task RefreshSideMenuAsync()
    {
        if (!isLoaded)
        {
            return;
        }

        await LoadSideMenuDataAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadSideMenuDataAsync()
    {
        trendingTags = (await BlogService.GetTrendingTagsAsync(8)).ToArray();
        serieses = IsSloggerContext
            ? (await BlogService.GetSeriesByAuthorAsync(CurrentSloggerUserName, 8)).ToArray()
            : (await BlogService.GetPopularSeriesAsync(8)).ToArray();
    }
}
