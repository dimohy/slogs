@using System
@implements IDisposable
@inject NavigationManager Navigation
@inject AuthService AuthService
@inherits LayoutComponentBase

<div class="min-h-screen bg-slate-100">
    <header class="slogs-app-header sticky top-0 z-20 border-b border-slate-200 bg-white bg-opacity-90 backdrop-blur-md">
        <div class="slogs-reconnect-slot">
            <ReconnectModal />
        </div>

        <div class="slogs-app-header__inner mx-auto flex w-full max-w-6xl flex-wrap items-center gap-3 px-4 py-3 md:flex-nowrap">
            <a class="slogs-brand" href="/" aria-label="slogs 홈">
                <img class="slogs-brand__icon" src="@Assets["favicon.svg"]" alt="" width="32" height="32" />
                <span class="slogs-brand__wordmark">slogs</span>
            </a>

            <div class="slogs-header-search hidden min-w-0 flex-1 items-center gap-2 rounded-full border border-slate-200 bg-white px-3 py-2 md:flex">
                <input class="min-w-0 flex-1 border-0 bg-transparent text-sm text-slate-700 outline-none"
                       @bind="searchTerm" @bind:event="oninput" placeholder="글 제목, 태그, 작성자로 검색"
                       @onkeydown="HandleSearchKeyDown" />
                <button class="rounded-full bg-slate-900 px-3 py-1 text-sm font-semibold text-white transition hover:bg-slate-800"
                        type="button" @onclick="GoSearch">
                    검색
                </button>
            </div>

            <nav class="slogs-header-actions ml-auto flex items-center gap-2" aria-label="header actions">
                @if (CurrentUser is null)
                {
                    <a class="rounded-full bg-slate-900 px-3 py-1.5 text-sm font-semibold text-white transition hover:bg-slate-800"
                       href="@GetLoginHref()">로그인</a>
                }
                else
                {
                    <a class="rounded-full border border-slate-300 px-3 py-1.5 text-sm font-semibold text-slate-800 transition hover:bg-slate-100"
                       href="/write">글쓰기</a>
                    <div class="relative">
                        <button class="rounded-full border border-slate-200 bg-slate-100 px-3 py-1.5 text-sm font-semibold text-slate-700 transition hover:bg-slate-200"
                                type="button"
                                aria-haspopup="menu"
                                aria-expanded="@isAccountMenuOpen"
                                @onclick="ToggleAccountMenu">
                            @CurrentUser.DisplayName
                        </button>
                        @if (isAccountMenuOpen)
                        {
                            <div class="absolute right-0 mt-2 w-44 overflow-hidden rounded-xl border border-slate-200 bg-white py-1 text-sm shadow-lg"
                                 role="menu">
                                <a class="block px-4 py-2 font-semibold text-slate-800 transition hover:bg-slate-100"
                                   href="@GetCurrentUserPath()"
                                   role="menuitem"
                                   @onclick="CloseAccountMenu">@GetCurrentUserMenuText()</a>
                                <a class="block px-4 py-2 text-slate-700 transition hover:bg-slate-100"
                                   href="/me"
                                   role="menuitem"
                                   @onclick="CloseAccountMenu">내 글</a>
                                <form method="post" action="/auth/logout">
                                    <input type="hidden" name="returnUrl" value="/" />
                                    <button class="block w-full px-4 py-2 text-left text-slate-700 transition hover:bg-slate-100"
                                            type="submit"
                                            role="menuitem">로그아웃</button>
                                </form>
                            </div>
                        }
                    </div>
                }
            </nav>
        </div>
    </header>

    <div class="slogs-page-shell mx-auto grid w-full max-w-6xl grid-cols-1 gap-4 px-4 py-4 lg:grid-cols-12">
        <aside class="lg:sticky lg:top-24 lg:self-start lg:col-span-4 xl:col-span-3">
            <NavMenu />
        </aside>

        <main class="min-w-0 lg:col-span-8 xl:col-span-9">
            @Body
        </main>
    </div>
</div>

<div id="blazor-error-ui" data-nosnippet>
    오류가 발생했습니다.
    <a href="." class="reload">다시 시도</a>
    <span class="dismiss">×</span>
</div>

@code {
    private string searchTerm = string.Empty;
    private bool isAccountMenuOpen;

    private AuthUser? CurrentUser => AuthService.CurrentUser;

    protected override void OnInitialized()
    {
        AuthService.AuthStateChanged += OnAuthStateChanged;
    }

    public void Dispose()
    {
        AuthService.AuthStateChanged -= OnAuthStateChanged;
    }

    private void OnAuthStateChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    private void ToggleAccountMenu()
    {
        isAccountMenuOpen = !isAccountMenuOpen;
    }

    private void CloseAccountMenu()
    {
        isAccountMenuOpen = false;
    }

    private string GetCurrentUserPath()
    {
        return CurrentUser is null
            ? "/"
            : $"/@{Uri.EscapeDataString(CurrentUser.UserName)}";
    }

    private string GetCurrentUserMenuText()
    {
        return CurrentUser is null
            ? "@"
            : $"@{CurrentUser.UserName}";
    }

    private string GetLoginHref()
    {
        var safeReturn = GetCurrentPathWithQuery();
        return $"/login?returnUrl={Uri.EscapeDataString(safeReturn)}";
    }

    private string GetCurrentPathWithQuery()
    {
        var uri = new Uri(Navigation.Uri);
        if (uri.AbsolutePath.Equals("/login", StringComparison.OrdinalIgnoreCase)
            || uri.AbsolutePath.Equals("/register", StringComparison.OrdinalIgnoreCase))
        {
            var explicitReturnUrl = GetExplicitReturnUrlFromQuery(uri.Query);
            var baseHost = new Uri(Navigation.BaseUri).Host;
            if (!string.IsNullOrWhiteSpace(explicitReturnUrl)
                && TryNormalizeRelativeReturnUrl(explicitReturnUrl, baseHost, out var safeReturnUrl))
            {
                return safeReturnUrl;
            }

            return "/";
        }

        return string.IsNullOrWhiteSpace(uri.Query) ? uri.AbsolutePath : uri.PathAndQuery;
    }

    private static string? GetExplicitReturnUrlFromQuery(string? query)
    {
        if (string.IsNullOrWhiteSpace(query) || query.Length <= 1)
        {
            return null;
        }

        var raw = query[1..];
        foreach (var segment in raw.Split('&', StringSplitOptions.RemoveEmptyEntries))
        {
            var split = segment.Split('=', 2);
            if (!split[0].Equals("returnUrl", StringComparison.OrdinalIgnoreCase) || split.Length < 2)
            {
                continue;
            }

            var decoded = Uri.UnescapeDataString(split[1]);
            return string.IsNullOrWhiteSpace(decoded) ? null : decoded;
        }

        return null;
    }

    private static bool TryNormalizeRelativeReturnUrl(string? returnUrl, string? baseHost, out string safeReturnUrl)
    {
        safeReturnUrl = string.Empty;

        if (string.IsNullOrWhiteSpace(returnUrl))
        {
            return false;
        }

        if (!Uri.TryCreate(returnUrl, UriKind.RelativeOrAbsolute, out var parsedReturn))
        {
            return false;
        }

        if (!parsedReturn.IsAbsoluteUri && parsedReturn.OriginalString.StartsWith("/"))
        {
            safeReturnUrl = parsedReturn.OriginalString;
            return true;
        }

        if (parsedReturn.IsAbsoluteUri && !string.IsNullOrWhiteSpace(baseHost)
            && parsedReturn.Host.Equals(baseHost, StringComparison.OrdinalIgnoreCase))
        {
            safeReturnUrl = parsedReturn.PathAndQuery;
            return true;
        }

        return false;
    }

    private void GoSearch()
    {
        if (string.IsNullOrWhiteSpace(searchTerm))
        {
            Navigation.NavigateTo("/");
            return;
        }

        Navigation.NavigateTo(ParseSearchDestination(searchTerm.Trim()));
    }

    private void HandleSearchKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            GoSearch();
        }
    }

    private static string ParseSearchDestination(string term)
    {
        var trimmed = term.Trim();
        if (string.IsNullOrWhiteSpace(trimmed))
        {
            return "/";
        }

        if (trimmed.StartsWith("#", StringComparison.Ordinal))
        {
            var tag = trimmed[1..].Trim();
            if (!string.IsNullOrWhiteSpace(tag))
            {
                return $"/tag/{Uri.EscapeDataString(tag)}";
            }

            return "/tag";
        }

        if (trimmed.StartsWith("@@", StringComparison.Ordinal))
        {
            var writer = trimmed[2..].Trim();
            if (!string.IsNullOrWhiteSpace(writer))
            {
                return $"/@{Uri.EscapeDataString(writer)}";
            }

            return "/writer";
        }

        if (trimmed.StartsWith("@", StringComparison.Ordinal))
        {
            var writer = trimmed[1..].Trim();
            if (!string.IsNullOrWhiteSpace(writer))
            {
                return $"/@{Uri.EscapeDataString(writer)}";
            }

            return "/writer";
        }

        if (trimmed.StartsWith("tag:", StringComparison.OrdinalIgnoreCase))
        {
            var tag = trimmed[4..].Trim();
            if (!string.IsNullOrWhiteSpace(tag))
            {
                return $"/tag/{Uri.EscapeDataString(tag)}";
            }

            return "/tag";
        }

        if (trimmed.StartsWith("writer:", StringComparison.OrdinalIgnoreCase))
        {
            var writer = trimmed[7..].Trim();
            if (!string.IsNullOrWhiteSpace(writer))
            {
                return $"/@{Uri.EscapeDataString(writer)}";
            }

            return "/writer";
        }

        if (trimmed.StartsWith("series:", StringComparison.OrdinalIgnoreCase))
        {
            var series = trimmed[7..].Trim();
            if (!string.IsNullOrWhiteSpace(series))
            {
                return $"/series/{Uri.EscapeDataString(series)}";
            }

            return "/series";
        }

        return $"/?q={Uri.EscapeDataString(trimmed)}";
    }
}
