@page "/post"
@using Microsoft.AspNetCore.Components.Web
@inject BlogService BlogService
@inject AuthService AuthService
@inject NavigationManager Navigation

<PageTitle>글 목록</PageTitle>
<SeoHead Title="글 목록 | slogs"
         Description="slogs의 공개 글을 최신순, 인기순, 업데이트순으로 탐색합니다."
         CanonicalPath="/post"
         NoIndex="@(!string.IsNullOrWhiteSpace(Query))"
         JsonLd="@(SeoMetadata.CollectionPageJsonLd(Navigation.BaseUri, "/post", "slogs 글 목록", "slogs의 공개 글을 최신순, 인기순, 업데이트순으로 탐색합니다."))" />

<h1 class="text-2xl font-bold text-slate-900">전체 글</h1>
<p class="mb-3 text-sm text-slate-500">글 목록을 전체 정렬 기준으로 확인합니다.</p>

<div class="mb-4">
    <div class="flex flex-wrap gap-2">
        <input class="min-w-0 flex-1 rounded-full border border-slate-300 bg-white px-3 py-2 text-sm outline-none transition focus:border-slate-900"
               value="@searchText"
               @oninput="HandleSearchInputChanged"
               @onkeydown="HandleSearchKeyDown"
               placeholder="검색: 키워드 또는 #태그, @@작성자"
               aria-label="검색어 입력" />
        <a class="rounded-full border border-slate-300 bg-slate-900 px-3 py-2 text-sm font-semibold text-white transition hover:bg-slate-700"
           href="@GetSearchResultHref()">
            검색
        </a>
        @if (!string.IsNullOrWhiteSpace(Query))
        {
            <a class="rounded-full border border-slate-300 px-3 py-2 text-sm font-semibold text-slate-700 transition hover:bg-slate-100"
               href="@GetPostQueryQuery(sort: Sort)">
                검색 초기화
            </a>
        }
    </div>
    <p class="mt-2 text-xs text-slate-500">예시: react, #javascript, @@admin</p>
</div>

<div class="mb-3 flex flex-wrap gap-2">
    <a class="@GetSortChipClass(null)" href="@GetSortQuery(null)">최신</a>
    <a class="@GetSortChipClass("popular")" href='@GetSortQuery("popular")'>인기</a>
    <a class="@GetSortChipClass("updated")" href='@GetSortQuery("updated")'>최신 업데이트</a>
</div>
@if (!string.IsNullOrWhiteSpace(actionMessage))
{
    <p class="mb-2 rounded-lg border border-amber-200 bg-amber-50 px-3 py-2 text-sm text-amber-800">@actionMessage</p>
}

<section class="grid grid-cols-1 gap-3 md:grid-cols-2">
    @if (!posts.Any())
    {
        <p class="rounded-2xl border border-slate-200 bg-white p-4 text-slate-500">작성된 글이 없습니다.</p>
    }
    else
    {
        @foreach (var post in posts)
        {
            <article class="clickable-post-card rounded-2xl border border-slate-200 bg-white p-4"
                     data-card-click-href="@GetPostUrl(post)"
                     tabindex="0"
                     role="link"
                     aria-label="@($"{post.Title} 상세 보기")">
                <PostCardImage Post="post" PostUrl="@GetPostUrl(post)" />
                <a class="mb-2 block text-xl font-bold text-slate-900 hover:underline" href="@GetPostUrl(post)">@post.Title</a>
                <div class="mb-2 flex flex-wrap items-center gap-1 text-sm text-slate-500">
                    <a class="hover:underline" href="@($"/@{Uri.EscapeDataString(post.Author)}")">@post.Author</a>
                    <span>·</span>
                    <span>@FormatDate(post.PublishedAt)</span>
                    <span>·</span>
                    <span>@post.ReadTimeMinutes 분</span>
                    <span>·</span>
                    <span>@post.ViewCount 회 조회</span>
                </div>
                <p class="text-slate-700">@post.Summary</p>
                @if (post.Tags.Any())
                {
                    <div class="mt-2 flex flex-wrap gap-2">
                        @foreach (var tag in post.Tags)
                        {
                            <a class="rounded-full border border-sky-200 bg-sky-50 px-2.5 py-1 text-xs font-semibold text-sky-900 hover:bg-sky-100"
                               href="@($"/tag/{Uri.EscapeDataString(tag)}")">#@tag</a>
                        }
                    </div>
                }

                <div class="mt-3 flex flex-wrap gap-2">
                    <button class="rounded-full border border-slate-300 px-3 py-1.5 text-sm font-semibold transition hover:bg-slate-100 @(IsPostBusy(post.Slug, pendingLikeSlugs) ? "opacity-60" : string.Empty)"
                            disabled="@IsPostBusy(post.Slug, pendingLikeSlugs)"
                            @onclick="() => ToggleLikeAsync(post.Slug)">
                        @((post.IsLikedBy(CurrentUserName) ? "좋아요 취소" : "좋아요")) (@post.LikeCount)
                    </button>
                    <button class="rounded-full border border-slate-300 px-3 py-1.5 text-sm font-semibold transition hover:bg-slate-100 @(IsPostBusy(post.Slug, pendingBookmarkSlugs) ? "opacity-60" : string.Empty)"
                            disabled="@IsPostBusy(post.Slug, pendingBookmarkSlugs)"
                            @onclick="() => ToggleBookmarkAsync(post.Slug)">
                        @(post.IsBookmarkedBy(CurrentUserName) ? "북마크 해제" : "북마크")
                    </button>
                    <a class="rounded-full border border-slate-300 px-3 py-1.5 text-sm font-semibold transition hover:bg-slate-100" href="@GetPostCommentsUrl(post)">댓글 @post.CommentCount</a>
                </div>
            </article>
        }
    }
</section>

@if (totalPages > 1)
{
    <div class="mt-4 flex flex-wrap items-center justify-center gap-2">
        <a class="rounded-full border border-slate-300 px-3 py-1.5 text-sm font-semibold text-slate-700 hover:bg-slate-100 @(currentPage == 1 ? "pointer-events-none opacity-50" : string.Empty)"
           href="@GetPageHref(Math.Max(1, currentPage - 1))">이전</a>

        @foreach (var pageNumber in GetPageNumbers())
        {
            <a class="@(pageNumber == currentPage
                ? "rounded-full bg-slate-900 px-3 py-1.5 text-sm font-semibold text-white"
                : "rounded-full border border-slate-300 bg-white px-3 py-1.5 text-sm font-semibold text-slate-700 hover:bg-slate-100")"
               href="@GetPageHref(pageNumber)">
                @pageNumber
            </a>
        }

        <a class="rounded-full border border-slate-300 px-3 py-1.5 text-sm font-semibold text-slate-700 hover:bg-slate-100 @(currentPage == totalPages ? "pointer-events-none opacity-50" : string.Empty)"
           href="@GetPageHref(Math.Min(totalPages, currentPage + 1))">다음</a>
    </div>
}

@code {
    [SupplyParameterFromQuery(Name = "sort")] public string? Sort { get; set; }
    [SupplyParameterFromQuery(Name = "page")] public string? PageQuery { get; set; }
    [SupplyParameterFromQuery(Name = "q")] public string? Query { get; set; }

    private IReadOnlyList<BlogPost> posts = Array.Empty<BlogPost>();
    private int currentPage;
    private int totalPages;
    private string actionMessage = string.Empty;
    private HashSet<string> pendingLikeSlugs = [];
    private HashSet<string> pendingBookmarkSlugs = [];
    private string searchText = string.Empty;
    private string? normalizedSort;

    private AuthUser? CurrentUser => AuthService.CurrentUser;
    private string CurrentUserName => AuthService.CurrentUser?.UserName ?? string.Empty;

    protected override async Task OnParametersSetAsync()
    {
        searchText = Query ?? string.Empty;
        normalizedSort = ListQueryUrlBuilder.NormalizeSortValue(Sort, "latest", "popular", "updated");
        await LoadPostsAsync();
    }

    private async Task LoadPostsAsync()
    {
        var basePosts = string.IsNullOrWhiteSpace(Query)
            ? await BlogService.GetLatestAsync(200)
            : await BlogService.SearchPostsAsync(Query);

        var requestedPage = ListQueryUrlBuilder.ParsePage(PageQuery);
        currentPage = Math.Max(1, requestedPage);

        var allPosts = normalizedSort switch
        {
            "popular" => basePosts.OrderByDescending(x => x.LikeCount * 2 + x.ViewCount).ThenByDescending(x => x.PublishedAt).ToList(),
            "updated" => basePosts.OrderByDescending(x => x.UpdatedAt).ThenByDescending(x => x.PublishedAt).ToList(),
            _ => basePosts.OrderByDescending(x => x.PublishedAt).ToList()
        };

        totalPages = allPosts.Count == 0 ? 0 : (int)Math.Ceiling(allPosts.Count / 6d);
        currentPage = Math.Min(currentPage, Math.Max(1, totalPages));
        posts = allPosts.Skip((currentPage - 1) * 6).Take(6).ToList();
        actionMessage = string.Empty;
    }

    private string GetSortQuery(string? sort)
    {
        if (string.IsNullOrWhiteSpace(sort))
        {
            return GetPostQueryQuery();
        }

        return GetPostQueryQuery(sort);
    }

    private string GetSortChipClass(string? sort)
    {
        var target = (sort ?? string.Empty).Trim().ToLowerInvariant();
        var current = string.IsNullOrWhiteSpace(normalizedSort) ? "latest" : normalizedSort!;
        var isActive = (target == "latest" ? string.IsNullOrWhiteSpace(current) || current == "latest" : current == target);

        return isActive
            ? "rounded-full bg-slate-900 px-3 py-1.5 text-sm font-semibold text-white"
            : "rounded-full border border-slate-300 bg-white px-3 py-1.5 text-sm font-semibold text-slate-700 hover:bg-slate-100";
    }

    private string GetPageHref(int targetPage)
    {
        var page = Math.Max(1, targetPage);
        if (totalPages > 0 && page > totalPages)
        {
            page = totalPages;
        }
        return GetPostQueryQuery(sort: normalizedSort, page: page);
    }

    private IEnumerable<int> GetPageNumbers()
    {
        if (totalPages <= 1)
        {
            yield break;
        }

        const int maxButtons = 7;
        var half = maxButtons / 2;
        var start = Math.Max(1, currentPage - half);
        var end = Math.Min(totalPages, start + maxButtons - 1);
        if (end - start + 1 < maxButtons)
        {
            start = Math.Max(1, end - maxButtons + 1);
        }

        for (var pageNumber = start; pageNumber <= end; pageNumber++)
        {
            yield return pageNumber;
        }
    }

    private string GetSearchResultHref()
    {
        var normalizedSearch = searchText.Trim();
        return GetPostQueryQuery(sort: normalizedSort, query: normalizedSearch);
    }

    private void HandleSearchInputChanged(ChangeEventArgs e)
    {
        searchText = e?.Value?.ToString() ?? string.Empty;
    }

    private void HandleSearchKeyDown(KeyboardEventArgs e)
    {
        if (string.Equals(e.Key, "Enter", StringComparison.OrdinalIgnoreCase))
        {
            Navigation.NavigateTo(GetSearchResultHref());
        }
    }

    private string GetPostQueryQuery(string? sort = null, string? query = null, int? page = null)
    {
        var normalizedQuery = query ?? Query;
        var normalizedSortValue = ListQueryUrlBuilder.NormalizeSortValue(sort, "latest", "popular", "updated") ?? normalizedSort;
        var normalizedPage = page ?? ListQueryUrlBuilder.ParsePage(PageQuery);

        return ListQueryUrlBuilder.Build("/post", normalizedSortValue, normalizedQuery, normalizedPage, totalPages);
    }

    private static string GetPostUrl(BlogPost post)
        => $"/@{Uri.EscapeDataString(post.Author)}/{Uri.EscapeDataString(post.Slug)}";

    private static string GetPostCommentsUrl(BlogPost post)
        => $"{GetPostUrl(post)}#comments";

    private bool IsPostBusy(string slug, HashSet<string> busySet) => busySet.Contains(slug);

    private async Task ToggleLikeAsync(string slug)
    {
        if (CurrentUser is null)
        {
            NavigateToLogin();
            return;
        }

        if (pendingLikeSlugs.Contains(slug))
        {
            return;
        }

        pendingLikeSlugs.Add(slug);
        actionMessage = string.Empty;
        StateHasChanged();

        try
        {
            await BlogService.ToggleLikeAsync(slug, CurrentUserName);
            await LoadPostsAsync();
        }
        finally
        {
            pendingLikeSlugs.Remove(slug);
            actionMessage = string.Empty;
            StateHasChanged();
        }
    }

    private async Task ToggleBookmarkAsync(string slug)
    {
        if (CurrentUser is null)
        {
            NavigateToLogin();
            return;
        }

        if (pendingBookmarkSlugs.Contains(slug))
        {
            return;
        }

        pendingBookmarkSlugs.Add(slug);
        actionMessage = string.Empty;
        StateHasChanged();

        try
        {
            await BlogService.ToggleBookmarkAsync(slug, CurrentUserName);
            await LoadPostsAsync();
        }
        finally
        {
            pendingBookmarkSlugs.Remove(slug);
            actionMessage = string.Empty;
            StateHasChanged();
        }
    }

    private void NavigateToLogin()
    {
        var returnUrl = GetCurrentPathWithQuery();
        var encoded = Uri.EscapeDataString(string.IsNullOrWhiteSpace(returnUrl) ? "/post" : returnUrl);
        Navigation.NavigateTo($"/login?returnUrl={encoded}");
    }

    private string GetCurrentPathWithQuery()
    {
        var uri = new Uri(Navigation.Uri);
        return string.IsNullOrWhiteSpace(uri.Query) ? uri.AbsolutePath : uri.PathAndQuery;
    }

    private static string FormatDate(DateTime dateTime) => dateTime.ToLocalTime().ToString("yyyy.MM.dd");

}


