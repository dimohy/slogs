@page "/"
@page "/recent"
@page "/trending"
@page "/recommended"
@page "/feed"
@inject BlogService BlogService
@inject AuthService AuthService
@inject NavigationManager Navigation
<PageTitle>slogs</PageTitle>
<SeoHead Title="@GetSeoTitle()"
         Description="@GetSeoDescription()"
         CanonicalPath="@GetSeoCanonicalPath()"
         NoIndex="@ShouldNoIndex"
         JsonLd="@(SeoMetadata.WebSiteJsonLd(Navigation.BaseUri))" />

<div class="mb-4 rounded-2xl border border-slate-200 bg-white p-6">
    <div class="mb-4 flex flex-wrap gap-2">
        <a class="@GetDiscoveryTabClass("trending")" href="/trending">트렌딩</a>
        <a class="@GetDiscoveryTabClass("recommended")" href="/recommended">추천</a>
        <a class="@GetDiscoveryTabClass("recent")" href="/recent">최신</a>
        <a class="@GetDiscoveryTabClass("feed")" href="/feed">피드</a>
    </div>
    <h1 class="text-2xl font-bold text-slate-900">
        @(string.IsNullOrWhiteSpace(Query)
            ? GetDiscoveryTitle()
            : $"\"{GetDisplayedQuery()}\" 검색 결과")
    </h1>
    <p class="mt-1 text-sm text-slate-500">@GetDiscoveryDescription()</p>
</div>

<div class="mb-4">
    <div class="flex flex-wrap items-center gap-2">
        <input class="min-w-0 flex-1 rounded-full border border-slate-300 bg-white px-3 py-2 text-sm outline-none transition focus:border-slate-900"
               value="@searchText"
               @oninput="HandleSearchInputChanged"
               @onkeydown="HandleSearchKeyDown"
               placeholder="검색: 태그/#태그, @@작성자, tag:, writer:, series:"
               aria-label="검색어 입력" />
        <a class="rounded-full border border-slate-300 bg-slate-900 px-3 py-2 text-sm font-semibold text-white transition hover:bg-slate-700"
           href="@GetSearchResultHref()">
            검색
        </a>
        @if (!string.IsNullOrWhiteSpace(Query))
        {
            <a class="rounded-full border border-slate-300 px-3 py-2 text-sm font-semibold text-slate-700 transition hover:bg-slate-100"
               href="@GetHomeQuery(sort: normalizedSort, feed: normalizedFeed)">
                검색 초기화
            </a>
        }
    </div>
    <p class="mt-2 text-xs text-slate-500">예시: #javascript, @@작성자, tag:javascript, writer:작성자, series:시리즈</p>
</div>

<div class="mb-3 flex flex-wrap gap-2">
    <a class="@GetFeedChipClass(null)" href="@GetHomeQuery(sort: null, feed: null)">전체</a>
    <a class="@GetFeedChipClass("following")" href="@GetHomeQuery(sort: null, feed: "following")">팔로우</a>
</div>

<div class="mb-2 flex items-center justify-between gap-3 text-sm text-slate-500">
    <span>@($"{totalCount}개 글")</span>
    @if (totalPages > 1)
    {
        <span>@($"페이지 {currentPage}/{totalPages}")</span>
    }
</div>

    @if (!string.IsNullOrWhiteSpace(displayedSearchMessage))
    {
        <p class="mb-4 rounded-2xl border border-slate-200 bg-white p-4 text-sm text-slate-500">
            @displayedSearchMessage
        </p>
    }

    @if (!string.IsNullOrWhiteSpace(actionMessage))
    {
        <p class="mb-4 rounded-2xl border border-amber-200 bg-amber-50 p-4 text-sm text-amber-800">
            @actionMessage
        </p>
    }

<section class="grid grid-cols-1 gap-3 md:grid-cols-2">
@if (!posts.Any())
{
    @if (IsFollowingFeed && string.IsNullOrWhiteSpace(Query) && CurrentUser is not null)
    {
        <div class="rounded-2xl border border-slate-200 bg-white p-4">
            <p class="text-slate-500">팔로우한 작성자의 최신 글이 아직 없습니다.</p>
            <a class="mt-2 inline-block rounded-full border border-slate-300 bg-slate-900 px-3 py-2 text-sm font-semibold text-white transition hover:bg-slate-800"
               href="/writer">
                작성자 찾아보기
            </a>
        </div>
    }
    else
    {
        <p class="rounded-2xl border border-slate-200 bg-white p-4 text-slate-500">조건에 맞는 글이 없습니다.</p>
    }
}
else
{
    foreach (var post in posts)
    {
        <article class="clickable-post-card rounded-2xl border border-slate-200 bg-white p-4"
                 data-card-click-href="@GetPostUrl(post)"
                 tabindex="0"
                 role="link"
                 aria-label="@($"{post.Title} 상세 보기")">
            <PostCardImage Post="post" PostUrl="@GetPostUrl(post)" />
            <div class="mb-2 flex flex-wrap items-center gap-1 text-sm text-slate-500">
            <a class="font-semibold text-slate-800 hover:underline"
                   href="@($"/@{Uri.EscapeDataString(post.Author)}")">@post.Author</a>
                <span>·</span>
                <span>@FormatDate(post.PublishedAt)</span>
                <span>·</span>
                <span>@post.ReadTimeMinutes 분</span>
                <span>·</span>
                <span>@post.ViewCount 회 조회</span>
                <span>·</span>
                <span>@post.LikeCount 개 좋아요</span>
                @if (post.Series.Count > 0)
                {
                    <span>·</span>
                    @foreach (var series in post.Series)
                    {
                        <a class="hover:underline" href="@($"/series/{Uri.EscapeDataString(series)}")">시리즈: @series</a>
                    }
                }
            </div>

            <a class="mb-2 block text-xl font-bold text-slate-900 hover:underline"
               href="@GetPostUrl(post)">@post.Title</a>
            <p class="text-slate-700">@Shorten(post.Summary, 170)</p>

            <div class="mt-3 flex flex-wrap gap-2">
                @foreach (var tag in post.Tags)
                {
                    <a class="rounded-full border border-sky-200 bg-sky-50 px-2.5 py-1 text-xs font-semibold text-sky-900 hover:bg-sky-100"
                       href="@($"/tag/{Uri.EscapeDataString(tag)}")">#@tag</a>
                }
            </div>

            <div class="mt-3 flex flex-wrap gap-2">
                <button class="rounded-full border border-slate-300 px-3 py-1.5 text-sm font-semibold transition hover:bg-slate-100 @(IsPostBusy(post.Slug, pendingLikeSlugs) ? "opacity-60" : "")"
                        disabled="@IsPostBusy(post.Slug, pendingLikeSlugs)"
                        @onclick="() => ToggleLikeAsync(post.Slug)">
                    @((post.IsLikedBy(CurrentUserName) ? "좋아요 취소" : "좋아요")) (@post.LikeCount)
                </button>
                <button class="rounded-full border border-slate-300 px-3 py-1.5 text-sm font-semibold transition hover:bg-slate-100 @(IsPostBusy(post.Slug, pendingBookmarkSlugs) ? "opacity-60" : "")"
                        disabled="@IsPostBusy(post.Slug, pendingBookmarkSlugs)"
                        @onclick="() => ToggleBookmarkAsync(post.Slug)">
                    @(post.IsBookmarkedBy(CurrentUserName) ? "북마크 해제" : "북마크")
                </button>
                <a class="rounded-full border border-slate-300 px-3 py-1.5 text-sm font-semibold transition hover:bg-slate-100"
                   href="@GetPostCommentsUrl(post)">댓글 @post.CommentCount</a>
            </div>
        </article>
    }
}
</section>

    @if (totalPages > 1)
    {
        <div class="mt-4 flex flex-wrap items-center justify-center gap-2">
            <a class="rounded-full border border-slate-300 px-3 py-1.5 text-sm font-semibold text-slate-700 hover:bg-slate-100 @(currentPage == 1 ? "pointer-events-none opacity-50" : string.Empty)"
               href="@GetPageHref(Math.Max(1, currentPage - 1))">이전</a>

            @foreach (var pageNumber in GetPageNumbers())
            {
                <a class="@(pageNumber == currentPage
                    ? "rounded-full bg-slate-900 px-3 py-1.5 text-sm font-semibold text-white"
                    : "rounded-full border border-slate-300 bg-white px-3 py-1.5 text-sm font-semibold text-slate-700 hover:bg-slate-100")"
                   href="@GetPageHref(pageNumber)">
                    @pageNumber
                </a>
            }

            <a class="rounded-full border border-slate-300 px-3 py-1.5 text-sm font-semibold text-slate-700 hover:bg-slate-100 @(currentPage == totalPages ? "pointer-events-none opacity-50" : string.Empty)"
               href="@GetPageHref(Math.Min(totalPages, currentPage + 1))">다음</a>
        </div>
    }
    <section class="mt-5 rounded-2xl border border-slate-200 bg-white p-4">
    <h2 class="mb-3 text-lg font-bold text-slate-900">인기 태그</h2>
    <div class="flex flex-wrap gap-2">
        @if (trendingTagCloud.Count == 0)
        {
            <p class="text-sm text-slate-500">인기 태그가 없습니다.</p>
        }
        else
        {
            foreach (var item in trendingTagCloud)
            {
                <a class="rounded-full border border-slate-200 bg-slate-50 px-2.5 py-1 text-sm font-semibold text-slate-700 hover:bg-slate-900 hover:text-white"
                   href="@($"/tag/{Uri.EscapeDataString(item.Tag)}")">
                    @($"#{item.Tag} ({item.Count})")
                </a>
            }
        }
    </div>
</section>

@code {
    [SupplyParameterFromQuery(Name = "q")]
    public string? Query { get; set; }

    [SupplyParameterFromQuery(Name = "sort")]
    public string? Sort { get; set; }
    [SupplyParameterFromQuery(Name = "feed")]
    public string? Feed { get; set; }
    [SupplyParameterFromQuery(Name = "page")]
    public string? PageQuery { get; set; }

    private IReadOnlyList<BlogPost> posts = Array.Empty<BlogPost>();
    private int currentPage;
    private int totalCount;
    private int totalPages;
    private IReadOnlyList<(string Tag, int Count)> trendingTagCloud = Array.Empty<(string Tag, int Count)>();
    private string? displayedSearchMessage;
    private string actionMessage = string.Empty;
    private HashSet<string> pendingLikeSlugs = [];
    private HashSet<string> pendingBookmarkSlugs = [];
    private string searchText = string.Empty;
    private string? normalizedSort;
    private string? normalizedFeed;
    private string discoveryMode = "recent";

    protected override async Task OnParametersSetAsync()
    {
        searchText = Query ?? string.Empty;
        var currentPath = new Uri(Navigation.Uri).AbsolutePath.TrimEnd('/');
        currentPath = string.IsNullOrWhiteSpace(currentPath) ? "/" : currentPath;
        isFeedPageRoute = string.Equals(currentPath, "/feed", StringComparison.OrdinalIgnoreCase);
        discoveryMode = ResolveDiscoveryMode(currentPath);
        var requestedPage = ListQueryUrlBuilder.ParsePage(PageQuery);
        var effectiveFeed = isFeedPageRoute
            ? "following"
            : Feed;
        var requestedSort = string.IsNullOrWhiteSpace(Sort)
            ? GetDefaultSortForDiscoveryMode(discoveryMode)
            : Sort;

        normalizedSort = ListQueryUrlBuilder.NormalizeSortValue(requestedSort, "latest", "popular", "updated", "recommended");
        normalizedFeed = ListQueryUrlBuilder.NormalizeFeedValue(effectiveFeed);

        if (isFeedPageRoute && !string.IsNullOrWhiteSpace(Feed)
            && !string.Equals(Feed, "following", StringComparison.OrdinalIgnoreCase))
        {
            Navigation.NavigateTo(GetHomeQuery(sort: normalizedSort, feed: "following", query: Query, page: requestedPage), forceLoad: true);
            return;
        }

        if (IsFollowingFeed && !isFeedPageRoute)
        {
            Navigation.NavigateTo(GetHomeQuery(sort: normalizedSort, feed: "following", query: Query, page: requestedPage), forceLoad: true);
            return;
        }

        if (IsFollowingFeed && string.IsNullOrWhiteSpace(CurrentUserName))
        {
            NavigateToLogin(GetCurrentPathWithQuery());
            return;
        }

        await LoadPostsAsync();
    }

    private async Task LoadPostsAsync()
    {
        currentPage = ListQueryUrlBuilder.ParsePage(PageQuery);
        displayedSearchMessage = null;
        actionMessage = string.Empty;

        var normalizedQuery = Query?.Trim();
        var structuredSearch = ResolveSearchDestination(normalizedQuery);

        var allPosts = string.IsNullOrWhiteSpace(Query)
            ? await GetDefaultPostSourceAsync()
            : structuredSearch is null
                ? await BlogService.SearchPostsAsync(Query)
                : await structuredSearch.Value.QueryHandler();

        if (IsFollowingFeed)
        {
            allPosts = await ApplyFollowingScopeAsync(allPosts);
        }

        if (string.IsNullOrWhiteSpace(Query) && IsFollowingFeed && CurrentUser is null)
        {
            displayedSearchMessage = "팔로우 피드는 로그인 후 이용 가능합니다.";
        }
        else if (string.IsNullOrWhiteSpace(Query) && IsFollowingFeed && !allPosts.Any())
        {
            displayedSearchMessage = "팔로우한 작성자가 없습니다. 작성자 페이지에서 팔로우해 보세요.";
        }

        if (IsSearchOnlyPrefix(Query))
        {
            displayedSearchMessage = $"{GetDisplayedQuery()} 뒤에 검색어를 입력해 주세요.";
        }
        else if (!string.IsNullOrWhiteSpace(Query) && allPosts.Count == 0)
        {
            displayedSearchMessage = IsFollowingFeed
                ? $"팔로우 피드에서 \"{GetDisplayedQuery()}\"에 대한 검색 결과가 없습니다."
                : $"\"{GetDisplayedQuery()}\"에 대한 검색 결과가 없습니다.";
        }

        allPosts = SortPosts(allPosts);
        totalCount = allPosts.Count;
        totalPages = totalCount == 0 ? 0 : (int)Math.Ceiling(totalCount / 6d);
        currentPage = Math.Min(currentPage, Math.Max(1, totalPages));
        posts = allPosts.Skip((currentPage - 1) * 6).Take(6).ToList();
        trendingTagCloud = await BlogService.GetTagCloudAsync(10);
    }

    private string CurrentUserName => AuthService.CurrentUser?.UserName ?? string.Empty;
    private AuthUser? CurrentUser => AuthService.CurrentUser;

    private static string GetPostUrl(BlogPost post)
        => $"/@{Uri.EscapeDataString(post.Author)}/{Uri.EscapeDataString(post.Slug)}";

    private static string GetPostCommentsUrl(BlogPost post)
        => $"{GetPostUrl(post)}#comments";

    private async Task ToggleLikeAsync(string slug)
    {
        if (CurrentUser is null)
        {
            NavigateToLogin(GetLoginReturnUrl());
            return;
        }

        if (pendingLikeSlugs.Contains(slug))
        {
            return;
        }

        pendingLikeSlugs.Add(slug);
        actionMessage = string.Empty;
        StateHasChanged();

        try
        {
            await BlogService.ToggleLikeAsync(slug, CurrentUser.UserName);
            await LoadPostsAsync();
        }
        finally
        {
            pendingLikeSlugs.Remove(slug);
            actionMessage = string.Empty;
            StateHasChanged();
        }
    }

    private async Task ToggleBookmarkAsync(string slug)
    {
        if (CurrentUser is null)
        {
            NavigateToLogin(GetLoginReturnUrl());
            return;
        }

        if (pendingBookmarkSlugs.Contains(slug))
        {
            return;
        }

        pendingBookmarkSlugs.Add(slug);
        actionMessage = string.Empty;
        StateHasChanged();

        try
        {
            await BlogService.ToggleBookmarkAsync(slug, CurrentUser.UserName);
            await LoadPostsAsync();
        }
        finally
        {
            pendingBookmarkSlugs.Remove(slug);
            actionMessage = string.Empty;
            StateHasChanged();
        }
    }

    private bool IsPostBusy(string slug, HashSet<string> busySet) => busySet.Contains(slug);

    private string GetSearchResultHref()
    {
        var normalizedSearch = searchText.Trim();
        return GetHomeQuery(sort: normalizedSort, feed: normalizedFeed, query: normalizedSearch, page: 1);
    }

    private void HandleSearchInputChanged(ChangeEventArgs e)
    {
        searchText = e?.Value?.ToString() ?? string.Empty;
    }

    private void HandleSearchKeyDown(KeyboardEventArgs e)
    {
        if (!string.Equals(e.Key, "Enter", StringComparison.OrdinalIgnoreCase))
        {
            return;
        }

        Navigation.NavigateTo(GetSearchResultHref());
    }

    private async Task<IReadOnlyList<BlogPost>> GetDefaultPostSourceAsync()
    {
        if (!IsFollowingFeed)
        {
            return await BlogService.GetLatestAsync(200);
        }

        var following = await AuthService.GetFollowingAsync(CurrentUserName);
        var followingPosts = await BlogService.GetByAuthorsAsync(following);
        return followingPosts;
    }

    private async Task<IReadOnlyList<BlogPost>> ApplyFollowingScopeAsync(IReadOnlyList<BlogPost> source)
    {
        if (!IsFollowingFeed)
        {
            return source;
        }

        var following = await AuthService.GetFollowingAsync(CurrentUserName);
        if (following.Count == 0)
        {
            return Array.Empty<BlogPost>();
        }

        var followingSet = following.ToHashSet(StringComparer.OrdinalIgnoreCase);
        return source.Where(x => followingSet.Contains(x.Author)).ToList();
    }

    private void NavigateToLogin(string returnUrl)
    {
        var encoded = Uri.EscapeDataString(string.IsNullOrWhiteSpace(returnUrl) ? "/" : returnUrl);
        Navigation.NavigateTo($"/login?returnUrl={encoded}");
    }

    private string GetCurrentPathWithQuery()
    {
        var uri = new Uri(Navigation.Uri);
        return string.IsNullOrWhiteSpace(uri.Query) ? uri.AbsolutePath : $"{uri.AbsolutePath}{uri.Query}";
    }

    private string GetDiscoveryTitle()
    {
        return discoveryMode switch
        {
            "trending" => "트렌딩",
            "recommended" => "추천 글",
            "feed" => "팔로우 피드",
            _ => "최신 글"
        };
    }

    private string GetDiscoveryDescription()
    {
        return discoveryMode switch
        {
            "trending" => "slogs에서 반응이 높은 글을 먼저 보여줍니다.",
            "recommended" => "참여도와 글 정보를 바탕으로 읽을 만한 글을 추천합니다.",
            "feed" => "팔로우한 작성자의 글만 모아 봅니다.",
            _ => "slogs에 올라온 새 글을 빠르게 살펴봅니다."
        };
    }

    private string GetSeoTitle()
    {
        return string.IsNullOrWhiteSpace(Query)
            ? $"{GetDiscoveryTitle()} | slogs"
            : $"{GetDisplayedQuery()} 검색 결과 | slogs";
    }

    private string GetSeoDescription()
    {
        return string.IsNullOrWhiteSpace(Query)
            ? GetDiscoveryDescription()
            : $"slogs에서 {GetDisplayedQuery()} 검색 결과를 확인합니다.";
    }

    private string GetSeoCanonicalPath()
    {
        var path = new Uri(Navigation.Uri).AbsolutePath;
        return string.IsNullOrWhiteSpace(path) ? "/" : path;
    }

    private bool ShouldNoIndex => IsFollowingFeed || !string.IsNullOrWhiteSpace(Query);

    private string GetDiscoveryTabClass(string mode)
    {
        return string.Equals(discoveryMode, mode, StringComparison.OrdinalIgnoreCase)
            ? "rounded-full bg-slate-900 px-3 py-1.5 text-sm font-semibold text-white"
            : "rounded-full border border-slate-300 bg-white px-3 py-1.5 text-sm font-semibold text-slate-700 transition hover:bg-slate-100";
    }

    private string GetLoginReturnUrl()
    {
        return GetHomeQuery(sort: normalizedSort, feed: normalizedFeed, query: Query, page: currentPage);
    }

    private IReadOnlyList<BlogPost> SortPosts(IEnumerable<BlogPost> source)
    {
        return normalizedSort switch
        {
            "popular" => source.OrderByDescending(x => x.LikeCount * 2 + x.ViewCount).ThenByDescending(x => x.PublishedAt).ToList(),
            "recommended" => source.OrderByDescending(GetRecommendedScore).ThenByDescending(x => x.UpdatedAt).ThenByDescending(x => x.PublishedAt).ToList(),
            "updated" => source.OrderByDescending(x => x.UpdatedAt).ThenByDescending(x => x.PublishedAt).ToList(),
            _ => source.OrderByDescending(x => x.PublishedAt).ToList()
        };
    }

    private static int GetRecommendedScore(BlogPost post)
    {
        return post.LikeCount * 4
            + post.CommentCount * 3
            + post.ViewCount
            + post.Tags.Count
            + post.Series.Count * 2
            + Math.Min(post.ReadTimeMinutes, 20);
    }

    private string GetSortQuery(string? sort)
    {
        return GetHomeQuery(sort: sort, feed: normalizedFeed, query: Query, page: 1);
    }

    private string GetPageHref(int targetPage)
    {
        var page = Math.Max(1, targetPage);
        return GetHomeQuery(sort: normalizedSort, feed: normalizedFeed, query: Query, page: page);
    }

    private (string? Display, Func<Task<IReadOnlyList<BlogPost>>> QueryHandler)? ResolveSearchDestination(string? query)
    {
        if (string.IsNullOrWhiteSpace(query))
        {
            return null;
        }

        if (query.StartsWith("#", StringComparison.Ordinal))
        {
            var tag = query[1..].Trim();
            return string.IsNullOrWhiteSpace(tag)
                ? ("태그", () => GetFallbackQueryPostsAsync())
                : ($"# {tag}", () => BlogService.GetByTagAsync(tag));
        }

        if (query.StartsWith("@@", StringComparison.Ordinal))
        {
            var writer = query[2..].Trim();
            return string.IsNullOrWhiteSpace(writer)
                ? ("작성자", () => GetFallbackQueryPostsAsync())
                : ($"작성자: {writer}", () => BlogService.GetByAuthorAsync(writer));
        }

        if (query.StartsWith("@", StringComparison.Ordinal))
        {
            var writer = query[1..].Trim();
            return string.IsNullOrWhiteSpace(writer)
                ? ("작성자", () => GetFallbackQueryPostsAsync())
                : ($"작성자: {writer}", () => BlogService.GetByAuthorAsync(writer));
        }

        if (query.StartsWith("tag:", StringComparison.OrdinalIgnoreCase))
        {
            var tag = query[4..].Trim();
            return string.IsNullOrWhiteSpace(tag)
                ? ("태그", () => GetFallbackQueryPostsAsync())
                : ($"태그: {tag}", () => BlogService.GetByTagAsync(tag));
        }

        if (query.StartsWith("writer:", StringComparison.OrdinalIgnoreCase))
        {
            var writer = query[7..].Trim();
            return string.IsNullOrWhiteSpace(writer)
                ? ("작성자", () => GetFallbackQueryPostsAsync())
                : ($"작성자: {writer}", () => BlogService.GetByAuthorAsync(writer));
        }

        if (query.StartsWith("series:", StringComparison.OrdinalIgnoreCase))
        {
            var series = query[7..].Trim();
            return string.IsNullOrWhiteSpace(series)
                ? ("시리즈", () => GetFallbackQueryPostsAsync())
                : ($"시리즈: {series}", () => BlogService.GetBySeriesAsync(series));
        }

        return null;
    }

    private string GetDisplayedQuery()
    {
        var structured = ResolveSearchDestination(Query);
        if (structured is null)
        {
            return Query ?? string.Empty;
        }

        return structured.Value.Display ?? Query ?? string.Empty;
    }

    private static bool IsSearchOnlyPrefix(string? query)
    {
        if (string.IsNullOrWhiteSpace(query))
        {
            return false;
        }

        var trimmed = query.Trim();
        return trimmed is "#" or "@"
            || trimmed is "@@"
            || (trimmed.Length == 4 && trimmed.StartsWith("tag:", StringComparison.OrdinalIgnoreCase))
            || (trimmed.Length == 7 && trimmed.StartsWith("writer:", StringComparison.OrdinalIgnoreCase))
            || (trimmed.Length == 7 && trimmed.StartsWith("series:", StringComparison.OrdinalIgnoreCase));
    }

    private Task<IReadOnlyList<BlogPost>> GetFallbackQueryPostsAsync()
    {
        return BlogService.GetLatestAsync(200);
    }

    private string GetSortChipClass(string? sort)
    {
        var target = (sort ?? string.Empty).Trim().ToLowerInvariant();
        var current = string.IsNullOrWhiteSpace(normalizedSort) ? "latest" : normalizedSort!;
        var isActive = (target == "latest" ? string.IsNullOrWhiteSpace(current) || current == "latest" : current == target);

        return isActive
            ? "rounded-full bg-slate-900 px-3 py-1.5 text-sm font-semibold text-white"
            : "rounded-full border border-slate-300 bg-white px-3 py-1.5 text-sm font-semibold text-slate-700 hover:bg-slate-100";
    }

    private string GetFeedChipClass(string? feed)
    {
        if (string.IsNullOrWhiteSpace(feed))
        {
            return string.IsNullOrWhiteSpace(normalizedFeed)
                ? "rounded-full bg-slate-900 px-3 py-1.5 text-sm font-semibold text-white"
                : "rounded-full border border-slate-300 bg-white px-3 py-1.5 text-sm font-semibold text-slate-700 hover:bg-slate-100";
        }

        return string.Equals(feed, normalizedFeed, StringComparison.OrdinalIgnoreCase)
            ? "rounded-full bg-slate-900 px-3 py-1.5 text-sm font-semibold text-white"
            : "rounded-full border border-slate-300 bg-white px-3 py-1.5 text-sm font-semibold text-slate-700 hover:bg-slate-100";
    }

    private string GetHomeQuery(string? sort, string? feed = null, string? query = null, int? page = null)
    {
        var isFollowing = string.Equals(feed, "following", StringComparison.OrdinalIgnoreCase);
        var basePath = isFollowing
            ? "/feed"
            : GetBasePathForSort(sort);
        var builderFeed = string.Equals(feed, "following", StringComparison.OrdinalIgnoreCase) ? null : feed;
        var builderSort = IsDefaultSortForBasePath(basePath, sort) ? null : sort;
        return ListQueryUrlBuilder.Build(basePath, builderSort, query, page ?? 1, totalPages, builderFeed);
    }

    private static string ResolveDiscoveryMode(string path)
    {
        if (string.Equals(path, "/trending", StringComparison.OrdinalIgnoreCase))
        {
            return "trending";
        }

        if (string.Equals(path, "/recommended", StringComparison.OrdinalIgnoreCase))
        {
            return "recommended";
        }

        if (string.Equals(path, "/feed", StringComparison.OrdinalIgnoreCase))
        {
            return "feed";
        }

        return "recent";
    }

    private static string? GetDefaultSortForDiscoveryMode(string mode)
    {
        return mode switch
        {
            "trending" => "popular",
            "recommended" => "recommended",
            _ => null
        };
    }

    private static string GetBasePathForSort(string? sort)
    {
        return sort switch
        {
            "popular" => "/trending",
            "recommended" => "/recommended",
            _ => "/recent"
        };
    }

    private static bool IsDefaultSortForBasePath(string basePath, string? sort)
    {
        return (string.Equals(basePath, "/trending", StringComparison.OrdinalIgnoreCase)
                && string.Equals(sort, "popular", StringComparison.OrdinalIgnoreCase))
            || (string.Equals(basePath, "/recommended", StringComparison.OrdinalIgnoreCase)
                && string.Equals(sort, "recommended", StringComparison.OrdinalIgnoreCase))
            || (string.Equals(basePath, "/recent", StringComparison.OrdinalIgnoreCase)
                && string.IsNullOrWhiteSpace(sort));
    }

    private IEnumerable<int> GetPageNumbers()
    {
        if (totalPages <= 1)
        {
            yield break;
        }

        const int maxButtons = 7;
        var half = maxButtons / 2;
        var start = Math.Max(1, currentPage - half);
        var end = Math.Min(totalPages, start + maxButtons - 1);
        if (end - start + 1 < maxButtons)
        {
            start = Math.Max(1, end - maxButtons + 1);
        }

        for (var pageNumber = start; pageNumber <= end; pageNumber++)
        {
            yield return pageNumber;
        }
    }

    private bool IsFollowingFeed => string.Equals(normalizedFeed, "following", StringComparison.OrdinalIgnoreCase);
    private bool isFeedPageRoute;

    private static string Shorten(string text, int maxLength)
    {
        if (string.IsNullOrWhiteSpace(text))
        {
            return string.Empty;
        }

        if (text.Length <= maxLength)
        {
            return text;
        }

        return text[..maxLength] + "...";
    }

    private static string FormatDate(DateTime dateTime) => dateTime.ToLocalTime().ToString("yyyy.MM.dd");

}


